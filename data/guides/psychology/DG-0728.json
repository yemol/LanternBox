    "降级处理",
    "轮休",
    "疲劳",
    "休息",
    "任务安排"
  ],
  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先列出必须连续有人负责的岗位，如火源、照护、入口观察。",
    "为每个岗位设置最长连续时间，超过就必须交接。",
    "交接时只说当前状态、异常、下一次检查时间。",
    "让最疲劳的人先离开高风险岗位，补水、进食和睡眠。",
    "每天复盘谁超时，第二天优先调整。"
  ],
  "check": [
    "每个关键岗位有交接人。",
    "连续值守时间受限。",
    "疲劳者不操作高风险任务。"
  ],
  "common_mistakes": [
    "奖励能熬的人继续熬。",
    "交接只靠一句没事。",
    "把休息看成偷懒。"
  ],
  "fallback": [
    "人手不足时降低任务频率，保留生命安全岗位。",
    "没有表时用餐次、天光和固定巡查轮次计时。"
  ],
  "stop_or_escalate": [
    "值守者打瞌睡、反应慢或发怒。",
    "连续交接失败。",
    "火源、照护或入口观察无人负责。"
  ],
