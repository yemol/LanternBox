{
  "id": "DG-0720",
  "title": "老人焦虑反复询问照护",
  "category": "心理韧性与冲突降温",
  "priority": "P1",
  "scenario": "老人反复询问消息、亲人、药物、撤离时间或物资是否够。",
  "goal": "减少不确定感和争执，把重复询问转化为固定回应和照护记录。",
  "keywords": [
    "psychology",
    "心理韧性与冲突降温",
    "老人焦虑反复询问照护",
    "长期断供",
    "小团队",
    "行动卡",
    "停止线",
    "降级处理",
    "老人焦虑",
    "反复询问",
    "照护",
    "安定"
  ],
  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先承认担心，不用你问过了来打断。",
    "写一张简短信息卡：今天日期、人在何处、下一次吃药或吃饭时间。",
    "固定一名成员在固定时间更新老人信息，不让多人给出不同说法。",
    "把药物、饮水、睡眠和排便变化记录下来。",
    "焦虑升高时减少消息轰炸，安排简单重复活动。"
  ],
  "check": [
    "老人能看到信息卡。",
    "回应口径一致。",
    "身体照护记录没有漏项。"
  ],
  "common_mistakes": [
    "嘲笑或责备重复询问。",
    "每个人给不同答案。",
    "把焦虑都当成不配合。"
  ],
  "fallback": [
    "没有纸时用固定口头句式和墙面符号。",
    "人手不足时把更新安排在餐前和睡前两个固定点。"
  ],
  "stop_or_escalate": [
    "老人突然意识混乱、跌倒或拒绝饮水进食。",
    "焦虑导致外出寻找或干扰高风险任务。",
    "照护者疲劳到无法回应。"
  ],
  "related_wiki": [
    "心理韧性与冲突降温",
    "压力下的团队协作"
  ],
  "notes": "长期断供和小团队场景下的非对抗行动卡；重点是低暴露、边界、记录、照护和降温。",
