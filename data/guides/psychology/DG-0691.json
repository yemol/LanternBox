  "tools": [
    "暂停口令卡",
    "计时器",
    "安静角",
    "记录纸",
    "水"
  ],
  "steps": [
    "团队提前约定一个短口令，任何成员都可在争吵升级前使用。",
    "听到口令后双方停止解释，先分开到不同位置十分钟。",
    "旁观者不站队、不继续转述，只保护物资和人员距离。",
    "十分钟后只讨论事实和下一步动作，不追溯人格评价。",
    "反复触发的主题写入复盘，不在疲劳时继续争论。"
  ],
  "check": [
    "争吵升级前暂停口令的责任人或边界已明确。",
    "关键记录已写下并可复核。",
    "下一步停止或复查条件清楚。"
  ],
  "common_mistakes": [
    "只靠口头记忆。",
    "临时扩大范围。",
    "没有设置复查时间。"
  ],
  "fallback": [
    "人员不足时先保留最关键任务，暂停低价值动作。",
    "记录材料不足时使用固定符号或墙面记录，但要能被下一班理解。"
  ],
  "stop_or_escalate": [
    "出现人员失联、冲突升级、污染扩散或边界被突破时停止普通流程。",
    "情况超出原计划时，由负责人重新复核，而不是个人临时决定。"
  ],
