  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先暂停讨论结论，确认双方最近睡眠和连续工作时间。",
    "把争执双方分开十分钟，给水和安静位置。",
    "由第三人接管当前任务，避免疲劳者继续操作火源、刀具或外出。",
    "争议事项写下来，推迟到补眠后再决定。",
    "当天减少非必要任务，优先安排轮休。"
  ],
  "check": [
    "争执双方已分开。",
    "高风险任务已交接。",
    "争议没有在极度疲劳时决定。"
  ],
  "common_mistakes": [
    "逼疲劳者马上认错。",
    "把睡眠不足解释成人品问题。",
    "继续让争执者同组工作。"
  ],
  "fallback": [
    "没有第三人时，先停止低价值任务，双方轮流休息。",
    "空间不足时至少背向坐开，暂停对话。"
  ],
  "stop_or_escalate": [
    "有人出现意识模糊、明显失控或持续失眠。",
    "争执涉及推搡、抢夺或危险工具。",
    "关键照护无人接手。"
  ],
