    "口令卡"
  ],
  "steps": [
    "先处理后果：人员、物资、环境和下一步风险。",
    "复盘时只按事实顺序记录，不先问谁的错。",
    "每个人只说一个可改进点和一个需要支持的地方。",
    "把结论写成规则、清单或停止线，而不是人格评价。",
    "设置复查时间，看新规则是否有效。"
  ],
  "check": [
    "后果已先处理。",
    "复盘输出是规则或清单。",
    "没有用羞辱代替改进。"
  ],
  "common_mistakes": [
    "一开始就追责。",
    "把失败藏起来。",
    "复盘开成情绪发泄会。"
  ],
  "fallback": [
    "时间紧时先写三行：发生了什么、损失什么、下次停止线。",
    "情绪太高时推迟深度复盘，先做安全处置。"
  ],
  "stop_or_escalate": [
    "失败导致伤病或重大安全风险。",
    "有人因害怕责备隐瞒事实。",
    "复盘引发新的冲突。"
  ],
