  "tools": [
    "信息卡",
    "座位区",
    "水杯",
    "时间表",
    "笔"
  ],
  "steps": [
    "每天固定两到三次同步关键信息：安全、食物、水、家人和下一步。",
    "使用短句和同一张信息卡，不让多人给出不同版本。",
    "允许老人提出一个最担心的问题，并写下回答。",
    "安排可参与的小任务，如看时间、折布、提醒饮水。",
    "若焦虑加重，减少嘈杂围观，安排熟悉成员陪伴。"
  ],
  "check": [
    "老人焦虑信息同步的责任人或边界已明确。",
    "关键记录已写下并可复核。",
    "下一步停止或复查条件清楚。"
  ],
  "common_mistakes": [
    "只靠口头记忆。",
    "临时扩大范围。",
    "没有设置复查时间。"
  ],
  "fallback": [
    "人员不足时先保留最关键任务，暂停低价值动作。",
    "记录材料不足时使用固定符号或墙面记录，但要能被下一班理解。"
  ],
  "stop_or_escalate": [
    "出现人员失联、冲突升级、污染扩散或边界被突破时停止普通流程。",
    "情况超出原计划时，由负责人重新复核，而不是个人临时决定。"
  ],
