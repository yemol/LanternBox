  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先核实消息来源和不确定点，没确认的内容明确标注。",
    "选择人员相对稳定、没有高风险操作的时间传达。",
    "先说事实，再说影响，最后说接下来两件可做的事。",
    "给成员提问时间，但不允许传言接力和互相指责。",
    "传达后更新任务板，让团队看到下一步秩序仍在。"
  ],
  "check": [
    "事实和推测已分开。",
    "传达后有具体下一步。",
    "没有在疲劳和危险操作中突然宣布。"
  ],
  "common_mistakes": [
    "为了安慰隐瞒关键事实。",
    "一次性倾倒所有恐惧推测。",
    "把坏消息变成追责大会。"
  ],
  "fallback": [
    "信息不完整时说目前只知道这些，并设定复查时间。",
    "人群不稳定时先通知核心照护者和负责人。"
  ],
