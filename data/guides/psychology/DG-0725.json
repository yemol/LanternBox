  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先把人带离围观处，问清拒绝原因：不会、害怕、太累、不同意还是身体不适。",
    "复述原因，不急着贴懒惰或不服从标签。",
    "把任务拆小或换成同等价值的低风险任务。",
    "确认对方能在多久内完成哪一项，并写到任务板。",
    "若持续拒绝，交由团队复核规则和照护状态，不当场羞辱。"
  ],
  "check": [
    "拒绝原因被记录。",
    "任务已拆分或替换。",
    "团队知道下一步谁负责。"
  ],
  "common_mistakes": [
    "公开羞辱。",
    "把恐惧和不会做当故意破坏。",
    "没人接管原任务。"
  ],
  "fallback": [
    "沟通困难时先暂停该成员高风险任务，安排整理、记录或照护辅助。",
    "人手紧张时缩小任务目标，保留核心安全。"
  ],
  "stop_or_escalate": [
    "拒绝源于伤病、极度疲劳或明显恐慌。",
    "关键任务无人可接。",
    "成员出现离队、破坏或自伤风险。"
  ],
