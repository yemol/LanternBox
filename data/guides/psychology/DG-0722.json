{
  "id": "DG-0722",
  "title": "两人争执升级降温",
  "category": "心理韧性与冲突降温",
  "priority": "P1",
  "scenario": "两名成员围绕任务、配给、照护或责任开始提高音量、贴近身体或翻旧账。",
  "goal": "把人和问题分开，先降温再处理事实。",
  "keywords": [
    "psychology",
    "心理韧性与冲突降温",
    "两人争执升级降温",
    "长期断供",
    "小团队",
    "行动卡",
    "停止线",
    "降级处理",
    "争执升级",
    "冲突降温",
    "暂停",
    "团队"
  ],
  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "旁观者先用中性句打断：先停两分钟，任务先保住。",
    "让双方后退到不同位置，不让围观者继续评论。",
    "各自只写一句事实和一个请求，不写评价。",
    "由第三人确认当前最紧急任务是否需要交接。",
    "半小时后只讨论下一步安排，深层矛盾放到复盘时间。"
  ],
  "check": [
    "双方距离拉开。",
    "围观被停止。",
    "当前任务没有因争执失控。"
  ],
  "common_mistakes": [
    "让大家评理投票。",
    "当场追问谁错。",
    "继续让双方共同处理危险工具。"
  ],
  "fallback": [
    "没有第三人时，双方先各自停止五分钟，按纸条交换请求。",
    "空间不足时至少背向坐开并降低音量。"
  ],
  "stop_or_escalate": [
    "出现推搡、摔物或威胁。",
    "争执者拒绝分开。",
    "儿童老人被卷入或惊吓严重。"
  ],
  "related_wiki": [
