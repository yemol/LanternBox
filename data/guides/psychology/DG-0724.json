    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先暂停临时分发，公布当前总量、预计天数和优先原则。",
    "解释特殊配给原因，如儿童、老人、病人、高强度值班。",
    "让成员提出一条可执行调整，不进行人格争辩。",
    "把最终配给规则写下，并设定下一次复核时间。",
    "分发时双人记录，减少私下猜疑。"
  ],
  "check": [
    "配给规则公开。",
    "特殊照护理由清楚。",
    "下一次复核时间明确。"
  ],
  "common_mistakes": [
    "私下临时加减。",
    "用道德压制质疑。",
    "让饥饿成员参与无休止争论。"
  ],
  "fallback": [
    "记录不足时先按人数和特殊需求做临时一餐规则。",
    "争议大时先保底分配，复核后调整。"
  ],
  "stop_or_escalate": [
    "出现抢夺、藏匿或拒绝照护脆弱成员。",
