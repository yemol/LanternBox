    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先确认计划返回时间、路线、人员、携带物和最后消息。",
    "让留守者暂停猜测，只按时间点记录事实。",
    "保留驻地照护和物资管理，不全员外出寻找。",
    "到达预设超时时间后，由两人以内按备用路线低风险查看。",
    "无消息继续扩大时，按撤离、求援或等待计划复核，不临时冲动行动。"
  ],
  "check": [
    "事实记录完整。",
    "驻地没有无人看守。",
    "查看行动人数和路线受控。"
  ],
  "common_mistakes": [
    "所有人一起冲出去找。",
    "把最坏猜测传播给儿童老人。",
    "不断改变等待时间。"
  ],
  "fallback": [
    "没有预设超时时间时，按天光、天气和人员体力设定一个保守点。",
    "人手不足时优先守住驻地并留下明显返回标记。"
  ],
  "stop_or_escalate": [
    "外出者涉及伤病、危险天气或冲突区域。",
    "留守人员情绪失控。",
    "第二组也超时未归。"
  ],
