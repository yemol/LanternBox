  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先选十五到三十分钟内能完成、低风险、看得见结果的任务。",
    "任务只给一个明确完成标准，如装满三瓶水、清出一米通道、更新一张清单。",
    "把成员分成两人小组，避免独自陷入焦虑。",
    "完成后公开确认成果，再安排下一轮。",
    "不要用小任务掩盖真正需要休息或医疗的情况。"
  ],
  "check": [
    "任务短、低风险、有完成标准。",
    "成员重新开始协作。",
    "完成后有简短确认。"
  ],
  "common_mistakes": [
    "安排巨大目标。",
    "把小任务变成惩罚。",
    "让疲劳者继续硬撑。"
  ],
  "fallback": [
    "物资少时选择整理、清洁、记录或照护类任务。",
    "人员情绪很差时先做安静任务，如折叠、分类、标记。"
  ],
  "stop_or_escalate": [
    "成员无法理解简单指令。",
    "小任务引发更多争执。",
    "有人需要立即休息或照护。"
  ],
