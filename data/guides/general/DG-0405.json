{
  "id": "DG-0405",
  "title": "急救角色演练",
  "category": "组织秩序与训练演练",
  "scenario": "发生割伤、摔倒、烫伤、发热或昏厥时，大家容易围观或乱帮忙。",
  "goal": "提前分配急救中的角色，减少现场混乱。",
  "tools": [
    "急救包",
    "角色卡",
    "记录本"
  ],
  "steps": [
    "设定急救场景，例如手部割伤或有人摔倒。",
    "分配角色：处理者、记录者、取物者、清场者、照护家属者。",
    "演练谁去拿急救包、谁记录时间和症状。",
    "清场者负责让无关人员后退，保持空气和空间。",
    "演练结束后检查急救包是否归位。",
    "复盘谁不知道做什么，修改角色卡。",
    "不演练危险动作，只演练流程和分工。"
  ],
  "check": [
    "角色明确。",
    "急救包能找到。",
    "记录者知道记录什么。"
  ],
  "common_mistakes": [
    "所有人围上去。",
    "没人记录时间。",
    "急救包演练后没放回。"
  ],
  "fallback": "人数少时，一个人可以兼任记录和取物，但必须明确。",
  "stop_or_escalate": [
    "真实急救中出现大出血、意识异常、呼吸问题时，按急救处理，不继续演练。"
  ],
  "notes": "急救现场最先需要处理的，有时是围观的人群。",
