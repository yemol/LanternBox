{
  "id": "DG-0142",
  "title": "共同值守规则",
  "category": "组织秩序与训练演练",
  "priority": "P1",
  "scenario": "多个家庭或小队轮流观察入口、水源、火源、儿童区或污染区。",
  "goal": "让共同值守可持续、可交接、不变成个人权力。",
  "tools": [
    "排班表",
    "哨子",
    "手电",
    "记录本",
    "公告板"
  ],
  "steps": [
    "写出值守目标：观察什么、何时叫人、不能独自做什么。",
    "按时间排班，避免同一个人连续熬夜。",
    "值守交接必须说清异常、未完成任务和下一班重点。",
    "值守者只负责预警，不单独处理冲突和危险源。",
    "每班记录时间、天气、人员、动物、水位或异常声音。",
    "值守表公开，让所有参与者知道轮换顺序。"
  ],
  "check": [
    "排班清楚。",
    "交接有记录。",
    "值守者不独自处理危险。"
  ],
  "common_mistakes": [
    "让一个人长期值守。",
    "值守者把岗位当权力。",
    "发现异常自己追出去。"
  ],
  "fallback": [
    "人手不足时，缩短值守窗口，只守最关键时段和位置。"
  ],
  "stop_or_escalate": [
    "值守者疲劳、冲突靠近、水源异常、火源异常时，立即叫醒负责人。"
  ],
  "notes": "共同值守的核心是预警，不是逞强。",
