  "steps": [
    "列出夜间必须有人负责的事项：火源、入口、病人、通信窗口和天气变化。",
    "每班写明开始结束时间、负责人、备用叫醒人和不得离岗事项。",
    "交接时上一班口头说明异常、未完成事项和下一次检查点。",
    "接班人确认手电、记录表和必要工具在手边。",
    "清晨复盘是否有漏记、迟到或疲劳成员。"
  ],
  "check": [
    "夜间轮值交接表的责任人或边界已明确。",
    "关键记录已写下并可复核。",
    "下一步停止或复查条件清楚。"
  ],
  "common_mistakes": [
    "只靠口头记忆。",
    "临时扩大范围。",
    "没有设置复查时间。"
  ],
  "fallback": [
    "人员不足时先保留最关键任务，暂停低价值动作。",
    "记录材料不足时使用固定符号或墙面记录，但要能被下一班理解。"
  ],
  "stop_or_escalate": [
    "出现人员失联、冲突升级、污染扩散或边界被突破时停止普通流程。",
    "情况超出原计划时，由负责人重新复核，而不是个人临时决定。"
