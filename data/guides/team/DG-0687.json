  "tools": [
    "外出登记表",
    "笔",
    "计时器",
    "入口检查点",
    "标签"
  ],
  "steps": [
    "外出前登记姓名、任务、路线、同行人、携带物和最晚返回时间。",
    "留守人复述任务边界，确认不得临时扩大目标。",
    "返回时先在入口报到，检查人员、物品、受伤、污染和异常接触。",
    "取回物资先放待检区，不直接进入食物水区。",
    "超时未归按预案复核，不派单人追出。"
  ],
  "check": [
    "外出登记和归队检查的责任人或边界已明确。",
    "关键记录已写下并可复核。",
    "下一步停止或复查条件清楚。"
  ],
  "common_mistakes": [
    "只靠口头记忆。",
    "临时扩大范围。",
    "没有设置复查时间。"
  ],
  "fallback": [
    "人员不足时先保留最关键任务，暂停低价值动作。",
    "记录材料不足时使用固定符号或墙面记录，但要能被下一班理解。"
  ],
  "stop_or_escalate": [
    "出现人员失联、冲突升级、污染扩散或边界被突破时停止普通流程。",
    "情况超出原计划时，由负责人重新复核，而不是个人临时决定。"
  ],
