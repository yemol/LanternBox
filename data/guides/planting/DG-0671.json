{
  "id": "DG-0671",
  "title": "种子干燥封存",
  "category": "种植",
  "priority": "P1",
  "scenario": "种子需要长期留存，但环境潮湿或温差大，可能提前发霉、虫蛀或失去发芽力。",
  "goal": "把种子干燥、分批、标记和离地封存，保留后续种植选择。",
  "keywords": [
    "种植",
    "种植",
    "种子干燥封存",
    "长期断供",
    "小团队",
    "行动卡",
    "种子干燥封存",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "纸袋或布袋",
    "干燥容器",
    "标签",
    "干布",
    "记录纸"
  ],
  "steps": [
    "先剔除破损、霉味、虫蛀和不明来源种子，避免混入主库存。",
    "把同一种子分成至少两小包，写明名称、来源、收集日期和预计用途。",
    "确认种子表面干燥后再封存，不把刚采下或受潮种子直接密封。",
    "容器放在阴凉、离地、避光位置，远离燃料、清洁剂和鼠害痕迹。",
    "每月抽查一小包外观和气味，只打开复查包，不频繁开启主包。"
  ],
  "check": [
    "种子已分批并标记。",
    "受潮或霉味种子未混入主库存。",
    "封存点离地、避光且远离污染物。"
  ],
  "common_mistakes": [
    "把潮湿种子直接装进密封袋。",
    "所有种子混成一大包。",
    "频繁打开主库存检查。"
  ],
  "fallback": [
    "没有密封容器时，先用纸袋或布袋透气干燥，再放入较干燥的盒中。",
    "不确定品种时，单独标记待试种，不和可靠种子混放。"
  ],
  "stop_or_escalate": [
    "发现霉味、虫粉、结块或容器进水时，停止使用该批做主种源。",
    "主库存被污染时，优先保留未开封备份包。"
  ],
