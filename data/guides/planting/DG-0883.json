{
  "id": "DG-0883",
  "title": "病虫害早期隔离与工具分流",
  "category": "种植与食物生产",
  "priority": "P0",
  "scenario": "叶背出现虫卵幼虫、植株有病斑腐烂，或工具可能把病害从问题区带到健康区。",
  "goal": "用巡查、隔离、人工处理和工具分区控制病虫害扩散。",
  "tools": [
    "地块标记",
    "单独手套",
    "待清洁工具盒",
    "记录纸",
    "隔离袋"
  ],
  "steps": [
    "停止跨区操作，先标记受影响作物、苗盘或地块。",
    "检查叶背、嫩梢、茎基、土面和病虫害扩散范围。",
    "人工清除虫卵幼虫或移除严重病株，并把残体隔离。",
    "剪过病株或接触腐烂苗盘的工具不进入健康区。",
    "记录处理数量、工具接触路径和复查时间。"
  ],
  "check": [
    "问题区有标记。",
    "病区工具和健康区工具分开。",
    "虫害或病害有复查记录。"
  ],
  "common_mistakes": [
    "用同一把剪刀从病株剪到留种株。",
    "只看叶面不看叶背。",
    "拔掉病株后残体丢在菜地边。"
  ],
  "fallback": [
    "缺工具时把一件工具限定为病区专用。",
    "人手不足时优先保护育苗区、留种株和主生产地块。",
    "严重局部可放弃，保护周边健康区。"
  ],
  "stop_or_escalate": [
    "病害迅速扩散、工具已跨多个健康区、不明化学污染或污染地块信号出现时，停止采收、移栽和跨区操作。",
    "无法分清污染边界时，先封区重建记录。"
  ],
  "notes": "Batch10-B Agriculture Second Stage v0.1 第一阶段行动知识链；不包含农药配方、化学灭虫剂自制或高复杂农业工程。",
