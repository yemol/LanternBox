{
  "id": "DG-0673",
  "title": "容器种植排水孔检查",
  "category": "种植",
  "priority": "P1",
  "scenario": "容器种植没有排水孔，浇水后容易烂根、发臭和滋生虫害。",
  "goal": "在播种或移栽前检查排水，避免把有限种子浪费在积水容器里。",
  "keywords": [
    "种植",
    "种植",
    "容器种植排水孔检查",
    "长期断供",
    "小团队",
    "行动卡",
    "容器种植排水孔检查",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "种植容器",
    "小刀或尖工具",
    "碎石或粗材料",
    "接水盘",
    "标签"
  ],
  "steps": [
    "先检查容器底部和侧下方是否有排水孔，旧桶旧盒要确认没有被泥堵住。",
    "没有排水孔时，在低位开多个小孔，孔口不要正对室内行走区。",
    "底部铺少量粗材料或架高容器，让多余水能离开根部。",
    "第一次浇水后观察排水速度，长时间积水的容器暂不播种。",
    "给容器贴上作物、日期和排水状态，后续浇水按土壤湿度而不是固定冲量。"
  ],
  "check": [
    "容器有可用排水孔。",
    "第一次浇水无长时间积水。",
    "容器标签包含作物和日期。"
  ],
  "common_mistakes": [
    "没有排水孔就直接播种。",
    "把接水盘积水长期留着。",
    "固定每天大量浇水。"
  ],
  "fallback": [
    "无法打孔时，把容器降级为短期育苗盘，并严格少量补水。",
    "没有粗材料时，至少架高容器并保持底部通风。"
  ],
  "stop_or_escalate": [
    "土壤发臭、根部发黑、虫害增加或水从容器外溢到生活区时停止继续使用。",
    "排水改造会割伤或损坏容器承重时，换低风险容器。"
  ],
