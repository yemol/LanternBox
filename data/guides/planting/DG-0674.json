{
  "id": "DG-0674",
  "title": "少水覆盖浇灌",
  "category": "种植",
  "priority": "P1",
  "scenario": "水量不足但仍要维持少量作物，裸露土面会快速失水。",
  "goal": "通过覆盖和定点浇灌减少蒸发，把水用在根区。",
  "keywords": [
    "种植",
    "种植",
    "少水覆盖浇灌",
    "长期断供",
    "小团队",
    "行动卡",
    "少水覆盖浇灌",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "干草或纸板",
    "小瓶",
    "标签",
    "土壤湿度记录",
    "遮阴物"
  ],
  "steps": [
    "先选择最有价值或最接近采收的作物，不把少量水平均分给所有盆。",
    "清除病叶和杂草，减少无效耗水。",
    "用干草、纸板或干净落叶覆盖土面，覆盖物不要贴住茎基部。",
    "用小瓶在根部少量慢浇，观察水是否渗入而不是从盆边流走。",
    "每日同一时间摸土记录湿度，连续过湿或过干都调整浇水。"
  ],
  "check": [
    "优先作物已选定。",
    "土面有覆盖且不贴茎。",
    "浇水集中在根区并有记录。"
  ],
  "common_mistakes": [
    "所有植物平均浇一点。",
    "覆盖物贴住茎导致腐烂。",
    "正午高温大量浇水。"
  ],
  "fallback": [
    "覆盖材料不足时，先覆盖最小、最易干的容器。",
    "水量极低时保留种源或多年生作物，放弃低价值幼苗。"
  ],
  "stop_or_escalate": [
    "覆盖后出现霉味、虫害或茎基腐烂时移除覆盖物。",
    "饮用水低于最低线时，暂停非关键浇灌。"
  ],
