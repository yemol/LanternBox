  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先把请求从现场带回评估，不当场承诺加入或入住。",
    "询问同行目的、人数、身体状况、携带物、目的地和能接受的边界。",
    "团队内部单独讨论，不让对方旁听库存、路线和人员弱点。",
    "若提供帮助，优先提供一次性信息或少量物资，不开放核心区域。",
    "需要临时同行时设置时间、距离、分工和退出条件。"
  ],
  "check": [
    "没有当场承诺长期同行。",
    "对方接受边界和退出条件。",
    "核心区域未开放。"
  ],
  "common_mistakes": [
    "因为同情直接带入驻地。",
    "让对方参与库存盘点。",
    "把拒绝说成永久敌意。"
  ],
  "fallback": [
    "无法评估时只提供公开方向或一次性援助。",
    "对方脆弱但风险不明时，联系可信第三方或安排外部等待点。"
  ],
  "stop_or_escalate": [
    "对方拒绝边界或要求立即进入。",
    "同行人数、目的或携带物前后矛盾。",
    "团队内部无法达成最低一致。"
  ],
