  "tools": [
    "交换袋",
    "清单",
    "记录纸",
    "遮盖布",
    "口令"
  ],
  "steps": [
    "交换前把本次可交换物资单独装袋，其他库存不出现在现场。",
    "交流时只说本次数量和状态，不谈总库存、存放位置和未来计划。",
    "一人交流一人观察周边，不让对方靠近住所或仓储点。",
    "交换后物品先隔离检查并记录来源。",
    "若对方追问库存，结束对话并改约或放弃。"
  ],
  "check": [
    "物资交换不暴露库存的责任人或边界已明确。",
    "关键记录已写下并可复核。",
    "下一步停止或复查条件清楚。"
  ],
  "common_mistakes": [
    "只靠口头记忆。",
    "临时扩大范围。",
    "没有设置复查时间。"
  ],
  "fallback": [
    "人员不足时先保留最关键任务，暂停低价值动作。",
    "记录材料不足时使用固定符号或墙面记录，但要能被下一班理解。"
  ],
  "stop_or_escalate": [
    "出现人员失联、冲突升级、污染扩散或边界被突破时停止普通流程。",
    "情况超出原计划时，由负责人重新复核，而不是个人临时决定。"
  ],
