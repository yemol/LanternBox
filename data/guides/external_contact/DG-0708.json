  "steps": [
    "先停止翻包和展示物品，把交换物收回到身体近侧。",
    "用短句说明边界：今天不做这个交换，我们需要回去复核。",
    "不要争论对方动机，不评价对方，只重复边界和结束时间。",
    "观察者提醒撤离路线，沟通者结束后缓慢离开。",
    "返回后记录拒绝原因，并暂缓再次接触。"
  ],
  "check": [
    "拒绝语句短且一致。",
    "没有继续讨价还价。",
    "人员已离开现场并记录原因。"
  ],
  "common_mistakes": [
    "解释太多暴露内部规则。",
    "被激将后继续谈。",
    "为了面子接受高风险条件。"
  ],
  "fallback": [
    "不敢当面拒绝时，改为需要回去确认，离开后取消。",
    "语言不通时用手势、纸条和退后动作表达结束。"
  ],
