  "steps": [
    "接触人员先洗手、换外层或隔离接触物，再进入核心区域。",
    "按时间顺序复述发生了什么，不先判断谁对谁错。",
    "列出暴露点：人数、库存、路线、脆弱成员、工具能力和习惯。",
    "决定下次级别：不再接触、低价值接触、可交换或需要观察。",
    "把结论写到外部接触记录，并告知留守人员。"
  ],
  "check": [
    "暴露点已列出。",
    "下次接触级别明确。",
    "换入物和接触人员已完成基础隔离。"
  ],
  "common_mistakes": [
    "回来后立刻混入人群和物资区。",
    "只讨论对方好坏，不讨论暴露了什么。",
    "没有把结论交接给下一班。"
  ],
  "fallback": [
    "人手不足时先完成隔离和三行复盘：发生、暴露、下次。",
