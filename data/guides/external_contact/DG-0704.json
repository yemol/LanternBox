  "steps": [
    "先把本次交换物单独装袋，现场不出现整箱、整包或库存清单。",
    "回答时只说本次可交换数量，不谈总量、存放点和未来补给计划。",
    "若对方追问库存，用固定句式结束：今天只处理这一份，其他不能谈。",
    "交换后检查是否有包装标记、标签或路线信息被留下。",
    "把对方追问情况写入记录，决定下次是否降级接触。"
  ],
  "check": [
    "现场只出现本次交换物。",
    "没有透露总库存和存放位置。",
    "追问被记录。"
  ],
  "common_mistakes": [
    "为了显得可信展示储备。",
    "让对方帮忙搬运到仓储区。",
    "承诺以后固定供给。"
  ],
  "fallback": [
    "没有小袋时用布包或不透明容器遮挡。",
    "来不及分装时取消交换，宁可失去本次机会。"
