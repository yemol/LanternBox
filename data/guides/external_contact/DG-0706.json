  "steps": [
    "交换结束后立即记录日期、地点、对象特征、换入换出物和数量。",
    "标明物品状态：是否开封、潮湿、破损、异味、来源不明。",
    "写下对方提出的额外要求、追问和下次接触暗示。",
    "把换入物先放隔离区，不直接进入饮食、医疗或核心工具区。",
    "一天内由非接触成员复核记录，决定是否允许下次交换。"
  ],
  "check": [
    "物品数量和来源可追溯。",
    "异常要求已记录。",
    "换入物未直接混入库存。"
  ],
  "common_mistakes": [
    "只记大概印象。",
    "把对方名字或特征写得别人无法理解。",
    "用未检查物品直接供儿童老人使用。"
  ],
  "fallback": [
    "没有纸笔时用固定符号或语音离线记录，稍后转写。",
    "疲劳时先写三项：谁、换了什么、异常点。"
  ],
