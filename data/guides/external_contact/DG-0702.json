{
  "id": "DG-0702",
  "title": "物资交换前风险评估",
  "category": "外部接触与交换风险",
  "priority": "P1",
  "scenario": "准备和外部人员交换水、食物、工具、药品或信息，但不确定对方可靠程度。",
  "goal": "在交换前判断是否值得接触，避免为了小物资暴露大风险。",
  "keywords": [
    "external_contact",
    "外部接触与交换风险",
    "物资交换前风险评估",
