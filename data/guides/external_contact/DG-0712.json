  "steps": [
    "先写下三类边界：可提供、需要复核、不能提供。",
    "把关键禁区列清楚：睡眠区、库存区、医疗区、记录本和核心设备。",
    "约定统一回应话术，所有成员都使用同一边界。",
    "每次接触后记录边界是否被尊重。",
    "边界被反复试探时，降低接触等级或暂停往来。"
  ],
  "check": [
    "可做和不可做事项清楚。",
    "成员回应一致。",
    "边界被突破会触发降级。"
  ],
  "common_mistakes": [
    "每个人按心情答应不同条件。",
    "把边界说成威胁。",
    "边界被突破后仍照常接触。"
  ],
  "fallback": [
    "来不及写完整规则时，先定三条：不进驻地、不看库存、不夜间交换。",
    "团队意见不一时按更保守边界执行。"
  ],
