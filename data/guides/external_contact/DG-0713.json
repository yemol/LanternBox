  "steps": [
    "先停止交易动作，把手从包内拿出，保持可见且不做突然动作。",
    "沟通者使用结束句：今天到这里，我们需要回去确认。",
    "观察者看退路，不和旁人争辩，不解释团队细节。",
    "按预定路线离开，不奔跑、不回头争吵、不直接回驻地。",
    "到安全点后清点人员物品，记录触发信号和后续限制。"
  ],
  "check": [
    "接触已在升级前结束。",
    "人员没有分散。",
    "撤离后未直接暴露驻地。"
  ],
  "common_mistakes": [
    "试图争赢道理。",
    "边退边骂或威胁。",
    "撤离时丢下儿童老人或关键物。"
  ],
  "fallback": [
    "没有预设路线时向开阔、人少、可观察方向移动。",
    "携带物过重时放弃低价值物品，保人和核心记录优先。"
  ],
