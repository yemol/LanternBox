    "不失控",
    "资源边界"
  ],
  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先确定互助目的：救急、共享信息、短时工具，还是共同观察。",
    "只承诺一次一项，不承诺长期供给、住宿或开放库存。",
    "用公开地点、固定时间和小数量方式交接。",
    "记录互助内容和对方是否按约定回馈、归还或停止。",
    "当互助影响团队基础安全时，暂停并重新说明边界。"
  ],
  "check": [
    "互助项目小且可停止。",
    "没有长期供给承诺。",
    "双方边界和记录清楚。"
  ],
  "common_mistakes": [
    "把好心变成无限责任。",
    "让互助对象知道全部库存。",
    "不记录借用和回馈。"
  ],
  "fallback": [
    "物资不足时改为信息互助、共同观察或一次性指引。",
    "对方急需但风险高时，转为放置点交接，不直接带入驻地。"
  ],
  "stop_or_escalate": [
    "互助对象开始施压或转告更多人。",
    "团队基本配给被影响。",
    "边界说明后仍被反复突破。"
  ],
