  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先确认谁外出、谁留守、谁照看儿童老人、谁记录时间。",
    "留守人员锁定或遮挡物资区，暂停不必要进出。",
    "约定外出返回时间、迟到多久启动等待流程、谁有权改变计划。",
    "留守者不接待第二批陌生人，不解释外出人员去向。",
    "外出人员回来后先简报，确认无人尾随后再恢复正常动线。"
  ],
  "check": [
    "驻地始终有人负责。",
    "脆弱成员不参与接触。",
    "超时处理规则清楚。"
  ],
  "common_mistakes": [
    "全员去看交换。",
    "留守者向陌生人解释队伍安排。",
    "外出回来直接进入物资区。"
  ],
  "fallback": [
    "人数少时取消非必要交换，至少保留一名清醒留守者。",
    "无法通信时使用纸条、时间表和固定等待点。"
  ],
