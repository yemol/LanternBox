  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "为对象建立简单记录：接触次数、内容、是否守时、是否尊重边界。",
    "每次只按上次评估等级接触，不因为熟悉就开放更多区域。",
    "限制固定时间和地点，避免形成随时上门习惯。",
    "出现要求升级时，必须团队复核，不由单人答应。",
    "定期决定继续、降级或暂停，并写明原因。"
  ],
  "check": [
    "对象记录可追溯。",
    "边界没有因熟悉而放松。",
    "下次接触等级明确。"
  ],
  "common_mistakes": [
    "把熟人等同可信。",
    "让对方掌握团队作息。",
    "为了维持关系不断提高付出。"
  ],
  "fallback": [
    "记录不足时从下一次开始补记，不追求回忆完整。",
    "团队分歧大时先暂停接触一轮。"
  ],
  "stop_or_escalate": [
    "对象开始不预约上门。",
    "对方要求固定份额或排他合作。",
    "接触后团队内部压力明显上升。"
  ],
