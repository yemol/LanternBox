  "tools": [
    "记录纸",
    "笔",
    "计时器或约定时间",
    "任务板",
    "口令卡"
  ],
  "steps": [
    "先问清信息来源：亲眼看见、别人转述，还是推测。",
    "记录时间、地点、可验证细节和对方是否从信息中获利。",
    "用至少一个独立来源或现场观察验证关键内容。",
    "验证前不改变撤离、库存、医疗和人员安排等高风险决策。",
    "把未验证信息标注为线索，并设置复查时间。"
  ],
  "check": [
    "来源层级已标明。",
    "关键细节可被复核。",
    "未验证信息没有直接驱动重大行动。"
  ],
  "common_mistakes": [
    "把语气坚定当可信。",
    "只听有利于自己愿望的消息。",
    "把单一消息转述成团队事实。"
  ],
  "fallback": [
    "无法验证时只用于低风险准备，不用于撤离或暴露库存。",
    "没有第二来源时延迟决策并继续观察。"
  ],
  "stop_or_escalate": [
    "信息要求团队立刻暴露位置或交出物资。",
    "对方拒绝提供任何可复核细节。",
    "信息与现场观察明显冲突。"
  ],
