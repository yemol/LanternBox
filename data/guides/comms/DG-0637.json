{
  "id": "DG-0637",
  "title": "纸条留言点每日复核",
  "category": "通讯",
  "priority": "P0",
  "scenario": "电子通信不稳定，成员需要依靠固定纸条留言点传递去向和需求。",
  "goal": "让纸条留言可验证、可更新，不被旧信息误导。",
  "keywords": [
    "通讯",
    "通讯",
    "纸条留言点每日复核",
    "长期断供",
    "小团队",
    "行动卡",
    "纸条留言点每日复核",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "防水袋",
    "纸笔",
    "夹子",
    "日期标记",
    "固定板",
    "遮挡物"
  ],
  "steps": [
    "选择一个不暴露核心住所、但成员都知道的固定留言点。",
    "每张纸条必须写日期、时间、姓名或编号、去向、预计返回和需要帮助事项。",
    "每日固定时段由两人复核留言点，旧纸条划线归档，不直接撕掉丢弃。",
    "紧急信息放在约定位置或用约定符号标识，普通留言不占用紧急位置。",
    "留言点被外人发现或移动痕迹明显时，立即启用备用点并通知成员。"
  ],
  "check": [
    "留言点和备用点已约定。",
    "纸条含时间、身份、去向和返回预期。",
    "旧信息已归档而非混在当前信息里。"
  ],
  "common_mistakes": [
    "只写一句“我出去了”。",
    "新旧纸条混在一起。",
    "留言点选在住所门口暴露位置。"
  ],
  "fallback": [
    "没有防水袋时，用瓶子、盒子或屋檐下夹板保护纸条。",
    "纸张不足时，使用可擦板或固定符号表，但保留日期变化。"
  ],
  "stop_or_escalate": [
    "留言点出现陌生标记、纸条被翻动或成员超过预计时间未归时，停止普通留言流程并进入失联复核。",
    "备用点也暴露时，重新设计联络方式。"
  ],
