{
  "id": "DG-0651",
  "title": "湿袜更换和脚部检查",
  "category": "衣物 / 鞋袜 / 体温防护",
  "priority": "P0",
  "scenario": "行走后袜子潮湿，脚底可能已有摩擦或低温损伤。",
  "goal": "换上干燥层并判断双脚能否继续负重行走。",
  "keywords": [
    "衣物",
    "衣物 / 鞋袜 / 体温防护",
    "湿袜更换和脚部检查",
    "长期断供",
    "小团队",
    "行动卡",
    "湿袜更换和脚部检查",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "干袜或干布",
    "擦脚布",
    "手电",
    "水泡覆盖材料",
    "记录纸"
  ],
  "steps": [
    "在避风干燥处脱下鞋袜，左右脚分开放置。",
    "擦干脚趾缝、脚底和脚跟，查看发白、红肿、水泡、裂口和失去感觉的位置。",
    "小水泡保持完整并覆盖摩擦点；有破口时用洁净材料覆盖。",
    "换上干袜，重新系鞋后慢走十步，确认没有新增压痛再继续。",
    "把损伤位置、换袜时间和下次检查点写入行程记录。"
  ],
  "check": [
    "脚趾缝和袜内摸起来干燥。",
    "慢走时没有刺痛、打滑或局部挤压。",
    "水泡未扩大，脚趾颜色和触觉左右相近。"
  ],
  "common_mistakes": [
    "只换袜而不检查脚底。",
    "挑破完整水泡。",
    "湿鞋内叠穿多层袜子导致挤压。"
  ],
  "fallback": [
    "没有干袜时，用干布包脚并轮换晾晒湿袜，缩短行走段。",
    "没有覆盖材料时，用清洁柔软布减少摩擦，不把胶带直接贴在破口上。"
  ],
  "stop_or_escalate": [
    "出现脚趾持续发白或发紫、麻木、明显肿胀、流脓或无法负重时停止行走。",
    "鞋内仍进水或无法保持脚部干燥时，暂停路线并先处理遮蔽和鞋体。"
  ],
