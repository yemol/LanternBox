    "高温外出防晒和补水",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "饮水",
    "浅色遮阳衣帽",
    "计时工具",
    "湿布",
    "路线记录"
  ],
  "steps": [
    "记录气温体感、路线、最晚返回时间和每人携水量。",
    "选择阴影较多的往返路线，把重物分给状态较好者。",
    "遮住头颈和裸露皮肤，出发前少量饮水。",
    "按固定间隔在阴影处停步，检查头晕、恶心、异常出汗和步态。",
    "饮水降到返程保留量或到达折返时间时立即返回。"
  ],
  "check": [
    "人员能正常复述路线和返回时间。",
    "休息时皮肤不过度灼热，步态和回答清楚。",
    "返程时仍保留约定饮水且无人落队。"
  ],
  "common_mistakes": [
    "口渴后才开始饮水。",
    "在正午加速赶路。",
    "把全部饮水在前半程用完。"
  ],
  "fallback": [
    "无帽时用浅色布遮住头颈，改在清晨、傍晚或阴影时段行动。",
    "饮水不足时缩短目标，只做最近且必要的任务，并保留返程水。"
  ],
  "stop_or_escalate": [
    "出现意识含糊、站立不稳、持续呕吐、皮肤异常灼热或无法饮水时停止行进，转入阴凉处降温。",
    "路线无阴影、无返程水或无法按时返回时取消外出。"
  ],
