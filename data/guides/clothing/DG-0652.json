{
  "id": "DG-0652",
  "title": "雨衣破洞临时补片",
  "category": "衣物 / 鞋袜 / 体温防护",
  "priority": "P0",
  "scenario": "雨衣破洞使躯干、保温层或背包持续进水。",
  "goal": "做出可拆除补片并验证在短时淋雨下不再明显渗水。",
  "keywords": [
    "衣物",
    "衣物 / 鞋袜 / 体温防护",
    "雨衣破洞临时补片",
    "长期断供",
    "小团队",
    "行动卡",
    "雨衣破洞临时补片",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "干布",
    "防水胶带或胶",
    "塑料片",
    "剪切工具",
    "压平用硬物"
  ],
  "steps": [
    "进入避雨处，擦净并晾干破洞周围至少一掌宽。",
    "摊平破洞，把翘起边缘对齐，不在受拉状态下粘贴。",
    "从内侧覆盖塑料片，再从外侧贴补片并压实边缘。",
    "弯折补片附近三次，检查边缘是否翘起。",
    "从外侧少量淋水，在内侧用干布检查渗点。"
  ],
  "check": [
    "补片四周贴合，没有可见翘边。",
    "弯折后裂口没有继续延伸。",
    "淋水检查时内侧干布无新增湿点。"
  ],
  "common_mistakes": [
    "表面潮湿或沾泥时直接贴。",
    "补片过小，只覆盖裂口不覆盖受损边缘。",
    "在肩、肘等受力处拉紧后粘贴。"
  ],
  "fallback": [
    "无胶带时，用塑料片从内侧覆盖并以绳带固定，外层减少活动。",
    "无法封住时把雨衣改作背包罩或地面隔潮层，人员使用塑料布遮雨。"
  ],
  "stop_or_escalate": [
    "破洞位于大面积脆化区域、补片反复脱落或雨水已浸湿保温层时停止依赖该雨衣。",
    "出现发抖、动作变慢或衣物无法换干时，停止外出并先恢复保温。"
  ],
