{
  "id": "DG-0452",
  "title": "病人软食安排",
  "category": "水与食物保障",
  "priority": "P0",
  "scenario": "发热、腹泻、术后、牙痛、老人或虚弱成员无法吃硬食。",
  "goal": "用有限食材提供易消化、低刺激食物。",
  "tools": [
    "锅",
    "米面",
    "水",
    "少量盐",
    "记录本"
  ],
  "steps": [
    "优先选择粥、软面、汤、蒸蛋或压碎熟食。",
    "少油、少辣、少硬、少高盐。",
    "腹泻时避免油腻和可疑剩食。",
    "发热或虚弱时少量多次，不强迫一次吃完。",
    "用独立餐具，避免与其他成员混用。",
    "记录吃了多少、是否呕吐、腹泻和精神状态。",
    "病情改善后再逐步恢复普通食物。"
  ],
  "check": [
    "食物软烂。",
    "少量多次。",
    "进食反应有记录。"
  ],
  "common_mistakes": [
    "病人和大家吃同样硬干粮。",
    "腹泻还吃油腻剩菜。",
    "吃不下就完全不记录。"
  ],
  "fallback": [
    "材料少时，用米汤、面汤、稀粥或温水加少量盐糖做最低支持。"
  ],
  "stop_or_escalate": [
    "持续不能进食、呕吐、腹泻加重、意识异常时，升级医疗观察。"
  ],
  "notes": "病人饭不是另开小灶，是给身体留修复通道。",
  "category_original": "菜单轮换与烹饪节奏",
