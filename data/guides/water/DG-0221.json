{
  "id": "DG-0221",
  "title": "室内禁止燃烧规则",
  "category": "水与食物保障",
  "priority": "P0",
  "scenario": "寒冷、停电、雨天或外部危险时，有人想在室内烧炭、柴火、炉具取暖或做饭。",
  "goal": "防止一氧化碳中毒、火灾和缺氧。",
  "tools": [
    "规则牌",
    "通风检查",
    "灭火材料",
    "记录本"
  ],
  "steps": [
    "明确写下：密闭空间内禁止烧炭、柴火和不明燃料。",
    "便携炉具也必须在通风良好、远离易燃物的位置短时使用。",
    "睡觉时不允许任何明火或燃烧取暖。",
    "不能把发电机、炭盆、柴火炉放在室内、车库、楼道或半封闭空间。",
    "出现头晕、恶心、乏力、多人犯困时，立刻开窗转移到新鲜空气处。",
    "所有成员都要知道燃烧取暖的风险。"
  ],
  "check": [
    "规则贴在厨房或火源区。",
    "睡觉时无明火。",
    "发电机不在室内。"
  ],
  "common_mistakes": [
    "关门烧炭取暖。",
    "觉得开一点窗就安全。",
    "在车库用发电机。"
  ],
  "fallback": "必须做饭时，选择通风处短时进行，并安排专人观察。",
  "stop_or_escalate": [
    "多人头晕恶心、燃烧废气进入室内、通风不足、火源无人看守时，立即停止燃烧。"
  ],
  "notes": "看不见的烟最会杀人。",
