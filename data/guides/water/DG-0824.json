  ],
  "steps": [
    "先把参与人数和预计停水天数记下来。",
    "先把每人每天的最低饮水量写成一个明确数字。",
    "先把总量和每个人的配额对上，避免“看起来够用”却实际超用。",
    "先把配额写在取水点附近，方便所有人按同一标准。",
    "先每天复核一次，水少时就立即缩减到最低配额。"
  ],
  "check": [
    "人数和天数已写清。",
    "每人配额已明确。",
    "取水点附近有配额提示。"
  ],
  "common_mistakes": [
    "只凭感觉分水。",
    "一开始就把每人配额定得太高。",
    "没有每天复核。"
  ],
  "fallback": [
    "水量不足时先按最低配额，先保留儿童、老人和病人。",
    "没有计算器时先用最简单的除法估算。"
  ],
  "stop_or_escalate": [
    "配额一再被超用时停止自由取水并重新分配。",
