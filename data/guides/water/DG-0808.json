  "steps": [
    "先把干净布铺在容器口上。",
    "先把水缓慢倒入布上，让大颗粒留在布上。",
    "先把滤过后的水转入干净容器。",
    "先观察过滤后水是否仍有异味或颜色异常。",
    "先把过滤后的水标记为“已过滤，待检”。"
  ],
  "check": [
    "滤布已准备。",
    "大颗粒已被挡住。",
    "滤后水已重新容器保存。"
  ],
  "common_mistakes": [
    "用脏布过滤。",
    "让过滤水重新接触脏容器。",
    "把“过滤过”当成“安全”。"
  ],
  "fallback": [
    "布不够时先用多层干净纱布或衣物。",
    "过滤后仍有异常时先停用。"
  ],
  "stop_or_escalate": [
    "过滤后仍有强烈异味或污染痕迹时停止继续使用。",
    "高风险水不要硬做后续处理。"
  ],
