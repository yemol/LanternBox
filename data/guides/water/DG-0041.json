{
  "id": "DG-0041",
  "title": "食物开封日期：临期和开封分区",
  "category": "水与食物保障",
  "priority": "P0",
  "scenario": "长期储备中有米、面、罐头、干货、调料、零食被陆续开封。",
  "goal": "让开封食物优先被吃掉，减少受潮、虫害和遗忘。",
  "tools": [
    "标签纸",
    "记号笔",
    "收纳箱",
    "库存模块"
  ],
  "steps": [
    "每次开封立刻写日期，不要等做完饭再补。",
    "把开封食物放到“优先消耗区”，未开封食物放长期储备区。",
    "开封袋口夹紧或转入密封容器。",
    "每次做饭先查看优先消耗区。",
    "发现受潮、虫害、霉味时单独隔离。",
    "每周复核开封区，更新库存。"
  ],
  "check": [
    "开封食物都有日期。",
    "开封区和长期区分开。",
    "先吃开封和临期。"
  ],
  "common_mistakes": [
    "同时开很多包同类食物。",
    "开封后放回长期储备深处。",
    "撕掉原包装导致不知道内容和日期。"
  ],
  "fallback": [
    "没有标签纸时，用纸条夹在容器上，或在箱子外写开封清单。"
  ],
  "stop_or_escalate": [
    "开封食物发霉、长虫、异味。",
    "包装被鼠咬或洪水泡过。"
  ],
  "notes": "开封管理能把浪费变成计划消耗。",
