{
  "id": "DG-0053",
  "title": "种子发芽测试：先测一小撮",
  "category": "水与食物保障",
  "priority": "P0",
  "scenario": "不确定种子是否还能种，或者储存时间较长。",
  "goal": "在不浪费全部种子的前提下判断发芽率。",
  "tools": [
    "湿布",
    "小盒",
    "标签纸",
    "安全水",
    "记录本"
  ],
  "steps": [
    "从一批种子中取少量样本，不要超过一小撮。",
    "把湿布打湿到不滴水，种子夹在湿布中。",
    "放在温暖但不暴晒的位置。",
    "每天检查湿度，干了就补一点安全水。",
    "记录几天后有多少发芽。",
    "发芽率低的种子优先播种或降级，不再当核心未来粮。"
  ],
  "check": [
    "只用少量种子测试。",
    "测试日期和数量有记录。",
    "没有把测试种子混回干种子。"
  ],
  "common_mistakes": [
    "把全部种子泡掉。",
    "湿布泡成水坑导致腐烂。",
    "不贴标签搞混批次。"
  ],
  "fallback": [
    "没有湿布时，用纸巾、干净布片、棉布代替。"
  ],
  "stop_or_escalate": [
    "种子发霉发臭。",
    "连续多天无发芽且储存条件差。"
  ],
  "notes": "发芽测试是小成本排雷。",
