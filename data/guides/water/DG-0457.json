{
  "id": "DG-0457",
  "title": "饮用水分区储存",
  "category": "水与食物保障",
  "priority": "P0",
  "scenario": "取回或净化后的水需要在住所、营地或车辆中储存。",
  "goal": "防止饮用水、生水、灰水和清洗水混淆。",
  "tools": [
    "水桶",
    "标签纸",
    "记号笔",
    "盖子",
    "记录本"
  ],
  "steps": [
    "把水分成饮用水、生水、清洗水、灰水四类。",
    "每个容器贴大字标签，颜色或形状尽量区分。",
    "饮用水放在干净区，高于地面并远离厕所、垃圾和燃料。",
    "生水和灰水不得靠近饮用水桶。",
    "饮用水桶必须有盖，取水工具专用。",
    "每天固定时间检查标签是否脱落、桶盖是否盖好。",
    "任何人发现容器混淆，立即暂停取用并重新确认。"
  ],
  "check": [
    "四类水有标签。",
    "饮用水有盖。",
    "取水工具专用。"
  ],
  "common_mistakes": [
    "所有桶看起来差不多。",
    "生水桶放饮用水旁边。",
    "用同一个勺子舀所有水。"
  ],
  "fallback": [
    "没有标签纸时，直接在桶身写字，或用绳结、布条、位置分区辅助区分。"
  ],
  "stop_or_escalate": [
    "有人误饮、标签脱落、饮用水桶被生水工具接触时，立即停止使用并重新处理。"
  ],
  "notes": "水最怕不是少，是脏水穿上干净水的衣服。",
