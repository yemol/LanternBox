  "title": "食物防鼠：硬盒、离地、清屑",
  "category": "水与食物保障",
  "priority": "P0",
  "scenario": "发现鼠迹、咬痕、粪便，或储粮被啃。",
  "goal": "防止粮食损失和污染。",
  "tools": [
    "硬质密封桶",
    "手套",
    "垃圾袋",
    "刷子",
    "标签纸"
  ],
  "steps": [
    "先戴手套检查粮食包装是否被咬破。",
    "被鼠咬、鼠尿污染或有粪便接触的食物单独隔离。",
    "把正常粮食转入硬质密封容器。",
    "清理食物碎屑和厨余，垃圾密封。",
    "封堵墙角、门缝、管线洞口。",
    "每天检查新咬痕和粪便。"
  ],
  "check": [
    "粮食离地并进入硬容器。",
    "地面没有食物碎屑。",
    "鼠迹变化有记录。"
  ],
  "common_mistakes": [
    "徒手处理鼠粪。",
    "把被咬食物切掉一块继续吃。",
    "垃圾和粮食放一起。"
  ],
  "fallback": "没有硬桶时，用金属盒、厚塑料箱、悬挂方式临时降低风险。",
  "stop_or_escalate": [
    "大量鼠迹持续增加。",
    "食物污染范围不明。",
    "有人处理后发热、腹泻或皮疹。"
  ],
