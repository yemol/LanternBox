{
  "id": "DG-0448",
  "title": "盐分和高盐食物控制",
  "category": "水与食物保障",
  "scenario": "咸菜、腌肉、方便食品、罐头、调料包等高盐食物容易成为主要食物。",
  "goal": "减少脱水、口渴和血压风险，同时保留电解质来源。",
  "tools": [
    "菜单表",
    "饮水记录",
    "调料清单"
  ],
  "steps": [
    "列出高盐食物和调料包。",
    "高盐食物不要连续多餐作为主要食物。",
    "烹饪时先尝味再加盐，不把调料包全倒入。",
    "高温、腹泻、重体力后可以适当保留盐分，但要配合饮水。",
    "老人、高血压或肾脏问题成员减少高盐份额。",
    "高盐食物开封后注意保存，防止吸潮变质。",
    "记录口渴、浮肿、头痛和血压异常。"
  ],
  "check": [
    "高盐食物有识别。",
    "调料包没有整包乱倒。",
    "重点成员有控制。"
  ],
  "common_mistakes": [
    "方便面调料全倒还喝汤。",
    "缺水时还大量吃咸食。",
    "老人和病人不区分。"
  ],
  "fallback": "没有低盐选择时，用主食和水稀释高盐食物，而不是单独吃。",
  "stop_or_escalate": [
    "多人明显口渴、浮肿、头痛或慢病成员不适时，降低高盐食物。"
  ],
  "notes": "盐很宝贵，但不是越多越像在补命。",
