{
  "id": "DG-0553",
  "title": "可疑水源：过滤、煮沸和禁用判断",
  "category": "水与食物保障",
  "priority": "P0",
  "scenario": "雨水、河水、井水、桶底水或洪水后水源不确定。",
  "goal": "用沉淀、过滤和煮沸降低风险，同时明确哪些水应直接禁用。",
  "tools": [
    "干净布",
    "容器",
    "锅",
    "火源",
    "过滤材料"
  ],
  "steps": [
    "先观察颜色、气味、油膜、漂浮物和周边污染源。",
    "明显有化学味、油膜、农药味、粪污或动物尸体污染的水，不作为饮用水处理。",
    "较浑浊但无化学污染信号的水，先静置沉淀，再用干净布或过滤材料预过滤。",
    "过滤后的水用于饮用前应充分煮沸；无法煮沸时只作为清洁或冲厕降级使用。",
    "处理后单独标记时间、来源和用途，不与原有饮用水混合。"
  ],
  "check": [
    "已先做禁用判断。",
    "可疑水已和饮用水分开。",
    "饮用前已过滤并煮沸。"
  ],
  "common_mistakes": [
    "以为过滤等于消毒。",
    "把有化学味的水煮沸后饮用。",
    "处理后的水不标记来源。"
  ],
  "fallback": [
    "没有火源时，可疑水只降级用于非入口清洁或冲厕，优先保存现有饮用水。"
  ],
  "stop_or_escalate": [
    "饮用后出现呕吐、腹泻、头晕，或水源疑似化学污染时，停止使用该水源。"
  ],
