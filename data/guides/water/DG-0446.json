{
  "id": "DG-0446",
  "title": "油脂节约和补充",
  "category": "水与食物保障",
  "scenario": "食用油、坚果、肥肉、芝麻、花生酱等油脂有限，长期缺油会影响热量和饱腹感。",
  "goal": "避免油脂前期耗尽，同时保证最低热量。",
  "tools": [
    "油瓶",
    "量勺",
    "菜单表",
    "库存记录"
  ],
  "steps": [
    "统计所有油脂来源和保质状态。",
    "做饭使用固定量勺，不凭手感倒油。",
    "优先用少油烹饪方式，例如煮、炖、蒸、拌。",
    "油脂不要完全停用，尤其是低温、高体力和儿童成员。",
    "坚果、芝麻、花生等可作为少量补充。",
    "油脂有哈喇味、霉味时停止入口使用。",
    "每周记录油脂消耗速度。"
  ],
  "check": [
    "油脂有计量。",
    "没有完全断油。",
    "变质油脂未食用。"
  ],
  "common_mistakes": [
    "前期炒菜用油太猛。",
    "为了省油完全不吃油。",
    "变味油继续吃。"
  ],
  "fallback": "没有量勺时，用瓶盖或固定小勺作为单位。",
  "stop_or_escalate": [
    "成员体力明显下降、持续畏寒、儿童摄入不足时，复核油脂和总热量。"
  ],
  "notes": "油脂像燃料添加剂，少了身体也会熄火。",
