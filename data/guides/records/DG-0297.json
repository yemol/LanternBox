{
  "id": "DG-0297",
  "title": "重大事件时间线",
  "category": "库存资料与成员档案",
  "priority": "P2",
  "scenario": "发生火灾、冲突、成员失踪、食物中毒、水源污染、数据泄露、撤离或伤亡事件。",
  "goal": "用时间线保留事实，方便后续处理和复盘。",
  "tools": [
    "记录本",
    "手表",
    "见证人",
    "照片可选"
  ],
  "steps": [
    "从事件开始时间写起，尽量用具体时间。",
    "按顺序记录关键节点：发现、通知、处理、转移、结果。",
    "记录参与人员、地点、物资、伤病和损失。",
    "事实和猜测分开写。",
    "多人证言分开记录，不合成一个看似确定的版本。",
    "事件结束后标出未确认事项。",
    "复盘时依据时间线修改规则。"
  ],
  "check": [
    "时间顺序清楚。",
    "事实和猜测分开。",
    "未确认事项被标出。"
  ],
  "common_mistakes": [
    "事后只凭情绪回忆。",
    "把猜测写成事实。",
    "多人说法混成一团。"
  ],
  "fallback": [
    "没有手表时，用相对顺序记录，例如饭前、雨停后、第二次值守时。"
  ],
  "stop_or_escalate": [
    "事件涉及人员安全、物资暴露、疾病传播或外部冲突时，必须建立时间线。"
  ],
  "notes": "时间线是混乱之后留下的一根尺。",
