{
  "id": "DG-0529",
  "title": "成员档案权限分级",
  "category": "库存资料与成员档案",
  "priority": "P2",
  "scenario": "成员档案包含照片、医疗记录、证件、联系人和敏感资料。",
  "goal": "按敏感程度控制访问。",
  "tools": [
    "权限表",
    "口令",
    "加密存储",
    "记录本"
  ],
  "steps": [
    "把成员资料分为普通、敏感、高敏感三级。",
    "普通资料用于日常照护，例如昵称和任务能力。",
    "敏感资料包括医疗、过敏、联系人。",
    "高敏感资料包括证件照片、完整身份信息和加密备份。",
    "不同级别设置不同访问口令或负责人。",
    "每次访问高敏感资料记录原因。",
    "成员离开或权限变化时更新权限表。"
  ],
  "check": [
    "资料分级。",
    "高敏感访问有记录。",
    "权限变更会更新。"
  ],
  "common_mistakes": [
    "所有资料一个入口。",
    "证件照随便看。",
    "访问不留记录。"
  ],
  "fallback": [
    "系统未完成时，用密封文件袋和纸质权限表临时管理。"
  ],
  "stop_or_escalate": [
    "口令泄露、设备丢失、成员资料被误看时，立即更换口令和备份。"
  ],
  "notes": "成员档案是救命资料，不是公共相册。",
