{
  "id": "DG-0656",
  "title": "入口缓冲区鞋物分离",
  "category": "庇护空间分区",
  "priority": "P0",
  "scenario": "入口泥水和污染物被鞋、外衣及工具带入生活区。",
  "goal": "在入口完成脱卸、暂存和清洁，保持内区地面干燥。",
  "keywords": [
    "庇护空间",
    "庇护空间分区",
    "入口缓冲区鞋物分离",
    "长期断供",
    "小团队",
    "行动卡",
    "入口缓冲区鞋物分离",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "地垫或旧布",
    "鞋物托盘",
    "挂钩",
    "分区标记",
    "清洁布"
  ],
  "steps": [
    "在门外或最靠门处划污染侧和清洁侧。",
    "进门先把鞋放托盘，外衣和工具挂在污染侧。",
    "跨入清洁侧前检查鞋底泥水并清洁双手。",
    "每天清理托盘渗水，晾干地垫并恢复边界。"
  ],
  "check": [
    "清洁侧地面无泥印和湿痕。",
    "鞋、外衣与食物寝具不接触。",
    "成员能指出脱鞋顺序和边界。"
  ],
  "common_mistakes": [
    "穿鞋跨区取物。",
    "湿外衣挂在睡眠区。",
    "托盘积水不清。"
  ],
  "fallback": [
    "无托盘时用塑料布折边集水。",
    "空间不足时按时间分流，一人完成清洁后再放行。"
  ],
  "stop_or_escalate": [
    "污水越过边界、标记失效或成员反复走错时停止开放入口并重设分区。",
    "无法保持清洁侧干燥时转移水食物和寝具。"
  ],
