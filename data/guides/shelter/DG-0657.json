{
  "id": "DG-0657",
  "title": "睡眠区远离污染区复核",
  "category": "庇护空间分区",
  "priority": "P0",
  "scenario": "睡眠区靠近垃圾、病人照护、漏水或高频通道。",
  "goal": "重新选择干燥、低污染且不妨碍撤离的位置。",
  "keywords": [
    "庇护空间",
    "庇护空间分区",
    "睡眠区远离污染区复核",
    "长期断供",
