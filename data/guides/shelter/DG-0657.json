    "睡眠区远离污染区复核",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "区域简图",
    "手电",
    "干布",
    "边界标记",
    "隔潮层"
  ],
  "steps": [
    "检查睡眠点上方漏水、地面潮湿、异味和通行次数。",
    "标出污染源和至少一条畅通出口。",
    "将寝具移到干燥上风且少通行位置，并铺隔潮层。",
    "夜间复查寝具底面和污染边界。"
  ],
  "check": [
    "寝具上下无滴水和湿痕。",
    "取水、如厕和垃圾路线不穿过睡眠区。",
    "出口可从睡位直接到达。"
  ],
  "common_mistakes": [
    "只搬病人不搬污染用品。",
    "在门口或通道铺床。",
    "用香味掩盖霉味。"
  ],
  "fallback": [
    "无独立房间时用可见边界和不同活动时段分离。",
    "干燥地不足时优先给伤病、儿童和低温风险者。"
  ],
  "stop_or_escalate": [
    "污水、烟雾、霉斑扩大或出口被堵时停止使用该睡眠区。",
    "无法与排泄或食物污染分开时重新选位。"
  ],
