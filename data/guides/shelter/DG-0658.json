{
  "id": "DG-0658",
  "title": "火源区周边清空",
  "category": "庇护空间分区",
  "priority": "P0",
  "scenario": "火源周围堆有布纸、燃料或通行杂物。",
  "goal": "建立不会被日常取物侵占的清空区。",
  "keywords": [
    "庇护空间",
    "庇护空间分区",
    "火源区周边清空",
