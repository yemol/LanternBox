    "火源区周边清空",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "收纳箱",
    "边界标记",
    "灭火材料",
    "扫具",
    "值守记录"
  ],
  "steps": [
    "熄火或降到可安全靠近后再整理。",
    "移走火源四周和上方的布、纸、燃料与垂挂物。",
    "在地面标出清空边界，把灭火材料放在出口侧。",
    "重新点火前由第二人沿边界复查。"
  ],
  "check": [
    "边界内只有炉具和当前使用锅具。",
    "燃料在火源外独立直立存放。",
    "出口侧可直接拿到灭火材料。"
  ],
  "common_mistakes": [
    "把湿衣挂在火上方。",
    "燃料瓶放在伸手范围内。",
    "清空后又临时堆物。"
  ],
  "fallback": [
    "无收纳箱时把杂物移到另一面并用绳线界定。",
    "空间过小时停用明火，改用无火保温或冷食。"
  ],
  "stop_or_escalate": [
    "发现泄漏、火星、焦味、边界无法维持或无人值守时立即停火。",
    "唯一出口被火源占据时禁止使用。"
  ],
