  "tools": [
    "收纳箱",
    "绑带",
    "低亮反光标记",
    "遮光手电",
    "通道简图"
  ],
  "steps": [
    "从睡眠点走到出口，标出绊脚物和狭窄处。",
    "将物资移到墙侧固定区，线缆贴边绑紧。",
    "在转角、台阶和出口放低位标记，不照向室外。",
    "关主灯后由两人分别试走并修正标记。"
  ],
  "check": [
    "通道全程可连续落脚且不侧身跨物。",
    "线缆和箱体不会被脚带动。",
    "低光下能辨认出口方向。"
  ],
  "common_mistakes": [
    "只把杂物推到门后。",
    "使用刺眼或对外暴露的灯。",
    "试走时携带重物。"
  ],
  "fallback": [
    "无反光材料时用浅色布条贴地标记。",
    "空间不足时设单向通道并禁止夜间临时堆物。"
  ],
  "stop_or_escalate": [
    "出口无法完全打开、标记被遮住或试走仍绊碰时停止夜间通行并重新清障。",
    "结构碎片持续掉落时封闭该通道。"
  ],
