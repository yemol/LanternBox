{
  "id": "DG-0594",
  "title": "潮湿寒冷：衣物分层和睡眠保温",
  "category": "火源保温与通风",
  "priority": "P0",
  "scenario": "衣物和环境潮湿且温度下降，睡眠时可能持续失热。",
  "goal": "先换干、隔地、挡风，再建立不过热出汗的睡眠层。",
  "tools": [
    "干衣或干布",
    "隔潮垫材",
    "保温层",
    "挡风材料",
    "热水容器（如有）"
  ],
  "steps": [
    "移除贴身湿层并擦干皮肤。",
    "用木板、纸板或干草隔开湿冷地面。",
    "按干燥内层、蓬松保温层、挡风层穿盖。",
    "入睡五分钟后摸后颈，出汗则减层，发冷则增加隔地或保温。"
  ],
  "check": [
    "后颈温暖干燥。",
    "寝具底面无明显潮湿。",
    "人员回答清楚且手脚可正常活动。"
  ],
  "common_mistakes": [
    "穿湿衣直接裹毯。",
    "只加上层不隔地。",
    "用密闭热源在寝具内燃烧。"
  ],
  "fallback": [
    "无干衣时拧干并用干布隔开皮肤，优先保护躯干。",
    "材料不足时缩小空间、共同保温并轮流清醒检查。"
  ],
  "stop_or_escalate": [
    "持续发抖后停止发抖、意识迟缓、动作笨拙或寝具持续进水时停止睡眠安排并转入失温处置。",
    "无法隔开湿地时更换位置。"
  ],
