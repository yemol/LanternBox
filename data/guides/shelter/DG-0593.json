{
  "id": "DG-0593",
  "title": "酒精炉使用：通风防倾倒和禁用场景",
  "category": "火源保温与通风",
  "priority": "P0",
  "scenario": "需要用酒精炉短时加热，但燃料火焰不易看清且易倾倒。",
  "goal": "只在稳定、通风、无泄漏且可立即覆盖熄火的条件下使用。",
  "tools": [
    "完好酒精炉",
    "稳定不可燃底板",
    "适配锅具",
    "灭火盖",
    "通风口"
  ],
  "steps": [
    "冷炉状态检查燃料杯、密封和周边渗漏。",
    "清空周边可燃物，打开通风并放稳锅具。",
    "在炉体冷却时加燃料，移走燃料瓶后再点火。",
    "全程值守；结束时用灭火盖覆盖，不吹火或移动热炉。"
  ],
  "check": [
    "炉体和锅具不晃动。",
    "周边无燃料湿痕或刺鼻气味。",
    "覆盖后火焰消失且炉体冷却再收纳。"
  ],
  "common_mistakes": [
    "燃烧中补酒精。",
    "看不见火焰就徒手触碰。",
    "在帐篷、睡眠区或无通风处使用。"
  ],
  "fallback": [
    "无稳定炉具时改用冷食或预先保温的热水。",
    "缺灭火盖时不点火。"
  ],
  "stop_or_escalate": [
    "发现燃料泄漏、火焰外溢、锅具倾斜、通风受阻或人员头晕时立即停止并覆盖熄火。",
    "炉体未冷却或燃料来源不明时禁止加注。"
  ],
