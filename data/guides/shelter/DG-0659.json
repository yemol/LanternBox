    "物资区高处防潮摆放",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "架板或垫块",
    "防水箱",
    "标签",
    "干布",
    "库存表"
  ],
  "steps": [
    "检查地面湿痕和上方漏水，先移走电源、药品和纸张。",
    "用稳固垫块把物资抬离地面，不堆在摇晃家具顶部。",
    "湿物与干物分开，外包装擦干后标记检查。",
    "重物放低层，常用物朝外，并更新库存位置。"
  ],
  "check": [
    "最下层与地面之间有可见空气间隙。",
    "包装表面干燥，无霉味或渗液。",
    "架体轻推不晃，通道未变窄。"
  ],
  "common_mistakes": [
    "用纸箱直接垫湿地。",
    "重物放高层。",
    "把潮湿包装塞入密闭干货箱。"
  ],
  "fallback": [
    "无架板时用倒置空容器垫高并分散重量。",
    "无法保持干燥时缩小库存，优先转移药品、电源和记录。"
  ],
  "stop_or_escalate": [
    "架体倾斜、漏水持续、包装发热鼓胀或霉味扩大时停止堆放并隔离受影响物。",
    "无法确认承重时不向高处叠加。"
  ],
