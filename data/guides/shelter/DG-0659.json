{
  "id": "DG-0659",
  "title": "物资区高处防潮摆放",
  "category": "庇护空间分区",
  "priority": "P0",
  "scenario": "食物、药品、纸张和电源物资贴地受潮。",
  "goal": "按怕水程度移到稳固高处，并保留通风和取用顺序。",
  "keywords": [
    "庇护空间",
    "庇护空间分区",
    "物资区高处防潮摆放",
    "长期断供",
