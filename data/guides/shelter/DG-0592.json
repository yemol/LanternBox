{
  "id": "DG-0592",
  "title": "蜡烛照明：防火间距和停止条件",
  "category": "火源保温与通风",
  "priority": "P0",
  "scenario": "断电后使用蜡烛照明，倾倒和近距离可燃物可能引发火灾。",
  "goal": "把蜡烛限制在稳固、有人值守且远离可燃物的位置。",
  "tools": [
    "宽底烛台",
    "金属托盘",
    "灭火毯或水（非电气火）",
    "计时工具",
    "反光板"
  ],
  "steps": [
    "选择不在通道、床边和帘布下的位置。",
    "将蜡烛固定在宽底托盘，清空一臂范围内可燃物。",
    "点燃后指定值守者，不移动燃烧中的蜡烛。",
    "离开、换班或睡前压灭烛芯并检查无红点。"
  ],
  "check": [
    "烛台轻推不倾倒。",
    "火焰上方和四周无布纸。",
    "熄灭后烛芯无烟、无红光。"
  ],
  "common_mistakes": [
    "用瓶口卡蜡烛。",
    "把蜡烛放在地面通道。",
    "无人时继续燃烧。"
  ],
  "fallback": [
    "无稳固烛台时用手电定时照明或反光板集中微弱光。",
    "电量不足时固定黑暗行动时段，不用开放火焰补光。"
  ],
  "stop_or_escalate": [
    "火焰摇摆接近物体、蜡油外溢、烛台松动或值守者离开时立即熄灭。",
    "有燃气味、氧气不足或儿童无法隔离时禁止使用。"
  ],
