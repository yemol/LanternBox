{
  "id": "DG-0591",
  "title": "室内取暖：通风和一氧化碳风险",
  "category": "火源保温与通风",
  "priority": "P0",
  "scenario": "封闭空间需要取暖，但燃烧会消耗氧气并产生一氧化碳。",
  "goal": "在持续通风、有人值守和可立即熄火的条件下限制燃烧取暖。",
  "tools": [
    "合规炉具",
    "稳定底座",
    "通风开口",
    "灭火材料",
    "计时工具"
  ],
  "steps": [
    "清空炉具周边可燃物并固定底座。",
    "开启对向通风缝，确认废气不回流。",
    "点火后安排清醒值守，按固定间隔检查人员和火焰。",
    "睡前完全熄火，把余烬移到不可燃位置复查。"
  ],
  "check": [
    "火焰稳定且无烟气倒灌。",
    "人员无头痛、恶心、嗜睡或步态异常。",
    "熄火后余烬不再发红发热。"
  ],
  "common_mistakes": [
    "关窗保温。",
    "睡眠时保持燃烧。",
    "在炉具附近晾易燃衣物。"
  ],
  "fallback": [
    "无安全炉具时用干燥分层衣物、缩小睡眠空间和地面隔冷替代。",
    "风大导致回烟时停用燃烧设备，只保留无火保温。"
  ],
  "stop_or_escalate": [
    "出现头痛恶心、异常嗜睡、烟气倒灌、火焰异常或通风无法维持时立即熄火并撤到新鲜空气处。",
    "无人清醒值守时禁止燃烧取暖。"
  ],
