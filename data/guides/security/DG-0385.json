{
  "id": "DG-0385",
  "title": "维修失败止损",
  "category": "工具维修与替代制作",
  "priority": "P0",
  "scenario": "维修尝试后问题没有改善，甚至出现新异常。",
  "goal": "及时停止，避免继续扩大损坏和风险。",
  "tools": [
    "记录本",
    "故障标签",
    "隔离区",
    "备用方案清单"
  ],
  "steps": [
    "设定维修停止条件，例如冒烟、异味、漏水扩大、零件丢失、结构松动。",
    "每一步维修后测试一次，不连续盲目拆到底。",
    "发现问题扩大时立刻停止并恢复能恢复的部分。",
    "把拆下零件集中保存，贴上来源。",
    "记录已尝试方法和新出现症状。",
    "切换备用方案，例如备用灯、备用容器、手动工具。",
    "后续再维修时先看记录，不重复同样错误。"
  ],
  "check": [
    "有停止条件。",
    "拆下零件未丢。",
    "失败后切换备用方案。"
  ],
  "common_mistakes": [
    "越修越急越拆越多。",
    "失败后零件散一地。",
    "下次又从头犯同样错误。"
  ],
  "fallback": [
    "如果无法恢复原状，至少隔离危险、保存零件、写清故障。"
  ],
  "stop_or_escalate": [
    "出现烟、火、燃气味、触电、漏液、结构失稳时，立即停止并撤离风险区。"
  ],
  "notes": "维修不是打怪，血条不对就要撤。",
