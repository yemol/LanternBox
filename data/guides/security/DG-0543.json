{
  "id": "DG-0543",
  "title": "夜间守夜与异常记录",
  "category": "安全与风险",
  "priority": "P0",
  "scenario": "夜间外部情况不明，需要持续观察但人员体力有限。",
  "goal": "用轮换和记录减少恐慌，避免所有人整夜紧张耗尽。",
  "tools": [
    "记录本",
    "低亮灯",
    "计时器",
    "哨子",
    "通讯设备"
  ],
  "steps": [
    "确定是否需要守夜，不把普通环境声音全部升级为威胁。",
    "安排短时轮换，每班只保留必要人员清醒。",
    "记录异常时间、方向、声音类型、持续多久和是否重复。",
    "守夜人员不单独外出，不离开约定观察位置。",
    "其他人员尽量休息，避免全队一起熬夜。",
    "每次交班说明最新异常和禁止动作。"
  ],
  "check": [
    "有明确轮班。",
    "异常被记录而不是靠记忆。",
    "没有全队同时熬夜。"
  ],
  "common_mistakes": [
    "所有人都不睡。",
    "守夜者单独外出查看。",
    "没有记录，第二天靠情绪判断风险。"
  ],
  "fallback": "人手不足时，只设短时复查点，不做整夜高强度守夜。",
  "stop_or_escalate": [
    "异常声音越来越近。",
    "出现明确破坏、试探或威胁。",
    "守夜人员疲劳到判断失误。"
  ],
  "notes": "记录能把恐慌变成信息。",
