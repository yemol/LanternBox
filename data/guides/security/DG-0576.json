{
  "id": "DG-0576",
  "title": "燃气味或疑似泄漏：低暴露撤离卡",
  "category": "安全与风险",
  "priority": "P0",
  "scenario": "室内出现燃气味或疑似泄漏，点火和电火花可能引发爆燃。",
  "goal": "不制造火花地撤到上风处并隔离入口。",
  "tools": [
    "湿布（仅遮口鼻）",
    "纸质人员表",
    "警示标记",
    "机械钥匙",
    "上风集合点"
  ],
  "steps": [
    "禁止开关电器、点火、插拔插头或使用室内电话。",
    "用喊话和手势通知人员，沿最近可走路线撤离。",
    "经过且无需进入浓味区时，只关闭可直接触及的气源阀。",
    "到上风集合点清点人员并标记禁止入口。",
    "记录气味位置、时间和是否关闭气源。"
  ],
  "check": [
    "所有人员在上风集合点并完成清点。",
    "入口有不可误解的禁火禁入标记。",
    "无人返回室内取物或操作电器。"
  ],
  "common_mistakes": [
    "开灯查漏。",
    "用明火寻找泄漏点。",
    "因气味变淡就立即返回。"
  ],
  "fallback": [
    "无法关闭气源时保持撤离和上风隔离。",
    "无标记材料时安排人员在安全距离口头拦阻，轮换值守。"
  ],
  "stop_or_escalate": [
    "闻到燃气、听到泄漏声、有人头晕恶心或来源不明时立即停止进入并撤离。",
    "未确认无泄漏前禁止点火、通电和返回取物。"
  ],
