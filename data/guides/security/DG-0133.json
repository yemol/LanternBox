{
  "id": "DG-0133",
  "title": "物资被翻动处理",
  "category": "个人装备与防护",
  "priority": "P0",
  "scenario": "发现食物、药品、工具、隐藏物资或仓库被人或动物动过。",
  "goal": "确认损失、污染和制度漏洞，避免立刻内讧。",
  "tools": [
    "库存模块",
    "手套",
    "记录本",
    "标签",
    "相机可选"
  ],
  "steps": [
    "先不要大声指责任何人，避免冲突升级。",
    "戴手套检查被动过的物资是否缺失、破损、污染或被咬。",
    "拍照或画图记录原位置、异常位置和缺失数量。",
    "高风险入口物资先隔离，不直接放回食物区。",
    "对照库存记录，确认数量和位置差异。",
    "复盘可能原因：借用未登记、动物、儿童误拿、外人进入、标签不清。",
    "调整措施：加锁、换位置、双人登记、边界标记或夜间观察。"
  ],
  "check": [
    "缺失和污染被记录。",
    "入口物资已隔离。",
    "没有靠猜测直接定责。"
  ],
  "common_mistakes": [
    "一发现就吵架。",
    "被鼠咬食物切掉一块继续吃。",
    "只改系统数量不查原因。"
  ],
  "fallback": "没有相机时，用纸画示意图，写明时间和位置。",
  "stop_or_escalate": [
    "药品、水、燃料、工具被动过且原因不明时，立即提高该类物资管理等级。"
  ],
  "notes": "被翻动是系统报警，不只是抓人的侦探题。",
