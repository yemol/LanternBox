{
  "id": "DG-0633",
  "title": "物资分配冲突暂停",
  "category": "安全",
  "priority": "P0",
  "scenario": "物资分配时出现情绪升级或互相指责，继续讨论会增加冲突风险。",
  "goal": "把冲突从现场分配中分离出来，先保护物资和人员距离。",
  "keywords": [
    "安全",
    "安全",
    "物资分配冲突暂停",
    "长期断供",
    "小团队",
    "行动卡",
    "物资分配冲突暂停",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "分配表",
    "暂停标记",
    "计时工具",
    "记录纸",
    "隔离箱"
  ],
  "steps": [
    "负责人说出暂停口令，立即停止拿取和分发，所有未分配物资回到可见位置。",
    "让争议双方分开至少数步，由第三人看管物资，不在物资旁继续争辩。",
    "用分配表核对已领、未领和特殊需求，只处理事实差异，不评价动机。",
    "设定短时间冷却后再恢复，恢复时按编号或小组顺序发放。",
    "事后记录争议触发点，下一轮提前公布规则或改为小组领取。"
  ],
  "check": [
    "物资已回到可见且可控位置。",
    "争议双方已分开。",
    "恢复分配依据为记录而非口头争执。"
  ],
  "common_mistakes": [
    "让吵得最凶的人先拿。",
    "负责人边解释边继续发。",
    "把库存放在争议双方中间。"
  ],
  "fallback": [
    "没有第三人时，先把物资封箱并暂停到成员冷静。",
    "配给表缺失时，立即重建当前库存和人数，不凭记忆补发。"
  ],
  "stop_or_escalate": [
    "出现推搡、抢夺、威胁或工具被拿起时停止分配并扩大人员距离。",
    "同一问题反复出现时，重设分配规则和见证机制。"
  ],
