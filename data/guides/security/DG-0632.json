{
  "id": "DG-0632",
  "title": "门口玻璃碎裂隔离",
  "category": "安全",
  "priority": "P0",
  "scenario": "门口玻璃碎裂，既有割伤风险，也可能暴露室内情况。",
  "goal": "先隔离碎玻璃和视线，再决定临时封堵方式。",
  "keywords": [
    "安全",
    "安全",
    "门口玻璃碎裂隔离",
    "长期断供",
    "小团队",
    "行动卡",
    "门口玻璃碎裂隔离",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "厚手套",
    "硬纸板或木板",
    "胶带",
    "扫帚",
    "袋子",
    "鞋底检查布"
  ],
  "steps": [
    "先让赤脚、儿童和宠物远离门口，划出不能踩踏的边界。",
    "从大块到小碎片清理玻璃，碎片装入硬容器或多层袋，外面标记锐物。",
    "检查门内外鞋底、门垫和通道，避免碎片被带入睡眠区。",
    "用纸板、木板或布从室内临时遮挡视线，保持可快速移除的出口。",
    "记录破裂原因和外部可见范围，安排夜间绕行或观察。"
  ],
  "check": [
    "碎玻璃已清理并标记。",
    "通道和鞋底已复查。",
    "遮挡没有封死撤离出口。"
  ],
  "common_mistakes": [
    "先封门再清玻璃。",
    "用薄垃圾袋装尖锐碎片。",
    "忽视鞋底带入的小碎片。"
  ],
  "fallback": [
    "没有硬板时，用多层纸箱和布先遮视线，再安排人员绕行。",
    "清理工具不足时，先扩大禁入区，不用手捡细碎玻璃。"
  ],
  "stop_or_escalate": [
    "玻璃继续脱落、外部有人试探或门体失去闭合能力时，停止普通清理并转为入口安全处置。",
    "有人割伤时，先处理伤口和污染，再继续清理。"
  ],
