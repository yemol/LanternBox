{
  "id": "DG-0194",
  "title": "纸条留言格式",
  "category": "通信信息与数据安全",
  "priority": "P0",
  "scenario": "需要快速留下可读、可执行的信息。",
  "goal": "让留言短、准、能被后来者理解。",
  "tools": [
    "纸",
    "笔",
    "防水袋",
    "手表"
  ],
  "steps": [
    "第一行写日期和时间。",
    "第二行写离开人数和基本状态。",
    "第三行写去向和备用去向。",
    "第四行写原因，例如进水、燃气味、外出取水、转移到备用点。",
    "第五行写下一次更新时间或等待多久。",
    "最后写不要进入的危险点，但不写完整库存。"
  ],
  "check": [
    "留言有时间。",
    "去向和原因清楚。",
    "读者知道下一步等还是走。"
  ],
  "common_mistakes": [
    "只写我们走了。",
    "字迹太小或太乱。",
    "写下完整隐藏物资位置。"
  ],
  "fallback": "时间紧时至少写：时间、人数、去向、原因。",
  "stop_or_escalate": [
    "地点危险、外人可能看到时，只留必要信息，不暴露敏感资料。"
  ],
  "notes": "好留言像路标，不像日记。",
