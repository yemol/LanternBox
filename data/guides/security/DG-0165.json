{
  "id": "DG-0165",
  "title": "宠物粮耗尽替代",
  "category": "种植养殖与采集",
  "priority": "P1",
  "scenario": "宠物粮不足或断供，需要短期过渡。",
  "goal": "短期维持宠物基本进食，同时不制造新卫生风险。",
  "tools": [
    "宠物碗",
    "安全水",
    "简单食材",
    "记录本"
  ],
  "steps": [
    "先盘点剩余宠物粮，计算能撑几天。",
    "短期替代优先选择简单、低盐、熟透、不过期的食物。",
    "不要给宠物吃腐败食物、重盐剩菜、骨头碎片和不明植物。",
    "每次换食物只换一部分，观察呕吐、腹泻和精神状态。",
    "宠物饮水要固定碗，不让它直接喝公共饮水桶。",
    "记录进食和排泄变化。"
  ],
  "check": [
    "宠物仍能进食饮水。",
    "没有翻垃圾找食物。",
    "呕吐腹泻被记录。"
  ],
  "common_mistakes": [
    "把腐败食物给宠物处理。",
    "宠物吃完污染食物后接触儿童餐具。",
    "突然大量换食。"
  ],
  "fallback": "没有合适食材时，减少活动量，优先保水，不用高风险食物硬喂。",
  "stop_or_escalate": [
    "宠物持续呕吐腹泻、精神萎靡、拒水或攻击性增加时，隔离观察。"
  ],
  "notes": "宠物也是家庭系统的一部分，不能让它变成卫生漏洞。",
