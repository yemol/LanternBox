{
  "id": "DG-0631",
  "title": "陌生人交换物资低暴露流程",
  "category": "安全",
  "priority": "P0",
  "scenario": "需要和陌生人交换物资，但不能暴露库存、成员结构和住所核心位置。",
  "goal": "用低暴露流程完成必要交换，并保留退出和复核空间。",
  "keywords": [
    "安全",
    "安全",
    "陌生人交换物资低暴露流程",
    "长期断供",
    "小团队",
    "行动卡",
    "陌生人交换物资低暴露流程",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "交换清单",
    "少量样品",
    "袋子",
    "记录纸",
    "口令或信号",
    "手电"
  ],
  "steps": [
    "交换前只带本次愿意放弃的物资，不携带完整库存清单或全部同类物品。",
    "选择离住所核心区有距离、可观察退路的位置，不让对方跟随回到储物点。",
    "由两人执行：一人交流，一人观察环境和时间，超过约定时间即结束。",
    "只谈物品数量、状态和交换条件，不透露总人数、病人、武器、粮水余量。",
    "交换物回到住所前先隔离检查，再登记来源和接触人员。"
  ],
  "check": [
    "携带物资限于本次交换量。",
    "交换点不暴露住所核心区。",
    "交换物已隔离检查并记录。"
  ],
  "common_mistakes": [
    "为了建立信任展示库存。",
    "单人携带大量物资外出。",
    "把陌生人带到储物区验货。"
  ],
  "fallback": [
    "对方要求查看更多库存时，改为下次约定，不现场加码。",
    "地点不合适时放弃交换，保留物资和人员安全。"
  ],
  "stop_or_escalate": [
    "对方试图跟随、围堵、打听人员弱点或临时改变人数时停止交换。",
    "观察者发现退路被遮挡或周边异常聚集时立即撤离。"
  ],
