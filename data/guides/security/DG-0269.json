{
  "id": "DG-0269",
  "title": "成员档案访问规则",
  "category": "通信信息与数据安全",
  "priority": "P2",
  "scenario": "成员档案库包含照片、医疗记录、数字证件、紧急联系人和照护信息。",
  "goal": "保证关键时刻能用，平时不被随意查看。",
  "tools": [
    "访问记录表",
    "口令页",
    "成员档案库",
    "负责人名单"
  ],
  "steps": [
    "成员档案入口默认锁定，不在首页显示姓名、照片和证件缩略图。",
    "指定档案负责人和备用负责人。",
    "访问前确认目的：医疗、撤离、照护交接、证件核对或备份。",
    "查看后记录访问时间、访问人和原因。",
    "查看完成后手动锁定页面，离开设备前确认已锁定。",
    "不要把成员档案截图存入普通图片目录。",
    "外部人员不得接触成员档案页面。"
  ],
  "check": [
    "档案默认锁定。",
    "访问有原因和记录。",
    "查看后能锁定。"
  ],
  "common_mistakes": [
    "成员照片直接显示在首页。",
    "临时打开后不锁屏。",
    "把证件截图发到普通文件夹。"
  ],
  "fallback": [
    "没有访问记录功能时，用纸质访问表临时记录。"
  ],
  "stop_or_escalate": [
    "发现非授权查看、设备丢失、口令泄露时，立即更换口令并检查备份。"
  ],
  "notes": "成员档案是生命资料，不是相册。",
