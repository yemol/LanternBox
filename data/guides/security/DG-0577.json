{
  "id": "DG-0577",
  "title": "夜间外部异响：观察与记录",
  "category": "安全与风险",
  "priority": "P0",
  "scenario": "夜间住所外出现不明异响，直接开门可能暴露人员和位置。",
  "goal": "在室内完成方向、次数和变化记录，再决定是否保持封闭。",
  "tools": [
    "手电（遮光）",
    "计时工具",
    "纸笔",
    "观察孔或安全窗",
    "预定信号表"
  ],
  "steps": [
    "熄灭靠窗强光，让人员离开门窗正前方。",
    "记录异响方向、时间、间隔和是否移动。",
    "从两个受保护观察点短时查看，不开门喊话。",
    "核对风、动物、松动物件和本队信号。",
    "指定一人继续观察，其余人员保持安静和通道畅通。"
  ],
  "check": [
    "记录能区分单次、重复和移动声源。",
    "门窗仍闭合，观察者未暴露轮廓。",
    "成员知道集合点和不开门规则。"
  ],
  "common_mistakes": [
    "多人同时靠窗。",
    "开门追查。",
    "用强光持续照向外部。"
  ],
  "fallback": [
    "无观察孔时只做听音记录并加强内侧门挡。",
    "无人可轮值时设置简易响铃标记并集中休息。"
  ],
  "stop_or_escalate": [
    "异响逼近、门窗被试探、出现烟火或成员无法保持安静时停止观察并转入内部避险位置。",
    "无法确认外部状态时不单独外出。"
  ],
  "related_wiki": [
    "safety-night-safety-003"
  ],
  "notes": "按时间线记录异响和观察结论。",
