{
  "id": "DG-0519",
  "title": "过滤材料替代边界",
  "category": "工具维修与替代制作",
  "priority": "P0",
  "scenario": "缺少正式滤芯，需要用布、砂、炭、纸等做预过滤。",
  "goal": "明确预过滤只能去除颗粒，不能等同安全饮水。",
  "tools": [
    "布",
    "砂石",
    "炭",
    "容器",
    "标签"
  ],
  "steps": [
    "先说明替代过滤只是预处理。",
    "布料过滤可去除大颗粒，但不能杀菌。",
    "砂石炭需要来源干净，不用化学污染材料。",
    "过滤后的水仍需消毒或煮沸。",
    "过滤装置标记为生水处理工具。",
    "入口和非入口过滤材料分开。",
    "过滤材料变臭、发黏或堵塞时更换。"
  ],
  "check": [
    "知道预过滤不是消毒。",
    "过滤后仍处理。",
    "工具有生水标签。"
  ],
  "common_mistakes": [
    "布滤一下就喝。",
    "用不明炭灰过滤。",
    "过滤器和饮用水工具混放。"
  ],
  "fallback": [
    "材料不足时，至少沉淀加布滤，再进行消毒。"
  ],
  "stop_or_escalate": [
    "水有化学味、油膜、尸体污染时，不靠替代过滤入口。"
  ],
  "notes": "过滤能抓住泥沙，抓不住所有危险。",
