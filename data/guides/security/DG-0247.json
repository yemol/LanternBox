{
  "id": "DG-0247",
  "title": "采集后隔离和试吃规则",
  "category": "种植养殖与采集",
  "priority": "P1",
  "scenario": "从野外或陌生来源取得食物，无法完全确认安全。",
  "goal": "让采集物先经过隔离、识别和小范围观察。",
  "tools": [
    "隔离箱",
    "标签",
    "记录本",
    "锅",
    "安全水"
  ],
  "steps": [
    "采集物先进入隔离区，不直接放进厨房和主食区。",
    "贴标签写来源、时间、采集人、识别依据。",
    "能确认的低风险食物也要清洗和充分加热。",
    "第一次食用只给健康成年人少量尝试，不给儿童、老人、孕妇、病人先吃。",
    "观察数小时到一天，记录是否腹痛、呕吐、腹泻、麻木、皮疹。",
    "没有异常后也不要立刻大量食用。",
    "任何不适都停止该批食物，并保留样本。"
  ],
  "check": [
    "采集物先隔离。",
    "来源和时间明确。",
    "脆弱成员没有先试吃。"
  ],
  "common_mistakes": [
    "采回来直接煮一锅全员吃。",
    "没记录来源。",
    "有人不适还继续吃。"
  ],
  "fallback": [
    "食物极少时，也要保留少量样本，不把全部吃光。"
  ],
  "stop_or_escalate": [
    "出现群体不适、神经症状、持续呕吐腹泻时，停止采集来源并处理为中毒事件。"
  ],
  "notes": "采集物要先通过门岗，再进饭锅。",
