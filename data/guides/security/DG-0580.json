{
  "id": "DG-0580",
  "title": "门窗受损：临时加固与低暴露",
  "category": "安全与风险",
  "priority": "P0",
  "scenario": "门窗破损导致风雨进入、碎片掉落或外部视线暴露。",
  "goal": "从室内低暴露位置清除松动物并做可撤除加固。",
  "tools": [
    "厚手套",
    "护目材料",
    "木条或硬板",
    "绳带或螺钉",
    "遮挡布"
  ],
  "steps": [
    "让人员离开破口正前方，检查碎玻璃、松框和外侧压力。",
    "戴防护从室内收集松散碎片，装入硬容器。",
    "用硬板跨过完整框架固定，不把力压在裂玻璃上。",
    "加内侧遮挡并保留一个可观察缝。",
    "轻推加固点，确认不晃动后标记复查时间。"
  ],
  "check": [
    "碎片不会从边缘掉落。",
    "固定点落在稳固框架且不挡主出口。",
    "风吹时板材不拍击或松脱。"
  ],
  "common_mistakes": [
    "站在外侧高处操作。",
    "胶带粘在潮湿粉化表面。",
    "封死唯一通风或出口。"
  ],
  "fallback": [
    "无板材时用厚布从内侧拉紧挡雨，并划出远离区。",
    "无法加固时关闭该房间，转移睡眠和物资。"
  ],
  "stop_or_escalate": [
    "框架变形、墙体开裂、外部飞物持续或需悬空作业时停止加固。",
    "无法保留撤离出口时不封堵该开口。"
  ],
  "related_wiki": [
