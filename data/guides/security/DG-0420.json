{
  "id": "DG-0420",
  "title": "口头交代三句法",
  "category": "通信信息与数据安全",
  "priority": "P0",
  "scenario": "时间紧、对方紧张或不能阅读，需要快速交代任务。",
  "goal": "用三句话交代行动，降低误解。",
  "tools": [
    "任务卡",
    "口令表",
    "记录本"
  ],
  "steps": [
    "第一句说目标：去哪里或做什么。",
    "第二句说边界：不要做什么或危险点在哪里。",
    "第三句说回报：什么时候回来或向谁汇报。",
    "让对方复述一遍。",
    "任务复杂时拆成多个三句，不一次说完全部。",
    "交代后写入记录本。",
    "任务完成后核对是否按三句执行。"
  ],
  "check": [
    "目标、边界、回报都有。",
    "对方复述过。",
    "任务有记录。"
  ],
  "common_mistakes": [
    "只说快去看看。",
    "不说危险边界。",
    "对方没听懂也出发。"
  ],
  "fallback": [
    "不会组织语言时，直接按做什么、别碰什么、回来找谁三项说。"
  ],
  "stop_or_escalate": [
    "对方复述错误、任务涉及高风险、外部情况不明时，暂停任务。"
  ],
  "notes": "三句法像把混乱装进小盒子，刚好够带走。",
