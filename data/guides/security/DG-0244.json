{
  "id": "DG-0244",
  "title": "蘑菇采集禁忌",
  "category": "种植养殖与采集",
  "priority": "P1",
  "scenario": "野外看到蘑菇，食物紧张，想采来吃。",
  "goal": "在没有专业识别能力时避免高风险中毒。",
  "tools": [
    "袋子",
    "记录本",
    "手套"
  ],
  "steps": [
    "没有可靠识别能力时，不采食野生蘑菇。",
    "不要相信颜色鲜艳才有毒、虫吃过就没毒、煮熟就安全等说法。",
    "不同蘑菇不要混在一起。",
    "如果为了记录，拍照或单独留样，不进入食物区。",
    "儿童不能采蘑菇玩或放入口中。",
    "如果误食，保留剩余样本和呕吐物线索，记录时间和数量。"
  ],
  "check": [
    "野生蘑菇没有进入公共食物。",
    "样本和食物分开。",
    "儿童不接触。"
  ],
  "common_mistakes": [
    "觉得煮熟就安全。",
    "看见动物吃过就跟着吃。",
    "把不同蘑菇混成一锅。"
  ],
  "fallback": [
    "食物紧张时，优先寻找更可识别、更低风险的食物来源。"
  ],
  "stop_or_escalate": [
    "误食蘑菇后出现恶心、呕吐、腹泻、出汗、幻觉、意识异常时，立即升级处理。"
  ],
  "notes": "蘑菇不是赌运气的食物。",
