  "steps": [
    "设定四档风险：正常、注意、警戒、停止。",
    "正常表示任务可按计划执行。",
    "注意表示有小变化，执行前复核路线和人员。",
    "警戒表示只做必要任务，高风险任务双人制。",
    "停止表示暂停外出、开火、交易或其他暴露行为。",
    "每天晨间和晚间评估一次当前等级。",
    "等级变化必须写明原因和生效时间。"
  ],
  "check": [
    "四档含义清楚。",
    "等级变化有原因。",
    "任务按等级调整。"
  ],
