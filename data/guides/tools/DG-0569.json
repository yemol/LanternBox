{
  "id": "DG-0569",
  "title": "门窗松动：临时加固",
  "category": "工具维修与替代",
  "priority": "P0",
  "scenario": "门窗连接件松动，风吹时晃动或发出撞击。",
  "goal": "从室内用可撤除支撑限制位移，同时保留出口。",
  "tools": [
    "木条或硬板",
    "绳带",
    "楔块",
    "手动工具",
    "标记"
  ],
  "steps": [
    "检查松动来自铰链、锁扣、框体还是墙面。",
    "关闭门窗，在稳固框体之间加楔或斜撑。",
    "用绳带限制开启幅度，不把固定点系在把手薄弱处。",
    "轻推测试并确认主出口仍可开启。"
  ],
  "check": [
    "风压下框体不反复撞击。",
    "支撑点不滑动、不压裂玻璃。",
    "主出口无需拆工具即可打开。"
  ],
  "common_mistakes": [
    "钉入开裂墙体。",
    "用重物顶住唯一出口。",
    "站到外侧高处加固。"
  ],
  "fallback": [
    "无木条时用折叠硬纸板作楔并缩短复查间隔。",
    "框体不稳时关闭该空间，人员转移到内侧房间。"
  ],
  "stop_or_escalate": [
    "墙体开裂、玻璃受压、支撑持续滑动或需外侧悬空操作时停止。",
    "加固会封死出口时不得实施。"
  ],
