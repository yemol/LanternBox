{
  "id": "DG-0567",
  "title": "电线破皮：临时绝缘和停用判断",
  "category": "工具维修与替代",
  "priority": "P0",
  "scenario": "电线外皮破损，可能露铜、短路或触电。",
  "goal": "判断只能做外层防磨还是必须彻底停用。",
  "tools": [
    "断电标记",
    "绝缘胶带或热缩材料",
    "手电",
    "剪线工具",
    "记录纸"
  ],
  "steps": [
    "先断电并拔离电源，检查破损处是否露铜、发黑或变形。",
    "仅外皮轻微磨损且导体完整时，清洁干燥后分层包覆。",
    "包覆两端超过破损处并避免形成尖锐折弯。",
    "标记修补处，只在低负载、干燥、有人观察下复核。"
  ],
  "check": [
    "无铜线外露、焦黑和异味。",
    "包覆层完整且弯折时不滑移。",
    "低负载复核时不发热。"
  ],
  "common_mistakes": [
    "不断电就缠胶带。",
    "把多根裸线一起包。",
    "在潮湿地面继续使用。"
  ],
  "fallback": [
    "无合格绝缘材料时停用该线，改用手动工具或位置更近的独立设备。",
    "必须保留设备时先移除负载并封住电源端。"
  ],
  "stop_or_escalate": [
    "露铜、焦黑、发热、火花、反复跳闸或修补层潮湿时立即停用。",
    "无法确认导体完整或需要高负载时不可继续。"
  ],
