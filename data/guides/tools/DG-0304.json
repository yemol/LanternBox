{
  "id": "DG-0304",
  "title": "木板和木棍再利用",
  "category": "工具维修与替代制作",
  "priority": "P0",
  "scenario": "有木板、桌腿、木棍、托盘、旧家具或建筑木料。",
  "goal": "用于垫高、支撑、固定、简易架子和燃料储备。",
  "tools": [
    "手套",
    "锤子",
    "绳子",
    "砂纸可选",
    "标签"
  ],
  "steps": [
    "先检查木料是否有钉子、尖刺、虫蛀、腐烂、霉味和化学漆味。",
    "可用木板优先用于物资离地、防潮垫、临时架子和门窗加固。",
    "木棍可做支撑杆、标记杆、简易晾晒杆和边界杆。",
    "有油漆、胶合、化学味的木料不要用于食物接触和室内燃烧。",
    "带钉木料集中放置并标记，避免踩伤。",
    "木料受潮后晾干，防止霉变。",
    "无法安全使用的木料再考虑作为室外燃料或废弃。"
  ],
  "check": [
    "木料无明显钉刺危险。",
    "化学味木料没有燃烧取暖。",
    "木板用途有分区。"
  ],
  "common_mistakes": [
    "拆旧家具直接烧。",
    "带钉木板丢通道。",
    "腐烂木板承重。"
  ],
  "fallback": "木料不足时，优先保留完整板材用于垫高和加固。",
  "stop_or_escalate": [
    "木料承重开裂、霉味严重、化学味强、有人被钉刺伤时，立即降级处理。"
  ],
  "notes": "木头有两条命：结构材料和燃料，先用结构价值。",
