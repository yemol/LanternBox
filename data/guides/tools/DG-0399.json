  "steps": [
    "建立长期任务清单，单独区别于每日任务。",
    "每项写清目标、下一步、需要材料和负责人。",
    "不要把长期任务写成巨大口号，拆成可执行小步。",
    "每周选择一到两项推进，不和保命任务抢资源。",
    "完成小步骤就打勾，保留进展记录。",
    "任务失去意义时标记取消，不让清单堆成负担。",
    "月底复盘哪些长期任务值得继续。"
  ],
  "check": [
    "长期任务有下一步。",
    "每周推进少量。",
    "过期任务会取消。"
  ],
