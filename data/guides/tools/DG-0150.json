{
  "id": "DG-0150",
  "title": "工具借用和归还",
  "category": "工具维修与替代制作",
  "priority": "P0",
  "scenario": "多人共用工具，容易丢失、损坏或不知道谁拿走了。",
  "goal": "让关键工具可追踪，避免需要时找不到。",
  "tools": [
    "工具清单",
    "编号标签",
    "记录本",
    "库存模块"
  ],
  "steps": [
    "给每件关键工具贴统一编号。",
    "借出时记录工具编号、借用人、时间、用途和预计归还时间。",
    "归还时检查是否损坏、缺件、沾水、沾油或变钝。",
    "损坏工具不要直接放回正常区，贴待修标签。",
    "每天固定时间清点高频工具，例如刀、钳子、手电、扳手。",
    "借出未归还时，先查记录，不靠猜测争吵。"
  ],
  "check": [
    "工具编号和记录一致。",
    "损坏工具没有混回正常区。",
    "关键工具能快速找到。"
  ],
  "common_mistakes": [
    "熟人借用不登记。",
    "坏了偷偷放回去。",
    "多人同时以为工具在别人那里。"
  ],
  "fallback": [
    "没有库存模块时，先用纸质借用表记录。"
  ],
  "stop_or_escalate": [
    "急救、取水、供电相关工具丢失时，立即暂停非必要借用并复查。"
  ],
  "notes": "工具是生存流程的手脚，丢一个常常卡一串。",
