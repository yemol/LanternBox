{
  "id": "DG-0566",
  "title": "插线板和延长线进水后：隔离复核卡",
  "category": "工具维修与替代",
  "priority": "P0",
  "scenario": "插线板或延长线进水，内部可能残留水分并带电。",
  "goal": "先断能隔离，未经完全干燥和复核不得通电试验。",
  "tools": [
    "断电标记",
    "绝缘干燥位置",
    "手电",
    "干布",
    "封存袋"
  ],
  "steps": [
    "不触碰湿设备，先从干燥配电位置切断对应电源。",
    "确认插头与电源分离后，用干燥绝缘物移到隔离区。",
    "擦去外部水分，端口朝下自然通风，不加热烘烤。",
    "贴上进水停用标签并记录浸水范围和时间。"
  ],
  "check": [
    "电源端已物理断开并有标记。",
    "设备外表和端口无可见水珠。",
    "无人把它接回可用设备区。"
  ],
  "common_mistakes": [
    "带电拔湿插头。",
    "用吹风机或火烤加速。",
    "表面干了就通电试。"
  ],
  "fallback": [
    "无法安全断电时远离并封闭区域。",
    "缺备用线时改用离线、手动或低压独立设备，不复用进水线。"
  ],
  "stop_or_escalate": [
    "出现火花、焦味、发热、漏电感或无法确认断电时立即停止接近。",
    "内部进水或端口锈蚀时保持停用，不可通电。"
  ],
