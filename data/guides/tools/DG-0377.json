{
  "id": "DG-0377",
  "title": "针线修补包",
  "category": "工具维修与替代制作",
  "priority": "P0",
  "scenario": "衣物、背包、布袋、帐篷、鞋面、绳套、雨布边缘出现破损。",
  "goal": "用简单针线延长软材料寿命。",
  "tools": [
    "针",
    "线",
    "顶针可选",
    "剪刀",
    "布片",
    "安全盒"
  ],
  "steps": [
    "把针、线、扣子、布片、别针集中成修补包。",
    "针必须放入硬盒或针包，不散放。",
    "修补前清理破口周围泥水和松线。",
    "破洞较大时先加布片补强，再缝合边缘。",
    "背包带、受力点、雨布边缘用多针加固。",
    "修补后轻拉测试，不直接上高强度任务。",
    "记录哪些装备修补过，后续重点观察。"
  ],
  "check": [
    "针有硬盒。",
    "受力点有补强。",
    "修补后测试过。"
  ],
  "common_mistakes": [
    "针插床上。",
    "只缝破口不补强受力点。",
    "刚缝完就重载使用。"
  ],
  "fallback": [
    "没有针线时，用胶带、绳扎、别针或布条临时固定。"
  ],
  "stop_or_escalate": [
    "背包肩带、鞋面、担架布等承重材料破损严重时，不只靠针线硬撑。"
  ],
  "notes": "针线是轻装备的续命术。",
