  "steps": [
    "拍摄清晰正面照片，光线足够。",
    "儿童和老人照片定期更新。",
    "照片与成员编号绑定。",
    "不要把照片放入公共指南或普通备份。",
    "照片备份进入加密高敏感资料。",
    "成员外貌明显变化时更新。",
    "更新后删除或归档旧照片。"
  ],
  "check": [
    "照片清晰。",
    "照片加密保存。",
    "编号对应正确。"
  ],
  "common_mistakes": [
    "照片模糊。",
    "照片混进普通文件夹。",
    "成员变化后不更新。"
  ],
  "fallback": "没有相机时，记录明显特征作为临时替代。",
  "stop_or_escalate": [
    "走失、转运、身份核对需要时，照片必须能快速找到。"
  ],
  "notes": "照片不是纪念，是紧急识别工具。",
