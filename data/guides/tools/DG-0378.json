{
  "id": "DG-0378",
  "title": "防水临时修补",
  "category": "工具维修与替代制作",
  "priority": "P0",
  "scenario": "雨衣、防水布、帐篷、桶盖、袋子、窗缝出现小破洞或漏水。",
  "goal": "临时减缓漏水，保护干衣、药品、文件和睡眠区。",
  "tools": [
    "胶带",
    "塑料片",
    "干布",
    "剪刀",
    "标记笔"
  ],
  "steps": [
    "先擦干破损周围，湿面会降低粘贴效果。",
    "剪一块比破洞更大的塑料片或胶带补片。",
    "从内外两侧贴补，比单面更可靠。",
    "补完后轻压边缘，检查是否翘起。",
    "关键防水物修补后做小水量测试。",
    "在修补点做标记，后续正式维修。",
    "临时补片不要靠近明火和高热。"
  ],
  "check": [
    "破损处已擦干。",
    "补片覆盖超过破洞。",
    "关键物测试过。"
  ],
  "common_mistakes": [
    "湿着直接贴。",
    "补片刚好盖住洞没有余量。",
    "修补点靠近炉具。"
  ],
  "fallback": "没有胶带时，用塑料片加绳扎、夹子或压条临时遮挡。",
  "stop_or_escalate": [
    "漏水进入药品、证件、电器、睡眠区时，优先转移物资而不是只补洞。"
  ],
  "notes": "防水修补先救里面的东西，再救外面的皮。",
