{
  "id": "DG-0318",
  "title": "鞋带和绑带备用",
  "category": "个人装备与防护",
  "priority": "P0",
  "scenario": "鞋带断裂、背包带松脱、固定绳不足或临时需要捆扎。",
  "goal": "准备可替换的绑带系统，避免装备突然失效。",
  "tools": [
    "备用鞋带",
    "绳子",
    "布条",
    "扎带",
    "小袋"
  ],
  "steps": [
    "每个外出包里放一到两根备用鞋带或细绳。",
    "检查鞋带是否磨薄、断股、打结处开裂。",
    "鞋带断裂时先更换，不用散鞋继续走远路。",
    "旧鞋带不要立刻丢，可降级为捆扎、标签绳或小修补材料。",
    "背包带、雨布绳、晾晒绳和鞋带不要混用到无法追踪。",
    "备用绑带集中收纳，贴上用途标签。",
    "每次使用备用绑带后补回。"
  ],
  "check": [
    "外出包有备用绑带。",
    "磨损鞋带已更换。",
    "绑带有固定收纳位置。"
  ],
  "common_mistakes": [
    "鞋带断了还拖着走。",
    "所有绳子混成一团找不到。",
    "备用绑带用完不补。"
  ],
  "fallback": [
    "没有鞋带时，用布条或细绳临时代替，但要打平结，避免硌脚。"
  ],
  "stop_or_escalate": [
    "鞋带失效导致摔倒、背包带断裂、关键雨布松脱时，立即补充绑带库存。"
  ],
  "notes": "一根鞋带有时候比一把刀更先救场。",
