  "steps": [
    "不认识的植物不尝味、不嚼叶、不给儿童试吃。",
    "记录地点、形态、气味、季节和周边动物是否取食，但不作为可食依据。",
    "可疑植物与已确认食物分袋，采集工具接触后清洁。",
    "只采集本地已可靠识别、团队一致确认的食物。",
    "若有人误食，记录植物特征、时间和症状，保留样本但不继续食用。"
  ],
  "check": [
    "未知植物没有入口。",
    "样本与食物分开。",
    "误食记录准备完整。"
  ],
  "common_mistakes": [
    "动物吃过就认为人能吃。",
    "先尝一点试毒。",
    "把未知植物混入汤或粥。"
  ],
  "fallback": [
    "食物不足时优先寻找已知来源、储备或交换，不用未知植物补缺口。",
    "识别争议时按不可食处理。"
  ],
  "stop_or_escalate": [
    "误食后恶心、麻木、腹痛、头晕或皮疹时停止所有同类植物接触。",
    "无法可靠识别时不进入食物链。"
  ],
