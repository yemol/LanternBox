{
  "id": "DG-0680",
  "title": "病死动物隔离不食用",
  "category": "小规模养殖",
  "priority": "P1",
  "scenario": "动物病死或死因不明，饥饿状态下也不能把它当作可食肉源。",
  "goal": "隔离病死动物，保护人员、其他动物、水和食物。",
  "keywords": [
    "养殖",
    "小规模养殖",
    "病死动物隔离不食用",
    "长期断供",
    "小团队",
    "行动卡",
    "病死动物隔离不食用",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "手套或塑料袋",
    "铲子",
    "双层袋",
    "标签",
    "灰土"
  ],
  "steps": [
    "发现病死动物后先阻止儿童、宠物和其他动物接触，不切开检查。",
    "用手套替代物或工具移动尸体，双层封袋或深埋在远离水源处。",
    "接触过的笼舍、垫料和容器单独清理，污染物封存。",
    "记录死亡时间、症状、同笼动物和最近饲料水源。",
    "观察同群动物食欲、粪便和精神，必要时隔离疑似个体。"
  ],
  "check": [
    "尸体未进入食物流程。",
    "污染垫料和容器已分开处理。",
    "同群动物已观察记录。"
  ],
  "common_mistakes": [
    "看起来新鲜就食用。",
    "徒手搬动尸体。",
    "只处理尸体不观察同群动物。"
  ],
  "fallback": [
    "无法深埋时，双层封存并放在远离水源和居住区的临时点。",
    "防护不足时，减少接触面积，使用工具而非手搬。"
  ],
  "stop_or_escalate": [
    "出现多只死亡、异常神经症状、出血或强烈腐败味时扩大隔离。",
    "污染接近饮水区时停止该水点入口用途。"
  ],
