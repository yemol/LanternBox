{
  "id": "DG-0676",
  "title": "小动物饮水遮阴",
  "category": "小规模养殖",
  "priority": "P1",
  "scenario": "小动物在高温或封闭环境中饮水和遮阴不足，容易迅速衰弱。",
  "goal": "保障基础饮水、遮阴和通风，减少热应激和死亡。",
  "keywords": [
    "养殖",
    "小规模养殖",
    "小动物饮水遮阴",
    "长期断供",
    "小团队",
    "行动卡",
    "小动物饮水遮阴",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "饮水容器",
    "遮阴布",
    "垫高物",
    "记录纸",
    "清洁布"
  ],
  "steps": [
    "先检查动物是否喘息、趴卧、精神差或饮水器空置。",
    "把饮水容器放在不会被踩翻的位置，每日固定时间清洗和补水。",
    "设置遮阴但保持通风，不用密闭塑料完全覆盖笼舍。",
    "高温时减少搬动和惊扰，饲喂安排在较凉时段。",
    "记录饮水量、粪便和精神变化，异常个体单独观察。"
  ],
  "check": [
    "饮水器稳定且有水。",
    "遮阴不影响通风。",
    "异常动物已记录。"
  ],
  "common_mistakes": [
    "只遮阴不通风。",
    "饮水容器被粪便污染仍继续用。",
    "高温正午搬动动物。"
  ],
  "fallback": [
    "容器不足时优先保障幼小、怀孕或虚弱动物。",
    "遮阴材料不足时，移动笼舍到自然阴影并抬高离地。"
  ],
  "stop_or_escalate": [
    "动物持续喘息、倒卧、拒水或抽搐时停止搬动并降温观察。",
    "饮水无法保障时，减少养殖规模或转入处置决策。"
  ],
