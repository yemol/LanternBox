    "粪便远离水源",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "铲子",
    "桶或袋",
    "灰土",
    "手套",
    "标记绳"
  ],
  "steps": [
    "先标出饮水点、取水路线和动物粪便区之间的距离。",
    "每日固定清除靠近水源、入口和食物区的粪便。",
    "粪便集中到下风、离水源远、不会被雨水冲回的地点。",
    "清理工具只用于圈舍，不进入食物、水和医疗区。",
    "清理后照护者洗手并记录粪便异常，如腹泻、血迹或寄生虫。"
  ],
  "check": [
    "粪便堆放点远离水源。",
    "圈舍工具没有进入生活区。",
    "粪便异常已记录。"
  ],
  "common_mistakes": [
    "雨前把粪便堆在坡上。",
    "用同一把铲子处理食物和粪便。",
    "只看气味不看水流方向。"
  ],
  "fallback": [
    "没有铲子时，用专用板片或厚枝条临时清理并标记禁作他用。",
    "空间不足时，用容器封存并提高离地，避免雨水冲刷。"
  ],
  "stop_or_escalate": [
    "粪水流向饮水区、动物集体腹泻或虫害爆发时停止该布局。",
    "清理者有伤口接触粪便时先处理伤口污染。"
  ],
