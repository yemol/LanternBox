{
  "id": "DG-0677",
  "title": "饲料霉变停用",
  "category": "小规模养殖",
  "priority": "P1",
  "scenario": "饲料出现霉味、结块或虫害，继续投喂会造成动物生病并污染圈舍。",
  "goal": "停用可疑饲料并保护剩余库存。",
  "keywords": [
    "养殖",
    "小规模养殖",
    "饲料霉变停用",
    "长期断供",
    "小团队",
    "行动卡",
    "饲料霉变停用",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "手套",
    "密封袋",
    "标签",
    "干燥容器",
    "记录纸"
  ],
  "steps": [
    "发现霉味、结块、变色或虫粉时，先停止投喂该批饲料。",
    "把可疑饲料密封移出饲喂区，不和干净饲料混放。",
    "检查同箱饲料和储存点是否受潮、漏水或被鼠咬。",
    "剩余可用饲料转入干燥容器，写明开封日期和检查人。",
    "观察已食用动物的精神、食欲和粪便，记录异常时间。"
  ],
  "check": [
    "可疑饲料已标记停用。",
    "干净饲料转入干燥区。",
    "动物异常观察已开始。"
  ],
  "common_mistakes": [
    "晒一晒继续喂。",
    "把霉料混进好料减少损失。",
    "只处理饲料不检查储存点。"
  ],
  "fallback": [
    "饲料紧缺时减少投喂量并寻找安全替代，不用霉变料补缺口。",
    "容器不足时至少分袋离地，避免同箱扩散。"
  ],
  "stop_or_escalate": [
    "多只动物腹泻、拒食或精神差时停止同批饲料。",
    "储存点持续潮湿时迁移全部饲料。"
  ],
