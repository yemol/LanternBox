{
  "id": "DG-0065",
  "title": "大规模停水第一天",
  "category": "灾害应对与灾后恢复",
  "priority": "P0",
  "scenario": "城市或区域突然停水，恢复时间不明。",
  "goal": "第一天建立水秩序，避免误用和浪费。",
  "tools": [
    "水桶",
    "标签纸",
    "库存模块",
    "记录本",
    "盆"
  ],
  "steps": [
    "立即盘点所有现有水：瓶装水、桶装水、水壶、热水器余水、马桶水箱水、雨水容器。",
    "按饮用、烹饪、清洁、冲厕分级标记。",
    "饮用水单独放，不参与洗手、洗衣、拖地。",
    "暂停洗澡、洗衣、长时间冲洗等高耗水行为。",
    "安排固定洗手点，用少量水和肥皂，避免每个人乱开容器。",
    "计算每人每天最低饮水和烹饪水，写在公告板或日记里。",
    "寻找后续水源前，先确认容器和取水路线。"
  ],
  "check": [
    "水已经分级。",
    "饮用水没有被拿去清洁。",
    "每天消耗有记录。"
  ],
  "common_mistakes": [
    "刚停水就用饮用水洗东西。",
    "所有水桶无标签。",
    "等水用完才找水源。"
  ],
  "fallback": [
    "容器不足时，优先给饮用水找有盖容器，清洁水可用开口盆短期存放。"
  ],
  "stop_or_escalate": [
    "有人误饮清洁水。",
    "水源被污染。",
    "饮用水低于最低库存线。"
  ],
  "notes": "停水第一天的管理，决定后面几天会不会混乱。",
