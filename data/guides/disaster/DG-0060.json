{
  "id": "DG-0060",
  "title": "台风或强风后：坠物和漏电检查",
  "category": "灾害应对与灾后恢复",
  "priority": "P0",
  "scenario": "台风、龙卷风、强风或大暴雨后准备外出或恢复活动。",
  "goal": "避免风停后的二次坠物、积水触电和结构风险。",
  "tools": [
    "厚底鞋",
    "手套",
    "手电",
    "记录本",
    "胶带"
  ],
  "steps": [
    "等风雨明显减弱后再外出，不为了围观提前下楼。",
    "从窗内先观察外部：树枝、电线、广告牌、玻璃、瓦片、积水。",
    "走路避开临街高楼、广告牌、脚手架、大树和电线附近。",
    "不踩不明积水，尤其积水中有电线、配电箱或电器碎片时。",
    "检查阳台、窗户、屋顶、排水口和漏水点。",
    "把松动的物品先移走或固定，危险点贴标记。",
    "记录损坏点和修复优先级。"
  ],
  "check": [
    "没有靠近断线和坠物区。",
    "阳台和窗边重物已处理。",
    "危险点已标记。"
  ],
  "common_mistakes": [
    "风刚停就外出拍照。",
    "徒手拉扯断线。",
    "让儿童先去阳台查看。"
  ],
  "fallback": [
    "无法修复时，先用胶带、绳子、箱子做临时隔离标记。"
  ],
  "stop_or_escalate": [
    "看到断电线、漏电火花、建筑外墙松动、持续落物时，远离并封锁路线。"
  ],
  "notes": "风停只是第一幕落幕，坠物常常在第二幕登场。",
