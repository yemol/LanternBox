{
  "id": "DG-0189",
  "title": "冬季水源防冻",
  "category": "灾害应对与灾后恢复",
  "priority": "P0",
  "scenario": "低温环境中饮用水、洗手水、管线或水桶可能冻结。",
  "goal": "保护最低可用水量，避免早晨无水可用。",
  "tools": [
    "水桶",
    "保温材料",
    "布料",
    "纸板",
    "室内角落"
  ],
  "steps": [
    "把饮用水优先放到室内较暖位置。",
    "水桶不要直接放在冰冷地面，下面垫纸板、木板或衣物。",
    "夜间给水桶外面包布料或毯子。",
    "小容器比大容器更容易冻透，关键水尽量集中保存。",
    "睡前确认第二天早晨最低饮水和做饭水已经准备好。",
    "冻住的水不要用明火直接烤塑料容器。"
  ],
  "check": [
    "早晨仍有可用饮水。",
    "水桶离开冰冷地面。",
    "关键水有保温。"
  ],
  "common_mistakes": [
    "所有水放室外。",
    "塑料桶直接靠火烤。",
    "把洗手水和饮用水冻在一起还无备用。"
  ],
  "fallback": "空间不足时，至少把一小部分饮用水放在睡眠区附近。",
  "stop_or_escalate": [
    "饮水全部冻住、容器冻裂、管线破裂时，调整储水位置和容器。"
  ],
  "notes": "冬季水不是只有有没有，还要能不能倒出来。",
