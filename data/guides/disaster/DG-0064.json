{
  "id": "DG-0064",
  "title": "疑似化学污染：远离、脱外层、冲洗",
  "category": "灾害应对与灾后恢复",
  "priority": "P0",
  "scenario": "闻到刺鼻化学味、看到异常烟雾、液体，或多人眼鼻喉刺激。",
  "goal": "尽快脱离污染源，减少皮肤和呼吸道接触。",
  "tools": [
    "口罩或布",
    "清水",
    "塑料袋",
    "手套",
    "剪刀"
  ],
  "steps": [
    "不要靠近源头识别，不拍照围观。",
    "观察风向，优先向上风向、侧风向、高处或远离源头方向移动。",
    "用布或口罩遮住口鼻，减少吸入。",
    "脱离后脱掉外层衣物，污染面朝内卷起，放入塑料袋。",
    "用大量清水冲洗暴露皮肤和眼周，避免污染水流到干净部位。",
    "记录接触时间、症状、位置和风向。",
    "污染衣物不要带入睡眠区、厨房和饮水区。"
  ],
  "check": [
    "已远离源头。",
    "污染衣物隔离。",
    "皮肤已冲洗。",
    "污染区和清洁区分开。"
  ],
  "common_mistakes": [
    "靠近源头查看。",
    "点火测试气味。",
    "把污染衣物穿回室内。",
    "用少量水随便擦一擦。"
  ],
  "fallback": [
    "没有塑料袋时，把污染衣物放在室外下风处并标记，不与其他衣物混放。"
  ],
  "stop_or_escalate": [
    "呼吸困难、眼睛剧痛、皮肤灼痛、呕吐、意识异常。"
  ],
  "notes": "化学污染不靠勇敢处理，靠远离处理。",
