{
  "id": "DG-0488",
  "title": "灰烬和焦物处理",
  "category": "灾害应对与灾后恢复",
  "priority": "P0",
  "scenario": "火灾后有灰烬、焦木、烧焦塑料、炭块和熄灭物。",
  "goal": "安全处理残留物，避免复燃、吸入和污染。",
  "tools": [
    "手套",
    "口罩",
    "金属容器",
    "水或沙土",
    "标签"
  ],
  "steps": [
    "等待灰烬完全冷却，不用手试温。",
    "用金属容器收集灰烬和焦物。",
    "塑料、化学品、电子残骸和普通木灰分开。",
    "不把可疑灰烬撒到种植土或饮水附近。",
    "灰烬搬运时避免扬尘，必要时轻微湿润。",
    "处理后清洁手套和工具。",
    "记录灰烬来源和最终处理点。"
  ],
  "check": [
    "灰烬已冷却。",
    "塑料电子残骸分开。",
    "没有污染水源和种植区。"
  ],
  "common_mistakes": [
    "热灰倒进塑料桶。",
    "烧焦塑料灰拿去种菜。",
    "处理时扬尘吸入。"
  ],
  "fallback": [
    "没有金属容器时，用耐热硬容器临时收纳，确认完全冷却后再转移。"
  ],
  "stop_or_escalate": [
    "灰烬复燃、刺激性烟味、人员咳嗽眼痛时，立即停止处理。"
  ],
  "notes": "灰烬看起来安静，但里面可能还藏着火的余温。",
