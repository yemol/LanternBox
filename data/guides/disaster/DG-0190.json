  "steps": [
    "少做多餐，减少剩饭。",
    "出锅时间写在容器上。",
    "熟食尽量放在阴凉通风处，不放阳光下。",
    "肉、蛋、奶、海鲜、熟饭优先吃，不当长期储备。",
    "再次食用前彻底加热。",
    "有异味、黏滑、起泡、变色的食物放弃。"
  ],
  "check": [
    "剩饭有时间标签。",
    "易坏食物优先处理。",
    "可疑食物没有给儿童老人吃。"
  ],
  "common_mistakes": [
    "一大锅饭常温放一整天。",
    "用重口味掩盖变质。",
    "把新熟食倒进旧剩饭里。"
  ],
  "fallback": "没有标签时，用固定“当天吃完区”并写入日记。",
  "stop_or_escalate": [
    "多人腹泻、呕吐、食物异味明显时，停止食用同批食物。"
