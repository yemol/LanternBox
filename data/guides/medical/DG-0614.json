{
  "id": "DG-0614",
  "title": "扭伤后转移固定",
  "category": "医疗急救",
  "priority": "P0",
  "scenario": "成员扭伤后仍需要移动或转移，若硬撑行走可能加重损伤。",
  "goal": "先固定、减负和观察循环，再决定是否短距离转移。",
  "keywords": [
    "医疗",
    "医疗急救",
    "扭伤后转移固定",
    "长期断供",
    "小团队",
    "行动卡",
    "扭伤后转移固定",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "弹性绷带或布条",
    "木板或硬纸板",
    "冷敷物",
    "拐杖替代物",
    "记录纸"
  ],
  "steps": [
    "让伤者停止负重，询问扭伤时间、方向、疼痛位置和是否听到断裂声。",
    "检查远端皮肤颜色、温度、感觉和活动，和另一侧对比后记录。",
    "用布条或绷带从远端向近端轻度固定，保持脚趾或手指可见，避免勒紧。",
    "转移前给伤者减负，把背包交给他人，必要时两人搀扶或使用临时支撑。",
    "每半小时复查疼痛、肿胀、麻木和远端颜色，变差则停止移动。"
  ],
  "check": [
    "伤者已停止直接负重。",
    "远端感觉、颜色和温度已记录。",
    "固定后没有麻木、发冷或颜色变白。"
  ],
  "common_mistakes": [
    "忍痛继续赶路。",
    "包扎越紧越放心。",
    "只看肿胀，不检查远端循环。"
  ],
  "fallback": [
    "没有绷带时，用宽布条加衣物垫层固定，避免细绳直接勒压。",
    "必须移动时缩短距离，分段休息，并让伤者不背重物。"
  ],
  "stop_or_escalate": [
    "明显变形、无法负重、远端麻木发冷、疼痛快速加重或怀疑骨折时停止转移。",
    "若环境危险必须撤离，采用抬扶或拖曳替代，优先减少受伤部位受力。"
  ],
