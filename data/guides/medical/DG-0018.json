{
  "id": "DG-0018",
  "title": "失温：保温、干燥、缓慢复温",
  "category": "医疗急救与照护",
  "scenario": "寒冷、淋雨、长时间暴露后发抖、迟钝、皮肤冰冷。",
  "goal": "阻止继续失热，缓慢恢复核心体温。",
  "tools": [
    "干衣物",
    "毯子",
    "睡袋",
    "热水袋",
    "防风布"
  ],
  "steps": [
    "把人转移到避风、干燥处。",
    "脱掉湿衣物，换上干衣或用干布包裹。",
    "重点保暖躯干、头颈、腋下和腹股沟。",
    "清醒能吞咽时，可少量喝温热甜饮。",
    "用热水袋时包布，放在躯干附近，不直接烫皮肤。",
    "减少不必要活动，持续观察意识和发抖情况。"
  ],
  "check": [
    "湿衣已移除。",
    "身体被防风保暖层包住。",
    "意识没有继续变差。"
  ],
  "common_mistakes": [
    "用酒精取暖。",
    "剧烈搓揉冻伤部位。",
    "把人直接放到火边烤。",
    "给意识不清者喂水。"
  ],
  "fallback": "没有毯子时，用干衣物、纸板、塑料布、背包隔潮保温。",
  "stop_or_escalate": [
    "停止发抖但意识迟钝。",
    "无法行走。",
    "呼吸异常。",
    "严重冻伤。"
  ],
  "notes": "失温时停止发抖不是好事，可能是恶化。",
