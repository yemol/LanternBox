{
  "id": "DG-0507",
  "title": "低温后睡眠看护",
  "category": "医疗急救与照护",
  "scenario": "成员经历寒冷、淋雨、落水、长时间户外后进入睡眠。",
  "goal": "防止睡眠中失温恶化。",
  "tools": [
    "干衣",
    "毯子",
    "温水",
    "记录本"
  ],
  "steps": [
    "先换掉湿衣物，擦干身体。",
    "提供干袜、帽子、保暖层和隔冷垫。",
    "给少量温热饮品，清醒能吞咽才饮用。",
    "睡前记录精神、发抖、皮肤温度和说话状态。",
    "夜间安排照护者查看是否异常安静、发抖停止但意识变慢。",
    "不使用无人看守明火取暖。",
    "早晨记录恢复情况。"
  ],
  "check": [
    "湿衣已换。",
    "有隔冷层。",
    "夜间有人观察。"
  ],
  "common_mistakes": [
    "淋雨后直接睡。",
    "靠炭火睡觉。",
    "发抖停止就以为好了。"
  ],
  "fallback": "被褥不足时，优先给低温暴露者和重点成员。",
  "stop_or_escalate": [
    "意识变慢、说话含糊、呼吸异常、皮肤冰冷时，立即处理失温。"
  ],
  "notes": "低温后的睡眠不是休息，可能是危险的静音模式。",
