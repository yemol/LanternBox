{
  "id": "DG-0004",
  "title": "严重出血：加压包扎与休克观察",
  "category": "医疗急救与照护",
  "priority": "P0",
  "scenario": "直接压迫后仍持续出血，或伤者苍白、冷汗、虚弱。",
  "goal": "持续控血，同时防止伤者进入更严重的全身状态。",
  "tools": [
    "厚敷料",
    "绷带",
    "毛毯",
    "记录本",
    "手套"
  ],
  "steps": [
    "保持直接压迫，不要松手检查。",
    "在原敷料上继续加厚敷料，形成持续压力。",
    "用绷带从远端向近端缠绕固定，让敷料紧贴出血点。",
    "检查远端颜色、温度、感觉。麻木发紫说明太紧，需要调整。",
    "让伤者平卧休息，减少活动，盖毯保温。",
    "记录开始出血时间、包扎时间、敷料浸透速度、意识变化。"
  ],
  "check": [
    "出血速度下降。",
    "远端没有发紫发冷。",
    "伤者保持清醒或没有继续恶化。"
  ],
  "common_mistakes": [
    "为了看伤口反复拆包。",
    "让伤者站立或走动。",
    "只处理伤口，不管冷汗、苍白、虚弱。"
  ],
  "fallback": [
    "没有厚敷料时，用折叠毛巾、衣物、围巾叠厚加压。"
  ],
  "stop_or_escalate": [
    "敷料持续快速浸透。",
    "伤者意识变差。",
    "呼吸异常或极度虚弱。"
  ],
  "notes": "控血后仍要继续观察，严重出血不是包上就结束。",
