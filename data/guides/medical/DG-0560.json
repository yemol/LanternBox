{
  "id": "DG-0560",
  "title": "烧烫伤冷却与覆盖",
  "category": "医疗与照护",
  "priority": "P0",
  "scenario": "烧烫伤冷却与覆盖相关场景出现，外部支援不确定，需要立刻用本地资源处理。",
  "goal": "围绕医疗与照护降低继续热损伤风险，形成可记录、可复核的行动。",
  "tools": [
    "纸笔",
    "标签",
    "手电",
    "干净布"
  ],
  "steps": [
    "立即让伤处离开热源，脱离仍在发热的物品。",
    "用干净凉水持续冷却伤处，优先保证伤口降温。",
    "小心取下戒指、手表和紧身物，粘在皮肤上的衣物不要硬撕。",
    "冷却后用干净、不粘的覆盖物轻盖伤处。",
    "记录烫伤时间、部位、面积、水泡和疼痛变化。"
  ],
  "check": [
    "已离开热源。",
    "伤处已冷却。",
    "没有乱涂牙膏、油或粉末。"
  ],
  "common_mistakes": [
    "涂牙膏、酱油、油脂或草木灰。",
    "挑破水泡。",
    "把粘住的衣物硬撕下来。"
  ],
  "fallback": [
    "没有流动水时用干净凉水反复更换冷却，避免冰直接贴皮肤。"
  ],
  "stop_or_escalate": [
    "面积较大、面部会阴手脚、深色焦皮、吸入烟雾、儿童老人或疼痛异常时，升级求援。"
  ],
