{
  "id": "DG-0017",
  "title": "中暑：转移、降温、补液",
  "category": "医疗急救与照护",
  "priority": "P0",
  "scenario": "高温环境头晕、乏力、大量出汗、恶心、体温升高。",
  "goal": "尽快降温，防止热伤害加重。",
  "tools": [
    "阴凉处",
    "湿毛巾",
    "水",
    "补液盐",
    "扇子"
  ],
  "steps": [
    "立刻停止活动，转移到阴凉通风处。",
    "松开衣物，移除多余装备。",
    "用湿毛巾擦拭颈部、腋下、腹股沟等散热区域，同时扇风。",
    "清醒能吞咽时，少量多次补充安全水和电解质。",
    "记录症状开始时间、是否出汗、意识是否清楚。",
    "当天停止重体力活动。"
  ],
  "check": [
    "头晕恶心减轻。",
    "意识清楚。",
    "能少量多次喝水。"
  ],
  "common_mistakes": [
    "继续暴晒劳动。",
    "一次性猛灌水。",
    "给意识不清者喂水。"
  ],
  "fallback": [
    "没有补液盐时，先少量多次喝安全水，并尽快补充含盐食物。"
  ],
  "stop_or_escalate": [
    "意识混乱。",
    "抽搐。",
    "体温很高。",
    "停止出汗且皮肤灼热。"
  ],
  "notes": "重症中暑会危及生命。",
