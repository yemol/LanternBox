{
  "id": "DG-0611",
  "title": "儿童发热咳嗽观察卡",
  "category": "医疗急救",
  "priority": "P0",
  "scenario": "儿童出现发热和咳嗽，外部医疗不稳定，需要家庭先做观察、隔离和危险信号记录。",
  "goal": "把普通观察、照护支持和必须停止等待的危险信号区分开。",
  "keywords": [
    "医疗",
    "医疗急救",
    "儿童发热咳嗽观察卡",
    "长期断供",
    "小团队",
    "行动卡",
    "儿童发热咳嗽观察卡",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "体温计",
    "纸笔",
    "饮水杯",
    "口罩或布巾",
    "单独毛巾",
    "钟表"
  ],
  "steps": [
    "记录体温、咳嗽开始时间、精神状态、饮水量、尿量和是否接触过病人。",
    "让儿童在通风但不受冷风直吹的位置休息，餐具、毛巾和照护者手卫生单独管理。",
    "少量多次补水，观察能否正常说话、进食、入睡和回应呼唤。",
    "每四小时更新观察卡，写下体温变化、咳嗽变化和照护动作。",
    "照护者减少轮换人数，接触后清洁双手，避免把症状带入食物区。"
  ],
  "check": [
    "观察卡包含体温、精神、饮水和尿量。",
    "儿童用品已和其他成员分开。",
    "照护者知道危险信号。"
  ],
  "common_mistakes": [
    "只盯体温，不看精神和呼吸。",
    "多人轮流围观照护。",
    "没有记录时间，后来无法判断是否恶化。"
  ],
  "fallback": [
    "没有体温计时，固定同一照护者用触摸、精神状态、饮水和尿量做趋势记录。",
    "水量不足时优先保证患儿少量多次饮水。"
  ],
  "stop_or_escalate": [
    "出现呼吸困难、嘴唇发紫、持续嗜睡、抽搐、无法饮水、尿量明显减少或症状快速恶化时停止居家观察。",
    "若仍有安全通信或转移条件，优先寻求医疗帮助；没有外部条件时，进入高优先级照护和转移复核。"
  ],
