{
  "id": "DG-0613",
  "title": "鼻出血不仰头处理",
  "category": "医疗急救",
  "priority": "P0",
  "scenario": "成员鼻出血时常本能仰头，可能导致吞血、呛咳和误判出血量。",
  "goal": "用前倾压迫和时间记录控制鼻出血，并识别需要停止普通处理的情况。",
  "keywords": [
    "医疗",
    "医疗急救",
    "鼻出血不仰头处理",
    "长期断供",
    "小团队",
    "行动卡",
    "鼻出血不仰头处理",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "干净布或纸巾",
    "计时工具",
    "手套或替代隔离物",
    "垃圾袋",
    "记录纸"
  ],
  "steps": [
    "让伤者坐下、身体微前倾，提醒从口中吐出血液，不仰头躺下。",
    "用手指持续捏住鼻翼柔软部位，连续压迫十分钟，中途不要频繁松开查看。",
    "用干净布接血，观察出血量、颜色、是否伴随头部外伤或用药史。",
    "十分钟后仍出血，再连续压迫一次，并让伤者保持安静避免擤鼻。",
    "清理血污时戴隔离物，污染物密封丢弃，照护者洗手。"
  ],
  "check": [
    "伤者保持前倾，没有仰头。",
    "压迫时间已连续计时。",
    "污染物已密封处理。"
  ],
  "common_mistakes": [
    "仰头让血流进喉咙。",
    "每隔几十秒松手查看。",
    "用纸团深塞鼻腔后忘记取出。"
  ],
  "fallback": [
    "没有纸巾时用干净布外接血，不把脏布反复塞入鼻腔。",
    "计时工具不足时由旁人按固定短句或钟点记录开始和结束。"
  ],
  "stop_or_escalate": [
    "头部外伤后鼻出血、出血量大、两轮压迫仍不停、伤者头晕苍白或呼吸受影响时停止普通处理。",
    "反复鼻出血伴随发热、皮疹或异常瘀斑时列入医疗优先观察。"
  ],
