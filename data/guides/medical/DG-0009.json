{
  "id": "DG-0009",
  "title": "疑似骨折：固定不复位",
  "category": "医疗急救与照护",
  "scenario": "摔倒、撞击、重物砸伤后剧痛、肿胀、畸形、无法承重。",
  "goal": "防止断端移动造成二次伤害。",
  "tools": [
    "夹板/木板/硬纸板",
    "绷带或布条",
    "纱布",
    "毛毯",
    "记录本"
  ],
  "steps": [
    "让伤者停止活动，不要再尝试站立或使用受伤部位。",
    "如果有开放伤口，先用干净敷料覆盖。",
    "找硬物作为夹板，长度要能固定伤处上下两个关节。",
    "用布条固定夹板，固定点避开伤口和明显疼痛点。",
    "固定后检查远端颜色、温度、感觉和活动。",
    "保暖并记录受伤时间、固定时间、远端感觉。"
  ],
  "check": [
    "伤处不再晃动。",
    "远端手指脚趾颜色正常、有温度、有感觉。",
    "疼痛没有因固定明显加重。"
  ],
  "common_mistakes": [
    "强行复位。",
    "按摩揉搓。",
    "让伤者继续走。",
    "夹板太短只固定骨折点。"
  ],
  "fallback": "没有夹板时，用卷起杂志、硬纸板、雨伞、木棍、登山杖代替。",
  "stop_or_escalate": [
    "开放性骨折。",
    "远端麻木发紫。",
    "疼痛剧烈且加重。",
    "疑似脊柱或骨盆损伤。"
  ],
  "notes": "固定的目标是少动，不是把外形恢复漂亮。",
