{
  "id": "DG-0559",
  "title": "腹泻与脱水观察",
  "category": "医疗与照护",
  "priority": "P0",
  "scenario": "腹泻与脱水观察相关场景出现，外部支援不确定，需要立刻用本地资源处理。",
  "goal": "围绕医疗与照护降低脱水风险，形成可记录、可复核的行动。",
  "tools": [
    "纸笔",
    "标签",
    "手电",
    "干净布"
  ],
  "steps": [
    "停止食用可疑食物或水，同批次先隔离。",
    "少量多次补充干净水或合适补液，呕吐后等待片刻再少量喝。",
    "记录腹泻次数、呕吐次数、饮水量、尿量和精神状态。",
    "处理粪便、呕吐物或衣物后要洗手或替代清洁。",
    "病人餐具、毛巾和垃圾尽量单独放置。"
  ],
  "check": [
    "可疑食物水源已停止。",
    "补液少量多次。",
    "尿量和精神有记录。"
  ],
  "common_mistakes": [
    "腹泻时完全不让喝水。",
    "马上吃油腻或难消化食物。",
    "粪便污染物和食物混放。"
  ],
  "fallback": [
    "没有标准补液盐时，优先少量多次干净水和易消化食物，不乱配高浓度盐糖水。"
  ],
  "stop_or_escalate": [
    "血便、持续高热、明显脱水、尿很少、意识差、婴幼儿或老人腹泻加重时，升级求援。"
  ],
