{
  "id": "DG-0472",
  "title": "腹泻呕吐隔离流程",
  "category": "医疗急救与照护",
  "priority": "P0",
  "scenario": "成员腹泻、呕吐或疑似食物中毒，污染扩散风险高。",
  "goal": "控制粪便、呕吐物、餐具和手部传播。",
  "tools": [
    "手套",
    "口罩",
    "有盖桶",
    "清洁水",
    "记录本"
  ],
  "steps": [
    "给患者安排靠近厕所但远离厨房和饮水区的位置。",
    "患者使用单独餐具、水杯和毛巾。",
    "呕吐物和污染纸巾放入有盖容器或密封袋。",
    "照护者处理后必须洗手或更换手套。",
    "厕所或便盆使用后及时盖上并清理。",
    "患者食物以少量、清淡、易消化为主，不吃可疑剩食。",
    "记录次数、颜色、是否发热、是否能喝水和尿量。"
  ],
  "check": [
    "污染物有盖。",
    "照护后洗手。",
    "饮食和排便有记录。"
  ],
  "common_mistakes": [
    "呕吐物敞口放着。",
    "处理后直接摸水桶。",
    "腹泻还吃油腻剩饭。"
  ],
  "fallback": "没有专用厕所时，用固定便盆和清污工具，明确标记不可混用。",
  "stop_or_escalate": [
    "腹泻呕吐持续、无法饮水、尿量很少、意识变差或多人同发时，升级医疗观察。"
  ],
  "notes": "腹泻不是只看厕所次数，更要看水分有没有留住。",
