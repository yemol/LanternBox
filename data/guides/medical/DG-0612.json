{
  "id": "DG-0612",
  "title": "小伤口少水清洁卡",
  "category": "医疗急救",
  "priority": "P0",
  "scenario": "小伤口需要清洁，但干净水有限，不能为了彻底冲洗耗尽饮用水。",
  "goal": "用少量干净水完成关键清洁、覆盖和后续感染观察。",
  "keywords": [
    "医疗",
    "医疗急救",
    "小伤口少水清洁卡",
    "长期断供",
    "小团队",
    "行动卡",
    "小伤口少水清洁卡",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "少量干净水",
    "肥皂",
    "干净布或纱布",
    "胶带或布条",
    "镊子",
    "记录纸"
  ],
  "steps": [
    "先让伤者坐稳，照护者清洁双手，确认伤口是否有大量出血、深刺入物或动物咬伤。",
    "用少量干净水从伤口中心向外轻冲可见污物，周边皮肤可用湿布擦净。",
    "不要把脏布、灰水或不明药粉塞进伤口；能取出的表浅碎屑再用干净工具处理。",
    "用干净覆盖物轻盖伤口，固定但不勒紧，写下受伤时间和污染来源。",
    "每天查看红肿、热痛、渗液、发热或活动受限，覆盖物潮湿污染时更换。"
  ],
  "check": [
    "伤口已去除可见污物并覆盖。",
    "饮用水消耗量已控制。",
    "感染观察时间已记录。"
  ],
  "common_mistakes": [
    "用大量饮用水反复冲到储备下降。",
    "用酒、泥土、草药粉等刺激物处理伤口。",
    "包扎过紧导致末端发冷或麻木。"
  ],
  "fallback": [
    "干净水极少时，优先冲洗明显污染和伤口入口，周边用湿布分区擦拭。",
    "没有纱布时，用煮沸晾干或熨烫过的干净布替代。"
  ],
  "stop_or_escalate": [
    "大量出血、深部异物、动物咬伤、关节附近深伤或感染迹象扩大时停止普通处理。",
    "伤者出现发热、红线向上延伸或疼痛迅速加重时，进入医疗求助或转移决策。"
  ],
