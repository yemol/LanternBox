{
  "id": "DG-0005",
  "title": "小伤口清洁与覆盖",
  "category": "医疗急救与照护",
  "priority": "P0",
  "scenario": "浅表割伤、擦伤、泥沙污染的小伤口。",
  "goal": "清掉污染物，降低感染风险，让伤口有干净保护层。",
  "tools": [
    "安全清水",
    "肥皂",
    "纱布",
    "创可贴",
    "镊子",
    "手套"
  ],
  "steps": [
    "洗手或戴手套。",
    "用安全清水冲洗伤口，把泥沙、灰尘、碎屑冲掉。",
    "伤口周围皮肤可用肥皂清洗，但不要把刺激性清洁剂灌进深伤口。",
    "可见的表浅小异物可用清洁镊子取出；看不见或很深的异物不要硬挖。",
    "用干净纱布轻轻擦干周围皮肤。",
    "覆盖创可贴或纱布，保持干净。每天检查和更换。"
  ],
  "check": [
    "伤口表面没有明显泥沙。",
    "敷料干净且固定。",
    "疼痛、红肿没有持续加重。"
  ],
  "common_mistakes": [
    "用干布暴力擦伤口。",
    "把酒精、强消毒剂倒进深伤口。",
    "裸露伤口继续干活。"
  ],
  "fallback": "没有创可贴时，用干净布片和胶带临时覆盖。",
  "stop_or_escalate": [
    "红肿扩大。",
    "伤口发热、流脓、疼痛加重。",
    "异物深嵌无法取出。"
  ],
  "notes": "小伤口在脏环境里也会变成大麻烦。",
