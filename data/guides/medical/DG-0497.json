{
  "id": "DG-0497",
  "title": "简易担架制作",
  "category": "医疗急救与照护",
  "scenario": "成员无法自行行走，需要短距离转移。",
  "goal": "用现有材料制作低风险临时担架。",
  "tools": [
    "结实布料",
    "两根杆",
    "绳子",
    "手套"
  ],
  "steps": [
    "先评估伤员是否适合搬动，疑似脊柱伤谨慎。",
    "选择结实床单、毯子或外套作为承托面。",
    "两侧穿入木棍、杆子或结实管材。",
    "边缘用绳子固定，防止滑脱。",
    "搬运前空载测试承重。",
    "至少两到四人配合，统一口令。",
    "搬运后检查伤员疼痛和意识变化。"
  ],
  "check": [
    "材料承重测试过。",
    "搬运有统一口令。",
    "伤员状态有复查。"
  ],
  "common_mistakes": [
    "没测试就抬人。",
    "一人拖着走。",
    "疑似脊柱伤随意弯折。"
  ],
  "fallback": "没有杆时，用毯子拖行只适合极短距离和低风险地面。",
  "stop_or_escalate": [
    "伤员剧痛、麻木、呼吸困难、意识变化时，停止非必要搬动。"
  ],
  "notes": "担架不是布加棍子那么简单，真正的关键是稳和同步。",
