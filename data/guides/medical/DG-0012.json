{
  "id": "DG-0012",
  "title": "异物入眼：冲洗不揉",
  "category": "医疗急救与照护",
  "priority": "P0",
  "scenario": "灰尘、沙粒、小虫、烟尘进入眼睛。",
  "goal": "把刺激物冲出，避免揉伤角膜。",
  "tools": [
    "安全清水或生理盐水",
    "干净杯",
    "纱布",
    "手电"
  ],
  "steps": [
    "立刻停止揉眼。",
    "让患者轻轻眨眼，观察异物是否能随泪液出来。",
    "用安全清水或生理盐水从内眼角向外冲洗。",
    "如果异物在下眼睑内，可轻轻翻开下眼睑冲洗。",
    "冲洗后用干净纱布轻遮，减少继续刺激。",
    "记录是否仍有刺痛、流泪、视物模糊。"
  ],
  "check": [
    "异物感减轻。",
    "视力没有下降。",
    "眼睛没有持续剧痛。"
  ],
  "common_mistakes": [
    "用棉签、针、刀尖挑眼。",
    "揉眼。",
    "拔出扎入眼球的异物。"
  ],
  "fallback": [
    "没有生理盐水时，用煮沸冷却后的安全水。"
  ],
  "stop_or_escalate": [
    "异物扎入眼球。",
    "视力下降。",
    "剧痛持续。",
    "化学品入眼。"
  ],
  "notes": "化学品入眼需要更长时间持续冲洗。",
