  "steps": [
    "先清空楼梯杂物和湿滑点。",
    "安排最有力者在下方承担主要重量。",
    "指定一人喊口令，所有人按口令移动。",
    "每几级停一次确认状态。",
    "不要在楼梯上临时换手或争论。",
    "伤员头部和脚部方向提前确定。",
    "到达后记录搬运过程异常。"
  ],
  "check": [
    "楼梯清空。",
    "有统一口令。",
    "下方有人承重。"
  ],
  "common_mistakes": [
    "多人各喊各的。",
    "楼梯上换人。",
    "照明不足还硬搬。"
  ],
  "fallback": "人手不足时，分段移动，宁慢勿急。",
  "stop_or_escalate": [
    "楼梯破损、人员体力不足、伤员状态恶化时，停止搬运。"
