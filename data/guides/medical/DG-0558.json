{
  "id": "DG-0558",
  "title": "发热观察、补水和记录",
  "category": "医疗与照护",
  "priority": "P0",
  "scenario": "发热观察、补水和记录相关场景出现，外部支援不确定，需要立刻用本地资源处理。",
  "goal": "围绕医疗与照护降低脱水和病情加重风险，形成可记录、可复核的行动。",
  "tools": [
    "纸笔",
    "标签",
    "手电",
    "干净布"
  ],
  "steps": [
    "测量体温并记录时间，不只凭手摸判断。",
    "让发热者休息，少量多次饮水，观察尿量和精神状态。",
    "衣物和被子以舒适为准，不捂汗，不强行冷水刺激。",
    "每 4 小时记录体温、饮水、尿量、咳嗽、腹泻、皮疹和疼痛。",
    "发热者餐具和毛巾尽量分开，照护后清洁双手。"
  ],
  "check": [
    "体温和时间已记录。",
    "饮水和尿量有观察。",
    "伴随症状已写下。"
  ],
  "common_mistakes": [
    "一发热就捂厚被逼出汗。",
    "只记录最高温，不记录精神和饮水。",
    "多人共用杯子毛巾。"
  ],
  "fallback": [
    "没有体温计时记录冷热感、出汗、精神、尿量和呼吸变化。"
  ],
  "stop_or_escalate": [
    "意识不清、呼吸困难、持续抽搐、不能饮水、婴幼儿高热、皮疹伴精神差或发热持续加重时，优先求援。"
  ],
