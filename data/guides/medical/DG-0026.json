{
  "id": "DG-0026",
  "title": "烧伤感染判断",
  "category": "医疗急救与照护",
  "priority": "P0",
  "scenario": "烧伤后数天内，创面需要持续护理。",
  "goal": "发现感染和护理失败信号。",
  "tools": [
    "纱布",
    "安全水",
    "记录本",
    "体温计"
  ],
  "steps": [
    "每天固定时间观察烧伤区域。",
    "记录红肿边界、疼痛、渗液、气味和体温。",
    "敷料潮湿、脏污或粘住时，先用干净水湿润再慢慢处理。",
    "水泡完整时保护，不主动刺破。",
    "水泡破裂后按开放伤口护理，保持干净覆盖。",
    "避免创面接触污水、灰尘、动物和脏衣物。"
  ],
  "check": [
    "红肿没有扩大。",
    "渗液没有变多变臭。",
    "疼痛趋势下降。"
  ],
  "common_mistakes": [
    "刺破水泡。",
    "涂不明油膏。",
    "硬撕粘住敷料。",
    "让创面接触脏水。"
  ],
  "fallback": "没有纱布时，用煮沸晾干后的干净布临时覆盖。",
  "stop_or_escalate": [
    "发热。",
    "红肿扩大。",
    "渗液有异味。",
    "疼痛突然加重。"
  ],
  "notes": "烧伤感染常发生在后续几天，不是当天冷却完就结束。",
