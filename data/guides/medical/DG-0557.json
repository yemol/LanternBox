{
  "id": "DG-0557",
  "title": "小伤口清洁与覆盖",
  "category": "医疗与照护",
  "priority": "P0",
  "scenario": "小伤口清洁与覆盖相关场景出现，外部支援不确定，需要立刻用本地资源处理。",
  "goal": "围绕医疗与照护降低感染风险，形成可记录、可复核的行动。",
  "tools": [
    "纸笔",
    "标签",
    "手电",
    "干净布"
  ],
  "steps": [
    "处理前先洗手或做替代清洁。",
    "用干净水冲掉可见泥沙和污物，不用力抠深处组织。",
    "伤口周围可用肥皂清洁，但不要把刺激性清洁剂倒进伤口深处。",
    "用干净敷料覆盖，保持干燥，湿了或脏了及时更换。",
    "每天观察红肿、热痛、流脓、红线和发热。"
  ],
  "check": [
    "可见污物已清除。",
    "伤口已覆盖。",
    "感染信号有记录。"
  ],
  "common_mistakes": [
    "用酒精反复灌洗深伤口。",
    "把草药、泥土或粉末撒进伤口。",
    "敷料湿脏后继续使用。"
  ],
  "fallback": [
    "干净水不足时优先清洁伤口和手，其他清洁用水降级。"
  ],
  "stop_or_escalate": [
    "伤口越来越红肿热痛、流脓、出现红线、发热或功能受限时，升级处理。"
  ],
