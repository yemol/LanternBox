{
  "id": "DG-0019",
  "title": "冻伤：保护不揉搓",
  "category": "医疗急救与照护",
  "priority": "P0",
  "scenario": "手指、脚趾、耳朵、鼻尖苍白、麻木、冰冷。",
  "goal": "保护组织，避免复温后再次冻结。",
  "tools": [
    "温水",
    "干袜子",
    "手套",
    "纱布",
    "保温层"
  ],
  "steps": [
    "转移到温暖避风处。",
    "取下戒指、湿袜、紧手套等会限制肿胀的物品。",
    "如果能保证不会再次冻结，用温水缓慢复温。",
    "复温后轻轻擦干，覆盖干净纱布，手指脚趾之间可用纱布隔开。",
    "保持保暖，不要再暴露在寒冷中。",
    "记录颜色、感觉、水泡和疼痛变化。"
  ],
  "check": [
    "麻木没有继续扩大。",
    "复温后保持干燥保暖。",
    "没有再次暴露在低温中。"
  ],
  "common_mistakes": [
    "揉搓冻伤部位。",
    "用火直接烤。",
    "在可能再次冻结前复温。",
    "刺破水泡。"
  ],
  "fallback": [
    "没有温水时，用身体温度保护，例如把手放在腋下，但不要摩擦。"
  ],
  "stop_or_escalate": [
    "皮肤变黑。",
    "大水泡。",
    "持续无感觉。",
    "冻伤范围扩大。"
  ],
  "notes": "冻伤处理宁可慢，也不要粗暴。",
