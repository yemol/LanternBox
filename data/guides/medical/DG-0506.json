{
  "id": "DG-0506",
  "title": "中暑后恢复观察",
  "category": "医疗急救与照护",
  "priority": "P0",
  "scenario": "高温任务后头晕、恶心、乏力、大汗或皮肤灼热。",
  "goal": "降温后继续观察，防止复发。",
  "tools": [
    "阴凉处",
    "湿布",
    "水",
    "记录本"
  ],
  "steps": [
    "立即停止高温任务，转入阴凉通风处。",
    "松开衣物，用湿布擦颈部、腋下和腹股沟。",
    "能清醒吞咽时少量多次饮水。",
    "记录意识、出汗、体温感、尿量和头晕。",
    "当天不再安排重体力和暴晒任务。",
    "夜间继续观察是否头痛、恶心或意识异常。",
    "第二天根据恢复情况逐步恢复任务。"
  ],
  "check": [
    "已停止任务。",
    "少量多次补水。",
    "当天任务调整。"
  ],
  "common_mistakes": [
    "凉一会儿马上继续干。",
    "意识不清还灌水。",
    "不记录复发。"
  ],
  "fallback": [
    "水少时优先湿敷关键部位并加强通风。"
  ],
  "stop_or_escalate": [
    "意识混乱、抽搐、停止出汗、无法饮水时，立即紧急处理。"
  ],
  "notes": "中暑不是充电五分钟就满血，恢复也要排班。",
