  "tools": [
    "故障标签",
    "纸笔",
    "零件盒",
    "手电",
    "断能工具"
  ],
  "steps": [
    "每次尝试只改变一个条件并记录结果。",
    "第三次失败后切断电源、压力、燃料或负载。",
    "把拆下零件按顺序收纳并标出缺失或破损处。",
    "贴上停用标签，记录三次现象和恢复条件。"
  ],
  "check": [
    "设备与能量源已分离。",
    "零件和紧固件数量可核对。",
    "停用标签写明故障、时间和责任人。"
  ],
  "common_mistakes": [
    "重复同一动作期待偶然恢复。",
    "带电或带压继续拆。",
    "从其他关键设备拆件试错。"
  ],
  "fallback": [
    "无法维修时把任务转为手工流程或备用设备。",
    "缺标签时用绳结封住开关并在值守记录中注明。"
  ],
  "stop_or_escalate": [
    "出现发热、火花、异味、裂纹、泄漏或工具打滑时立即停止。",
    "无法确认能量已隔离或超出工具能力时不得继续。"
  ],
