    "物资清单",
    "背包",
    "试重工具",
    "标记",
    "路线记录"
  ],
  "steps": [
    "停在可回撤位置，先保留个人水、药、保温、照明和导航。",
    "移除重复、沉重低效和可就地替代物。",
    "把共用关键物资分给两名以上成员。",
    "全员试走两分钟，再按最慢者状态二次减重。"
  ],
  "check": [
    "最慢成员能抬头观察并保持队距。",
    "双手可用于平衡，背包不偏斜。",
    "关键物资没有集中在一人。"
  ],
  "common_mistakes": [
    "只按体重平均，不看伤病和路况。",
    "外挂散物造成绊挂。",
    "为保工具削减水药。"
  ],
  "fallback": [
    "无秤时以连续试走和能否独立起身判断。",
    "包具不足时将关键物装衣袋或布包，放弃低优先散件。"
  ],
  "stop_or_escalate": [
    "有人站立不稳、呼吸无法恢复、持续疼痛或队伍被拉开时停止移动并减重。",
    "路线需攀爬涉水时禁止手提散包。"
  ],
