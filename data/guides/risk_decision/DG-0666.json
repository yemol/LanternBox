  "steps": [
    "出发前写下折返时间、返程水量和最远地标。",
    "每到岔路记录来向并检查剩余光线和水。",
    "只搜索路线两侧可快速检查的位置。",
    "任一停止线到达时按原路线返回，不追加目标。"
  ],
  "check": [
    "记录有明确折返时间和返程水量。",
    "当前位置能指出上一标记和回撤方向。",
    "返回时仍有照明或日光余量。"
  ],
  "common_mistakes": [
    "因已经走很远而继续。",
    "发现新线索后取消折返时间。",
    "把返程水用于继续搜索。"
  ],
  "fallback": [
    "无地图时记录地标顺序和行走时间。",
    "无人留守时只搜索营地可见范围。"
  ],
  "stop_or_escalate": [
    "路线无法回撤、标记丢失、返程水量触线、人员受伤或光线不足时停止搜索。",
    "无法确认地形稳定或污染来源时不进入。"
  ],
