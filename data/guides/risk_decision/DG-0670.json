  "tools": [
    "人员表",
    "地图",
    "计时工具",
    "通信约定",
    "值守记录"
  ],
  "steps": [
    "指定一名留守主责和一名可接替者。",
    "记录外出人员、路线、任务、最晚返回时间和信号。",
    "点交营地水、火源、伤病者和关键物资状态。",
    "由留守者复述逾时检查顺序，双方签记后出发。"
  ],
  "check": [
    "营地始终至少一名清醒留守者。",
    "留守者能指出路线和最晚返回时间。",
    "交接记录包含火源、伤病和库存异常。"
  ],
  "common_mistakes": [
    "留守者临时外出找人。",
    "只记目的地不记路线。",
    "换班时口头交接不留时间。"
  ],
  "fallback": [
    "人手不足时取消远距离分组，改为视听范围内行动。",
    "无地图时写地标顺序和预计耗时。"
  ],
  "stop_or_escalate": [
    "无人能持续留守、外出组不能复述路线或营地存在未控火源时停止分组。",
    "超过返回时间且无约定信号时，留守者不得单独追出。"
  ],
