    "降级处理"
  ],
  "tools": [
    "隔离容器",
    "标签",
    "手电",
    "食物记录",
    "手套"
  ],
  "steps": [
    "核对来源、开封时间和储存温度记录。",
    "不入口观察包装鼓胀、渗漏、霉斑、虫害和异常气味。",
    "任一证据异常即封装并标记不可食用。",
    "检查同批食物并记录受影响数量。"
  ],
  "check": [
    "可食用批次的来源和开封时间可追溯。",
    "可疑食物与餐具、饮水和其他食物分开。",
    "无人通过尝味判断安全。"
  ],
  "common_mistakes": [
    "切掉霉变部分继续吃。",
    "加热掩盖腐败气味。",
    "因食物短缺降低放弃标准。"
  ],
  "fallback": [
    "记录缺失时按可疑处理，改用有封装或可追溯食物。",
    "食物不足时缩小份量并优先安全食物，不混入可疑批次。"
  ],
  "stop_or_escalate": [
    "包装鼓胀渗漏、明显霉变、腐败味、食后多人不适或来源无法确认时停止食用。",
    "疑似化学污染或洪水浸泡时整批隔离。"
  ],
