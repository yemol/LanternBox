  "tools": [
    "路线纸条",
    "备用点清单",
    "粉笔或布条",
    "计时工具",
    "口令"
  ],
  "steps": [
    "出发前确认主集合点和两个备用点的顺序、等待时长和撤离方向。",
    "发现主点失效时，不在原地聚集讨论，先移动到预设观察位置。",
    "由两人确认失效原因，其他成员保持安静等待指令。",
    "启用备用点时留下约定标记，但不写完整人数、去向和库存信息。",
    "到达备用点后清点人员和物资，记录谁未到、最后出现位置和下一步等待时限。"
  ],
  "check": [
    "备用点顺序和等待时间已明确。",
    "原集合点没有留下敏感信息。",
    "到达备用点后已清点人员。"
  ],
  "common_mistakes": [
    "在失效集合点长时间等待。",
    "临时决定新地点导致成员找不到。",
    "标记透露完整路线。"
  ],
  "fallback": [
    "标记工具不足时，用预先约定的自然物位置或短口令替代。",
    "备用点也不可用时，按路线上的下一个安全观察点移动。"
  ],
  "stop_or_escalate": [
    "发现跟踪、围堵或备用点连续失效时，停止集合等待并进入分散撤离规则。",
    "成员失联超过约定时限时，不派单人返回寻找。"
  ],
