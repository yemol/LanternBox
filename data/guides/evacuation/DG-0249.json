{
  "id": "DG-0249",
  "title": "重物分批搬运",
  "category": "撤离交通与路线",
  "priority": "P0",
  "scenario": "需要搬运水、粮食、工具、燃料、设备、药品、书籍或箱子。",
  "goal": "避免一次搬太多导致受伤、摔倒和物资损坏。",
  "tools": [
    "背包",
    "箱子",
    "绳子",
    "标签纸",
    "任务表"
  ],
  "steps": [
    "先把物资按优先级分成必须带、可第二批带、可放弃。",
    "单件重物尽量拆分成多个小包。",
    "每包写编号、内容和目的地。",
    "重物靠近身体或背部，不用手臂远距离悬提。",
    "楼梯和湿滑路段降低重量，宁可多跑一趟。",
    "每批搬完后清点数量和人员状态。",
    "搬运结束后记录哪些物资已到位，哪些还留在原处。"
  ],
  "check": [
    "物资分批清楚。",
    "单人负重不过量。",
    "每批搬完有清点。"
  ],
  "common_mistakes": [
    "为了省时间一次搬到极限。",
    "重箱挡住视线走楼梯。",
    "搬完不更新库存位置。"
  ],
  "fallback": "没有背包时，用床单、布袋、纸箱和绳子分装，但至少留一只手保持平衡。",
  "stop_or_escalate": [
    "有人腰背疼痛、手麻、摔倒、视线被挡、路线变危险时，立即减重。"
  ],
  "notes": "搬运不是力量表演，是把东西安全送到下一个点。",
