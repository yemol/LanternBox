  "steps": [
    "出发前检查胎压、刹车、链条和车把。",
    "检查轮胎是否扎入玻璃、钉子和裂纹。",
    "刹车捏下后能有效减速。",
    "链条太干或掉链先处理。",
    "货物不要挂到影响车轮和刹车。",
    "返回后擦掉泥水并记录异常。",
    "每周检查螺丝松动和轮圈偏摆。"
  ],
  "check": [
    "胎压正常。",
    "刹车有效。",
    "货物不干扰车轮。"
  ],
