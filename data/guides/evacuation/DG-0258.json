  "steps": [
    "车内准备独立应急包，不完全依赖家中库存。",
    "包内至少有水、少量食物、手电、急救用品、保暖毯、口罩、手套。",
    "加入纸质地图、联络卡、备用充电线和简单工具。",
    "药品和易受热物品不要长期放在高温车内。",
    "每月检查水、食物、电池和工具状态。",
    "车辆换人使用时说明应急包位置。",
    "不要把车内应急包当日常杂物包。"
  ],
  "check": [
    "应急包位置固定。",
    "基础物资齐全。",
    "高温敏感物没有长期闷车。"
  ],
