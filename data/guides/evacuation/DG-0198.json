{
  "id": "DG-0198",
  "title": "纸质地图标注",
  "category": "撤离交通与路线",
  "priority": "P2",
  "scenario": "断网或手机没电时，需要保留路线、集合点、水源、危险区和仓库信息。",
  "goal": "让纸质地图成为离线导航核心。",
  "tools": [
    "纸质地图",
    "笔",
    "透明袋",
    "尺子",
    "贴纸"
  ],
  "steps": [
    "标出当前住所、主集合点、备用集合点。",
    "标出水源、医疗点、工具点、燃料点和可避雨点。",
    "标出危险区：低洼、废墟、冲突点、污染点、断桥、易积水路段。",
    "用不同符号区分资源、危险、路线和禁入区。",
    "地图放防水袋，另存一份备份地图。",
    "每次路线变化或发现新风险后更新地图日期。"
  ],
  "check": [
    "地图有日期。",
    "资源点和危险点不同符号。",
    "至少一名成员能读懂地图。"
  ],
  "common_mistakes": [
    "只依赖手机地图。",
    "地图不更新。",
    "符号只有绘制者自己懂。"
  ],
  "fallback": "没有正式地图时，手绘简图也可以，重点是方向、路口、集合点和危险点。",
  "stop_or_escalate": [
    "路线被水、火、坍塌、冲突切断时，立即更新地图。"
  ],
  "notes": "纸质地图是断电后的地面记忆。",
