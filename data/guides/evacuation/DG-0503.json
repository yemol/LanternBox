{
  "id": "DG-0503",
  "title": "留言点安全规则",
  "category": "撤离交通与路线",
  "scenario": "失联或分散时需要留下信息。",
  "goal": "留下足够信息但不暴露核心位置和库存。",
  "tools": [
    "纸条",
    "防水袋",
    "笔",
    "约定符号"
  ],
  "steps": [
    "留言只写时间、方向、下一步和安全代号。",
    "不写完整仓库、成员档案和物资位置。",
    "留言放在约定隐蔽但可找到的位置。",
    "使用约定符号表示安全、危险、已转移。",
    "留言写日期和留名编号。",
    "过期留言由返回人员回收。",
    "发现留言被翻动时更换留言点。"
  ],
  "check": [
    "留言有时间。",
    "没有暴露敏感位置。",
    "符号含义统一。"
  ],
  "common_mistakes": [
    "留言写满全部计划。",
    "放在人人可见处。",
    "过期留言不清理。"
  ],
  "fallback": "没有纸时，用约定符号和方向标记替代。",
  "stop_or_escalate": [
    "留言点被外人发现、符号被误读、路线变化时，立即更新规则。"
  ],
  "notes": "留言是给自己人看的，不能顺手写成公告。",
