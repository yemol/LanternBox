{
  "id": "DG-0626",
  "title": "桶厕满袋封存和更换",
  "category": "卫生",
  "priority": "P0",
  "scenario": "桶厕或临时排泄袋接近满载，需要封存更换，避免外溢污染居住区。",
  "goal": "安全封存满袋并恢复厕所可用，同时保护水源、食物和手卫生流程。",
  "keywords": [
    "卫生",
    "卫生",
    "桶厕满袋封存和更换",
    "长期断供",
    "小团队",
    "行动卡",
    "桶厕满袋封存和更换",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "垃圾袋",
    "扎带或绳子",
    "灰土或吸附材料",
    "手套替代物",
    "标签",
    "清洁水"
  ],
  "steps": [
    "先暂停使用桶厕，提醒成员改用备用容器或等待更换完成。",
    "在袋内表面撒灰土或吸附材料，降低液体晃动和气味扩散。",
    "双层封袋，先排出多余空气再扎紧外袋，外壁污染处用湿布定向擦拭。",
    "把封存袋移到远离水源、食物和睡眠区的位置，标记日期和内容。",
    "更换新袋后清洁接触点，照护者完成手卫生再接触门把、水桶和餐具。"
  ],
  "check": [
    "满袋已双层封存。",
    "临时存放点远离水食物。",
    "更换者完成手卫生。"
  ],
  "common_mistakes": [
    "等到外溢才更换。",
    "封袋后放在入口或水桶旁。",
    "更换后直接去做饭。"
  ],
  "fallback": [
    "没有双层袋时，先减少液体晃动并用桶或箱临时二次容纳。",
    "吸附材料不足时，优先防止外溢和标记，不移动过远距离。"
  ],
  "stop_or_escalate": [
    "袋体破裂、液体外漏或多人腹泻导致桶厕超负荷时，暂停该厕所并设置新点位。",
    "污染接触到饮用水区时，立即停止该水区入口用途。"
  ],
