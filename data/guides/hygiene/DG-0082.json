{
  "id": "DG-0082",
  "title": "呕吐物和腹泻污染清理",
  "category": "居住卫生与空间管理",
  "priority": "P0",
  "scenario": "有人呕吐、腹泻污染地面、厕所、床铺、衣物或餐具。",
  "goal": "快速隔离污染，减少病原传播。",
  "tools": [
    "手套或塑料袋",
    "口罩",
    "纸巾或旧布",
    "垃圾袋",
    "消毒液",
    "肥皂"
  ],
  "steps": [
    "先让无关人员离开，儿童和宠物不要靠近。",
    "照护者戴手套和口罩，没有手套时用塑料袋套手。",
    "用纸巾或旧布覆盖并吸收污染物，从外向内收集，放入垃圾袋。",
    "先清洁可见污物，再按消毒剂说明消毒污染区域和门把手、厕所按钮等高接触面。",
    "污染衣物单独装袋，能洗则单独洗，不能立刻洗就密封标记。",
    "处理结束后丢弃手套或清洗替代手套，认真洗手。",
    "记录患者、时间、地点，追踪是否还有其他人发病。"
  ],
  "check": [
    "污染区已清理并消毒。",
    "污染垃圾已密封。",
    "照护者处理后洗手。",
    "患者用品已隔离。"
  ],
  "common_mistakes": [
    "只用拖把拖开污染物。",
    "清理完不消毒高接触面。",
    "污染衣物和普通衣物混洗。",
    "徒手处理呕吐物。"
  ],
  "fallback": [
    "没有消毒液时，至少先用肥皂水彻底清洁可见污物，再隔离区域并加强洗手。"
  ],
  "stop_or_escalate": [
    "多人连续呕吐腹泻。",
    "患者脱水、血便、高热或意识变差。"
  ],
  "notes": "美国疾病控制与预防中心 对呕吐或腹泻污染区域建议立即清洁并消毒，先清污再消毒，别跳步骤。",
