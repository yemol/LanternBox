{
  "id": "DG-0172",
  "title": "睡眠区搭建",
  "category": "居住卫生与空间管理",
  "priority": "P0",
  "scenario": "需要在临时环境中连续睡觉，包括停电家中、避难点、车库、帐篷或办公室。",
  "goal": "建立能恢复体力、减少受凉和摔倒的睡眠区。",
  "tools": [
    "垫子",
    "毯子",
    "纸板",
    "低亮灯",
    "收纳袋"
  ],
  "steps": [
    "选择远离窗户、高柜、吊灯、漏水点和通道的位置。",
    "地面先铺纸板、垫子、衣物或防潮层，避免直接睡冷地面。",
    "每个人固定睡眠位置，儿童、老人、病人靠近照护者。",
    "床边放鞋、低亮灯、水和个人药品。",
    "睡前清理脚边工具、绳子、水桶和尖锐物。",
    "每天通风和晾晒被褥，潮湿后及时处理。"
  ],
  "check": [
    "睡眠点不靠危险物。",
    "脚边通道清空。",
    "个人鞋灯水药能摸到。"
  ],
  "common_mistakes": [
    "睡在窗边和高柜旁。",
    "鞋放太远，夜间赤脚走。",
    "睡眠区堆满杂物。"
  ],
  "fallback": "没有垫子时，用纸板、衣物、背包和塑料布分层隔冷隔潮。",
  "stop_or_escalate": [
    "漏水、霉味、虫害、余震坠物风险、夜间跌倒时，立即调整睡眠区。"
  ],
  "notes": "睡眠不是休闲，是长期生存的维修时间。",
