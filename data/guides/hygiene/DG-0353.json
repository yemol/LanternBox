{
  "id": "DG-0353",
  "title": "人体气味和清洁节奏",
  "category": "居住卫生与空间管理",
  "priority": "P0",
  "scenario": "长期缺水、拥挤、炎热、无法洗澡，体味、汗味和衣物味道积累。",
  "goal": "用低水量方式维持基本清洁，减少皮肤问题和气味暴露。",
  "tools": [
    "湿布",
    "小盆",
    "干净衣物",
    "晾晒绳",
    "肥皂少量"
  ],
  "steps": [
    "优先清洁腋下、腹股沟、脚、手、脸和伤口周围。",
    "使用湿布擦洗，不需要每次大量洗澡。",
    "汗湿衣物及时晾干或更换，不堆在睡眠区。",
    "每个人固定毛巾或擦洗布，不混用。",
    "脚部每天检查并保持干燥。",
    "清洁用水和饮水分开管理。",
    "炎热或多人同住时增加擦洗频率。"
  ],
  "check": [
    "重点部位有清洁。",
    "毛巾不混用。",
    "湿衣物不堆睡眠区。"
  ],
  "common_mistakes": [
    "缺水就完全不清洁。",
    "多人共用一条湿毛巾。",
    "湿衣服闷包里。"
  ],
  "fallback": "水极少时，先用干布擦汗，再用少量湿布处理重点部位。",
  "stop_or_escalate": [
    "皮肤破溃、瘙痒严重、异味伴随感染、脚部糜烂时，进入医疗观察。"
  ],
  "notes": "清洁不是体面问题，是皮肤防线维护。",
