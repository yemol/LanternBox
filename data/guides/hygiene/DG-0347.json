{
  "id": "DG-0347",
  "title": "工具噪声控制",
  "category": "居住卫生与空间管理",
  "scenario": "维修、拆解、敲击、锯切、整理金属和木板时会产生明显噪声。",
  "goal": "在必要维修中降低噪声和风险。",
  "tools": [
    "布垫",
    "手套",
    "工具箱",
    "任务表"
  ],
  "steps": [
    "先判断维修是否必须现在做，非紧急高噪任务尽量安排白天。",
    "敲击、拆卸前在下方垫布或纸板，减少金属碰撞声。",
    "小零件放入布垫或盒子，不让螺丝滚落地面。",
    "锯切、敲打前通知附近成员，避免误判为外部危险。",
    "每次只拿出需要的工具，其他工具留在箱内。",
    "高噪维修设置时间段，不连续长时间制造噪声。",
    "维修后清点金属碎片和尖锐物。"
  ],
  "check": [
    "高噪任务有时间安排。",
    "工具没有散落碰撞。",
    "维修前通知过成员。"
  ],
  "common_mistakes": [
    "半夜敲钉子。",
    "工具倒在地上哗啦响。",
    "螺丝散落找不到。"
  ],
  "fallback": "必须夜间维修时，用布垫、低声口令和最少工具完成。",
  "stop_or_escalate": [
    "噪声引来外部关注、成员恐慌、维修对象涉及电火燃气时，暂停任务。"
  ],
  "notes": "修东西时，声音也是成本。",
