{
  "id": "DG-0630",
  "title": "少水餐具清洁顺序",
  "category": "卫生",
  "priority": "P0",
  "scenario": "清洁餐具的水很少，需要安排顺序，避免把最脏餐具污染所有水。",
  "goal": "用少水流程完成餐具分级清洁，并保护饮用水储备。",
  "keywords": [
    "卫生",
    "卫生",
    "少水餐具清洁顺序",
    "长期断供",
    "小团队",
    "行动卡",
    "少水餐具清洁顺序",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "刮板或废纸",
    "小盆",
    "少量清水",
    "灰水桶",
    "干净布",
    "标签"
  ],
  "steps": [
    "先把餐具按干净程度排序：杯子、少油碗盘、油污餐具、生食接触器具。",
    "用刮板或废纸先去掉残渣和油脂，残渣进入垃圾或堆肥区，不进清洁水。",
    "少量清水从最干净餐具开始使用，逐步转到更脏餐具，最后进入灰水桶。",
    "接触生肉、呕吐物或污染水的器具单独处理，不混入普通餐具流程。",
    "清洁后倒扣晾干，擦干布保持专用，不擦地面或污染物。"
  ],
  "check": [
    "餐具按污染程度排序。",
    "残渣没有进入清洁水。",
    "灰水和饮用水容器分开。"
  ],
  "common_mistakes": [
    "所有餐具一起泡一盆水。",
    "用饮用水直接冲油盘。",
    "擦餐具的布又去擦地。"
  ],
  "fallback": [
    "没有足够水时，先清洁下一餐必须使用的餐具，其余刮净后封存待洗。",
    "没有清洁布时，优先自然晾干，不用脏衣物擦餐具。"
  ],
  "stop_or_escalate": [
    "出现腹泻、呕吐或生食污染餐具混入时，暂停普通流程并单独消毒或隔离。",
    "饮用水低于最低线时，停止非必要餐具清洗，改用个人固定餐具。"
  ],
