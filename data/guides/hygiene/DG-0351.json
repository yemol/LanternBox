{
  "id": "DG-0351",
  "title": "厨余气味控制",
  "category": "居住卫生与空间管理",
  "priority": "P0",
  "scenario": "做饭、吃饭、处理剩饭、鱼肉、动物饲料或腐败食物后产生气味。",
  "goal": "减少气味吸引动物、虫害和外部注意。",
  "tools": [
    "密封袋",
    "垃圾桶",
    "干土",
    "手套",
    "记录本"
  ],
  "steps": [
    "厨余当天小袋密封，不敞口过夜。",
    "肉、鱼、蛋、奶等易臭厨余优先处理。",
    "厨余桶远离睡眠区、饮水区和入口。",
    "无法外运时，用干土、灰或吸附材料覆盖减味。",
    "餐具残渣及时刮净，不让锅碗过夜发臭。",
    "发现酸臭、腐败味时查找来源，不用香味掩盖。",
    "记录虫害或动物翻找发生位置。"
  ],
  "check": [
    "厨余有盖或密封。",
    "气味源能找到。",
    "厨余不靠近入口和饮水区。"
  ],
  "common_mistakes": [
    "剩饭敞口放一夜。",
    "臭味用香味盖住。",
    "厨余桶放门口吸引动物。"
  ],
  "fallback": [
    "没有密封袋时，用带盖桶、土覆盖或分层纸包临时处理。"
  ],
  "stop_or_escalate": [
    "臭味增强、苍蝇聚集、动物翻动、多人恶心时，立即清理厨余点。"
  ],
  "notes": "厨余不只是垃圾，它会招来一整套麻烦。",
