{
  "id": "DG-0087",
  "title": "伤口避开污水：防水覆盖和事后清洗",
  "category": "居住卫生与空间管理",
  "priority": "P0",
  "scenario": "有开放伤口，但必须清理洪水、取水、雨中行动或接触脏环境。",
  "goal": "减少伤口接触污水导致感染。",
  "tools": [
    "防水敷料",
    "塑料袋",
    "胶带",
    "肥皂",
    "安全水",
    "干净纱布"
  ],
  "steps": [
    "行动前先用干净敷料覆盖伤口。",
    "外层加防水敷料、塑料袋或保鲜膜，边缘用胶带固定，但不要勒住血液循环。",
    "尽量避免伤口直接接触洪水、污水、泥水和盐水。",
    "行动结束后，立即取下外层防水材料。",
    "用肥皂和安全水清洗伤口周围，必要时重新冲洗伤口。",
    "换上干净干燥敷料，记录接触污水时间。",
    "接下来几天观察红肿、疼痛、渗液和发热。"
  ],
  "check": [
    "伤口行动前已覆盖。",
    "接触后已清洗并换敷料。",
    "没有长时间闷湿。"
  ],
  "common_mistakes": [
    "伤口泡污水后只擦一擦。",
    "防水层勒得手脚发紫。",
    "湿敷料继续贴一整天。"
  ],
  "fallback": [
    "没有防水敷料时，用干净塑料袋临时包住，但任务结束后必须换回透气干燥敷料。"
  ],
  "stop_or_escalate": [
    "伤口红肿扩大、流脓、疼痛加重、发热或出现红线。"
  ],
  "notes": "美国疾病控制与预防中心 提醒洪水会带来伤口感染等风险，有伤口时要尽量避免接触并保持清洁覆盖。",
