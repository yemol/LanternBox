{
  "id": "DG-0482",
  "title": "共享工具污染处理",
  "category": "居住卫生与空间管理",
  "scenario": "工具被病人、清污任务、动物处理、厕所区或外部污物接触。",
  "goal": "防止工具把污染带回公共区。",
  "tools": [
    "手套",
    "清洁布",
    "标签",
    "隔离盒"
  ],
  "steps": [
    "污染工具先放入待清洁区，不直接回工具箱。",
    "记录工具名称和污染来源。",
    "能清洁的工具清理后晾干，再归位。",
    "不能清洁或有渗透污染的软材料降级或丢弃。",
    "清污工具和厨房工具永久分开。",
    "处理工具的人完成后洗手。",
    "同一工具反复污染时考虑重新分配用途。"
  ],
  "check": [
    "污染工具未回普通箱。",
    "污染来源有记录。",
    "清污和厨房工具分开。"
  ],
  "common_mistakes": [
    "厕所用过的剪刀擦擦又回工具箱。",
    "污染布袋继续装食物。",
    "没人知道工具碰过什么。"
  ],
  "fallback": "没有隔离盒时，用袋子或纸包临时标记待清洁。",
