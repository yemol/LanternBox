{
  "id": "DG-0484",
  "title": "访客接触后清理",
  "category": "居住卫生与空间管理",
  "scenario": "外来人员、邻居、交易对象、临时求助者接触门口、桌面、工具、容器或物资。",
  "goal": "降低外部接触带来的卫生和信息风险。",
  "tools": [
    "清洁布",
    "记录本",
    "手套",
    "边界标记"
  ],
  "steps": [
    "访客离开后记录接触区域和物品。",
    "先清理门把手、桌面、交易物放置点和工具把手。",
    "访客使用过的杯子、碗或布单独清洗。",
    "交易物资进入缓冲区，先检查包装污染和虫害。",
    "参与接触的成员洗手或更换外层手套。",
    "不要让访客接触后的物资直接进入饮水和药品区。",
    "若访客有明显咳嗽、腹泻或污物接触，升级清理。"
  ],
  "check": [
    "接触点有清理。",
    "交易物资进缓冲区。",
    "接触人员洗手。"
  ],
  "common_mistakes": [
    "访客走后什么都不处理。",
    "交易袋直接放厨房。",
    "访客用过的杯子回公共箱。"
  ],
  "fallback": "没有清洁材料时，至少隔离接触物并加强手部清洁。",
  "stop_or_escalate": [
    "访客疑似生病、接触高敏感区域或污染物进入核心区时，立即复盘边界。"
  ],
  "notes": "访客带来的不只有消息，也可能带来一层看不见的灰。",
  "category_original": "公共接触面管理",
