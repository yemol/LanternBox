{
  "id": "DG-0534",
  "title": "睡眠区防潮",
  "category": "居住卫生与空间管理",
  "priority": "P0",
  "scenario": "多人长期睡在地面、靠墙、潮湿房间或临时垫上。",
  "goal": "减少受潮、霉味、皮肤问题和睡眠崩溃。",
  "tools": [
    "纸板",
    "垫子",
    "晾晒绳",
    "记录本"
  ],
  "steps": [
    "睡眠垫离地或加纸板隔层。",
    "床铺不紧贴潮湿墙面。",
    "每天早晨掀开被褥通风。",
    "湿衣不堆在睡眠区。",
    "每周检查床底、墙角和枕头霉味。",
    "老人儿童病人优先干燥位置。",
    "发现潮湿及时轮换晾晒。"
  ],
  "check": [
    "有隔潮层。",
    "被褥通风。",
    "重点成员睡干燥位。"
  ],
  "common_mistakes": [
    "湿衣堆床边。",
    "被子整天闷着。",
    "霉味枕头继续用。"
  ],
  "fallback": "垫子不足时，优先纸板加衣物隔开地面。",
  "stop_or_escalate": [
    "霉味明显、皮肤瘙痒、咳嗽增多时，调整睡眠区。"
  ],
  "notes": "睡眠区潮了，人会像被慢慢放进冷水里。",
  "category_original": "长期居住空间规划",
