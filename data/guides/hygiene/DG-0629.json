{
  "id": "DG-0629",
  "title": "防鼠食物高处封存",
  "category": "卫生",
  "priority": "P0",
  "scenario": "发现鼠迹或食物包装被咬，需要立即把食物高处封存并切断吸引源。",
  "goal": "保护可食用库存，减少鼠害接触食物、水和睡眠区。",
  "keywords": [
    "卫生",
    "卫生",
    "防鼠食物高处封存",
    "长期断供",
    "小团队",
    "行动卡",
    "防鼠食物高处封存",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "带盖容器",
    "绳子或架子",
    "标签",
    "扫帚",
    "手套",
    "记录纸"
  ],
  "steps": [
    "先停止食用被咬破、沾有鼠粪或有尿味的食物，整包隔离。",
    "把剩余食物转入带盖硬容器或悬挂高处，离地、离墙、离床铺。",
    "清扫碎屑时避免扬尘，鼠粪和污染包装密封丢弃。",
    "检查入口缝隙、垃圾点和水源周边，记录鼠迹出现位置。",
    "夜间收走散装食物和餐具残渣，固定一人每日复查库存容器。"
  ],
  "check": [
    "被污染食物已隔离禁食。",
    "可食用库存已离地封存。",
    "鼠迹位置和复查人已记录。"
  ],
  "common_mistakes": [
    "切掉被咬部分继续吃。",
    "只清理食物，不处理垃圾和碎屑。",
    "把食物袋堆在墙角地面。"
  ],
  "fallback": [
    "硬容器不足时，优先封存高热量、儿童和病人食物，其余悬挂并加外袋。",
    "无法封堵入口时，先减少食物暴露时间和夜间残渣。"
  ],
  "stop_or_escalate": [
    "发现大量鼠粪、咬破水袋或成员被咬伤时，扩大污染控制并停止该区食物存放。",
    "鼠害进入睡眠区时，重新划分睡眠和食物区。"
  ],
