{
  "id": "DG-0628",
  "title": "霉味衣物和睡眠区分离",
  "category": "卫生",
  "priority": "P0",
  "scenario": "衣物有霉味或潮味，若直接带入睡眠区会增加呼吸不适和交叉污染。",
  "goal": "把潮霉衣物和睡眠区分离，恢复可穿衣物的干燥分级。",
  "keywords": [
    "卫生",
    "卫生",
    "霉味衣物和睡眠区分离",
    "长期断供",
    "小团队",
    "行动卡",
    "霉味衣物和睡眠区分离",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "绳子",
    "夹子",
    "标签",
    "干布",
    "袋子",
    "通风位置"
  ],
  "steps": [
    "先把有霉味衣物从床铺、枕边和干净衣物箱移出，单独放入待处理袋。",
    "检查衣物是否有可见霉斑、潮湿、泥污或体液污染，按轻微潮味和明显污染分开。",
    "轻微潮味衣物挂到通风处晾干，不在睡眠区上方晾晒。",
    "明显霉斑或污染衣物在清洗前不得贴身穿，也不作为伤口覆盖布。",
    "睡眠区只保留干燥衣物和被褥，每晚检查地面返潮和墙角霉味。"
  ],
  "check": [
    "霉味衣物已离开睡眠区。",
    "干净衣物和待处理衣物分袋。",
    "睡眠区没有悬挂潮湿衣物。"
  ],
  "common_mistakes": [
    "把潮衣服盖在身上取暖。",
    "霉味衣物和干净衣物混箱。",
    "用霉布处理伤口或餐具。"
  ],
  "fallback": [
    "无法清洗时，先通风晾干并降级为外层或非贴身用途。",
    "空间不足时，用袋子和标签形成垂直分区，不和床铺接触。"
  ],
  "stop_or_escalate": [
    "出现大片霉斑、呼吸不适、皮肤瘙痒或衣物持续潮湿时停止贴身使用。",
    "睡眠区本身返潮时，优先迁移床铺或增加隔离垫层。"
  ],
