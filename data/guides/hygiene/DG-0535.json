{
  "id": "DG-0535",
  "title": "厨房最小安全线",
  "category": "居住卫生与空间管理",
  "priority": "P0",
  "scenario": "临时厨房、室内做饭点或户外炊事点长期使用。",
  "goal": "保证火、水、食物和清洁的最低安全边界。",
  "tools": [
    "桌面",
    "水桶",
    "工具",
    "垃圾桶"
  ],
  "steps": [
    "火源和燃料分开一定距离。",
    "生食、熟食、饮用水和垃圾分区。",
    "刀具固定位置，不放边缘。",
    "厨余桶有盖。",
    "做饭前后清理台面。",
    "儿童和宠物不进入火源半径。",
    "每天晚间检查厨房火源关闭。"
  ],
  "check": [
    "火源燃料分开。",
    "生熟和垃圾分区。",
    "晚间火源检查。"
  ],
  "common_mistakes": [
    "油、纸、燃料堆炉边。",
    "生熟混放。",
    "刀放桌沿。"
  ],
  "fallback": "空间小的话，至少分出火源点、切配点和垃圾点。",
  "stop_or_escalate": [
    "火源失控、食物污染、儿童烫伤风险时，立即停用厨房重整。"
  ],
  "notes": "厨房是营地的胃，也可能是火灾的嘴。",
