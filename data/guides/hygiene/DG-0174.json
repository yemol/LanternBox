{
  "id": "DG-0174",
  "title": "临时厨房位置选择",
  "category": "居住卫生与空间管理",
  "priority": "P0",
  "scenario": "需要长期做饭、烧水或处理食物。",
  "goal": "让厨房远离污染和火灾风险，同时方便取水和清洁。",
  "tools": [
    "桌面",
    "水桶",
    "垃圾袋",
    "刀具盒",
    "灭火材料"
  ],
  "steps": [
    "厨房应靠近清洁水，但不能贴着厕所、垃圾和污染衣物区。",
    "做饭台面保持稳定，不在床上、地上或堆满杂物的位置处理食物。",
    "火源周围清理纸张、布料、燃料和塑料袋。",
    "刀具和锐器有固定位置，儿童不能随手拿到。",
    "生食、熟食、餐具分开放置。",
    "饭后及时处理厨余，避免鼠虫。"
  ],
  "check": [
    "厨房远离污染区。",
    "火源周围无易燃杂物。",
    "刀具和食物分区清楚。"
  ],
  "common_mistakes": [
    "在厕所旁洗菜做饭。",
    "床上切菜。",
    "火源旁堆燃料和纸箱。"
  ],
  "fallback": "没有桌子时，用干净箱板、门板、塑料板做临时台面，并保持离地。",
  "stop_or_escalate": [
    "油烟过大、火源不稳、鼠虫增多、多人饭后腹泻时，重新评估厨房位置。"
  ],
  "notes": "厨房是营地的胃，胃脏了，全队都会不舒服。",
