{
  "id": "DG-0086",
  "title": "垃圾分区：普通、污染、尖锐",
  "category": "居住卫生与空间管理",
  "scenario": "长期避难产生厨余、医疗废物、破玻璃、呕吐物、用过敷料等。",
  "goal": "减少气味、虫鼠、割伤和交叉污染。",
  "tools": [
    "垃圾袋",
    "硬盒",
    "标签纸",
    "手套",
    "绳子"
  ],
  "steps": [
    "把垃圾分成三类：普通垃圾、污染垃圾、尖锐垃圾。",
    "普通垃圾包括包装、干纸板、普通厨余。",
    "污染垃圾包括呕吐物、腹泻污染物、带血敷料、病人用品。",
    "尖锐垃圾包括碎玻璃、针、刀片、金属尖片，放入硬盒再封口。",
    "每天固定时间处理垃圾，垃圾点远离厨房、饮水和睡眠区。",
    "垃圾袋封口后贴日期和类别。",
    "处理垃圾后洗手。"
  ],
  "check": [
    "尖锐物没有直接进入软垃圾袋。",
    "污染垃圾密封并远离生活区。",
    "垃圾点不靠近饮水。"
  ],
  "common_mistakes": [
    "所有垃圾混在一起。",
    "徒手压垃圾袋。",
    "破玻璃直接扔软袋导致割伤。"
  ],
  "fallback": "没有硬盒时，用厚塑料瓶、罐头盒、硬纸筒临时装尖锐物。",
  "stop_or_escalate": [
    "垃圾点出现大量苍蝇、鼠迹、臭液外漏、儿童接触污染垃圾。"
  ],
  "notes": "垃圾不是消失了，只是换了位置；位置选错就会反咬。",
