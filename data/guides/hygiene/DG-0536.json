{
  "id": "DG-0536",
  "title": "仓储离地离墙",
  "category": "居住卫生与空间管理",
  "priority": "P0",
  "scenario": "食物、药品、纸质资料、工具和衣物长期存放。",
  "goal": "减少潮气、虫害和查找困难。",
  "tools": [
    "架子",
    "纸板",
    "标签",
    "收纳箱"
  ],
  "steps": [
    "关键物资离地保存。",
    "食物和纸质资料不贴潮墙。",
    "重物放低，轻物放高。",
    "入口物资远离燃料和清污用品。",
    "每箱贴编号、分类和日期。",
    "每周检查墙角潮气和虫害。",
    "移动位置后更新库存。"
  ],
  "check": [
    "关键物资离地。",
    "重物低放。",
    "位置和库存一致。"
  ],
  "common_mistakes": [
    "米袋直接贴地。",
    "药品靠潮墙。",
    "燃料和食物一箱放。"
  ],
  "fallback": [
    "没有架子时，用纸板、木板、砖块或空箱垫高。"
  ],
  "stop_or_escalate": [
    "虫害、霉味、漏水、箱体变软时，立即转移物资。"
  ],
  "notes": "仓储不是堆高高，是让物资能活到被用那天。",
