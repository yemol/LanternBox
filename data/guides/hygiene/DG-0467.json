{
  "id": "DG-0467",
  "title": "饮水容器个人化",
  "category": "水与食物保障",
  "priority": "P0",
  "scenario": "多人共住时水杯、水瓶、吸管、壶容易混用。",
  "goal": "减少交叉感染、争议和误饮。",
  "tools": [
    "标签",
    "个人水杯",
    "绳子",
    "收纳格"
  ],
  "steps": [
    "给每个成员固定水杯或水瓶。",
    "用姓名、编号、颜色或绳结标记归属。",
    "个人杯不直接伸入公共饮用水桶。",
    "病人、腹泻者和儿童水具单独清洗和存放。",
    "夜间水杯放在固定位置，避免摸错。",
    "发现无主杯先放失物区，不随便使用。",
    "每周检查水具是否裂口、霉味或污垢。"
  ],
  "check": [
    "每人水具有标记。",
    "公共桶未被个人杯接触。",
    "病人水具分开。"
  ],
  "common_mistakes": [
    "全家共用杯子。",
    "杯子直接伸水桶。",
    "病人杯和公共杯混放。"
  ],
  "fallback": [
    "水杯不足时，用固定瓶子或碗分配，并做明显标记。"
  ],
  "stop_or_escalate": [
    "多人腹泻、传染风险、杯具混乱时，立即重新编号和清洗。"
  ],
  "notes": "个人水杯小小一只，却能拦住不少麻烦。",
