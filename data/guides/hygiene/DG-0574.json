{
  "id": "DG-0574",
  "title": "呕吐物和粪便污染：隔离清洁",
  "category": "卫生与清洁",
  "priority": "P0",
  "scenario": "呕吐物或粪便污染地面、织物或常用接触面。",
  "goal": "先固定污染边界，再移除污物并恢复可观察的清洁表面。",
  "tools": [
    "手套或套手塑料袋",
    "吸水材料",
    "铲片",
    "清洁剂",
    "污染袋和标记"
  ],
  "steps": [
    "让无关人员离开，用标记围住飞溅范围。",
    "从外缘向中心覆盖吸水材料，避免扫、刷或踩踏。",
    "戴隔离层用铲片收集污物，装入双层封袋。",
    "按清洁剂说明擦洗接触面，工具留在污染侧。",
    "脱下隔离层后清洁双手，待表面干燥再解除标记。"
  ],
  "check": [
    "地面无可见残留、湿痕和明显异味。",
    "污染袋不渗漏并已移出生活区。",
    "清洁者手脚和鞋底未把污物带过边界。"
  ],
  "common_mistakes": [
    "干扫导致飞溅或扬尘。",
    "把不同清洁剂混合。",
    "未干燥就开放通行。"
  ],
  "fallback": [
    "无清洁剂时先彻底移除污物，用肥皂水机械擦洗并保持隔离。",
    "缺人手时封闭区域，优先照护患者和保护水食物，延后深度清洁。"
  ],
  "stop_or_escalate": [
    "污染持续新增、范围进入水食物区、清洁者出现头晕或皮肤破损暴露时停止清理并扩大隔离。",
    "无法确认清洁剂成分时禁止混用或加热。"
  ],
