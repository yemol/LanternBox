    "分区标记",
    "洗手点",
    "桶厕材料",
    "巡查表",
    "交接记录"
  ],
  "steps": [
    "标出饮水区、洗手区、厕所区、厨房区、污染区和睡眠区。",
    "确定必须洗手时刻：处理厕所、呕吐物、垃圾后，做饭前，吃饭前，照护病人前后。",
    "每日巡查水桶、洗手点、桶厕、垃圾、病人用品、厨房表面。",
    "发现污染区漂移或标记破坏时，先隔离再清理。",
    "交接 WASH 状态和待处理异常。"
  ],
  "check": [
    "厕所区是否远离饮水和厨房。",
    "洗手点是否可用。",
    "污染垃圾是否二次封存。",
    "是否有腹泻、呕吐、异味、虫害记录。"
  ],
  "common_mistakes": [
    "把水桶放在厕所动线上。",
    "洗手水被普通擦洗用完。",
    "只口头交接污染区和病人用品。"
  ],
  "fallback": [
    "水不足时保留关键时刻洗手，其他清洁降级。",
    "空间不足时至少保持饮水、厨房、厕所三者不重叠。"
  ],
  "stop_or_escalate": [
    "厕所或污物接近饮水或厨房、桶厕破袋、多人腹泻呕吐、污染区无法标记时停止共用相关区域。",
    "食物接触污染表面时按弃用或隔离判断。"
  ],
