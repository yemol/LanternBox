{
  "id": "DG-0293",
  "title": "排队和分配秩序",
  "category": "组织秩序与训练演练",
  "priority": "P1",
  "scenario": "分配水、食物、药品、工具、充电机会或进入安全区域时出现拥挤。",
  "goal": "减少插队、推搡和重复领取。",
  "tools": [
    "排队标记",
    "名单",
    "编号牌",
    "记录本"
  ],
  "steps": [
    "先宣布分配规则：对象、数量、顺序、是否可重复领取。",
    "用编号、名单或家庭单位登记，不只靠眼熟。",
    "排队区域和领取区域分开，避免人群压到物资。",
    "弱势成员可由代表领取，但要登记。",
    "发放者和记录者尽量分开，一人给物，一人记账。",
    "出现争议时暂停该人的领取，先处理记录。",
    "分配结束后公开剩余数量或下一次时间。"
  ],
  "check": [
    "领取有记录。",
    "排队和物资区分开。",
    "发放和记录有人负责。"
  ],
  "common_mistakes": [
    "大家围着物资抢。",
    "熟人多拿没人记。",
    "规则临时变化不说明。"
  ],
  "fallback": [
    "人数少时也要简单登记，避免后续记忆冲突。"
  ],
  "stop_or_escalate": [
    "人群推挤、物资被抢、弱势成员无法领取时，暂停发放并重建秩序。"
  ],
  "notes": "分配最怕看起来公平，实际没人记得清。",
