{
  "id": "DG-0620",
  "title": "接口潮湿和线头保护",
  "category": "能源",
  "priority": "P0",
  "scenario": "接口潮湿、线头裸露或线缆外皮破损，继续通电会带来短路、触电和设备损坏风险。",
  "goal": "先断电、干燥、隔离和标记，不让潮湿接口进入供电链路。",
  "keywords": [
    "能源",
    "能源",
    "接口潮湿和线头保护",
    "长期断供",
    "小团队",
    "行动卡",
    "接口潮湿和线头保护",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "干布",
    "标签",
    "绝缘胶带",
    "小盒",
    "手电",
    "记录纸"
  ],
  "steps": [
    "发现潮湿或裸露线头时先断开电源端，再断开设备端，不带电擦拭接口。",
    "把潮湿线缆和设备放到通风干燥处，和可用线缆分盒存放。",
    "外皮破损但未露铜的线缆可临时贴待检标签；露铜、发黑、融化或松动接口直接禁用。",
    "检查桌面、地面和墙角是否有滴水、冷凝或饮水容器靠近充电区。",
    "重新启用前由两人复查干燥、无异味、无发热，再只接低风险设备短时测试。"
  ],
  "check": [
    "潮湿接口已断电并离开充电区。",
    "禁用线缆和可用线缆分开。",
    "充电区附近水源已移开。"
  ],
  "common_mistakes": [
    "边充电边擦接口。",
    "用嘴吹或靠火烤线头。",
    "把破损线缆卷起来继续备用。"
  ],
  "fallback": [
    "没有绝缘胶带时，直接禁用露铜线缆，不用布条当绝缘替代。",
    "线缆不足时优先保留完好线给通信和照明设备。"
  ],
  "stop_or_escalate": [
    "通电后出现发热、跳断、焦味、火花或设备异常重启时停止使用该线缆。",
    "充电区持续潮湿无法排除时，迁移到更高、更干燥位置。"
  ],
