{
  "id": "DG-0290",
  "title": "争议物资中立放置",
  "category": "组织秩序与训练演练",
  "priority": "P1",
  "scenario": "两人或多人争抢水、食物、药、工具、燃料、设备或证件。",
  "goal": "先让物资脱离争抢状态，降低肢体冲突。",
  "tools": [
    "中立箱",
    "记录本",
    "标签纸",
    "见证人"
  ],
  "steps": [
    "一旦出现争抢，立即停止分配。",
    "把争议物资放入中立箱或交给第三人临时保管。",
    "记录争议物资编号、数量、涉及人员和争议原因。",
    "双方先离开物资一段距离。",
    "按现有规则查库存、借用记录和任务需求。",
    "决定结果后记录分配依据。",
    "如果规则不足，补充规则后再分配。"
  ],
  "check": [
    "争议物资不在任何一方手里。",
    "争议原因有记录。",
    "分配依据写清楚。"
  ],
  "common_mistakes": [
    "边拉扯边讲道理。",
    "强势者先抢到就算。",
    "没有记录导致下次继续吵。"
  ],
  "fallback": [
    "没有中立箱时，把物资放到公共桌面，由两名见证人看管。"
  ],
  "stop_or_escalate": [
    "争抢中出现推搡、武器、药品损坏、燃料泄漏时，先处理安全风险。"
  ],
  "notes": "物资离开手，脑子才容易回来。",
