{
  "id": "DG-0565",
  "title": "停电夜间：低亮照明布置",
  "category": "能源照明与设备",
  "priority": "P0",
  "scenario": "停电夜间：低亮照明布置相关场景出现，外部支援不确定，需要立刻用本地资源处理。",
  "goal": "围绕能源照明与设备降低夜间跌倒和暴露风险，形成可记录、可复核的行动。",
  "tools": [
    "纸笔",
    "标签",
    "手电",
    "干净布"
  ],
  "steps": [
    "固定夜间必走路线：床到厕所、床到出口、照护点到水和药。",
    "在转角、台阶、门槛和水桶旁设置低亮或反光标记。",
    "手电固定放在每个睡眠区伸手可及的位置，方向朝下。",
    "夜间行动只开短时低亮，不照窗外或门缝。",
    "睡前收起地面杂物、水桶和线缆。"
  ],
  "check": [
    "夜间路线已清空。",
    "危险点已有低亮标记。",
    "手电位置固定。"
  ],
  "common_mistakes": [
    "用强光照窗外观察。",
    "把灯放在容易踢倒的位置。",
    "线缆横跨夜间路线。"
  ],
  "fallback": [
    "灯具不足时，优先标记台阶、门口和水源位置。"
  ],
  "stop_or_escalate": [
    "有人跌倒、玻璃破碎、火源附近照明不稳或外部风险升高时，停止非必要夜间行动。"
  ],
