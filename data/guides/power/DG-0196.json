{
  "id": "DG-0196",
  "title": "无通信外出规则",
  "category": "通信信息与数据安全",
  "priority": "P0",
  "scenario": "没有手机信号、对讲机、电量或可靠通信时必须外出。",
  "goal": "让外出行为可追踪，不让人消失在空白里。",
  "tools": [
    "外出登记表",
    "地图",
    "联络卡",
    "哨子",
    "手表"
  ],
  "steps": [
    "出发前登记外出人员、方向、路线、目的、预计返回时间。",
    "至少两人同行；只有任务在营地可见范围内、路线有明确返回点且留守者记录最晚返回时间时，才可单人短时行动。",
    "指定最晚返回时间，超时触发等待、观察或查找。",
    "每个人带联络卡、水、照明和基本防护。",
    "只走登记路线，不临时改路；必须改路时在固定留言点留信息。",
    "返回后立刻登记实际路线、发现和消耗。"
  ],
  "check": [
    "路线已记录返回点、避险点、危险区域和约定返回时间。",
    "外出者与留守者都能复述失联后的本地动作。",
    "返程所需照明、饮水和时间仍有保留量。"
  ],
  "common_mistakes": [
    "口头说一声就走。",
    "一个人去陌生路线。",
    "临时改变路线不留信息。"
  ],
  "fallback": [
    "必须单人短途时，限制距离和时间，并让值守者持续观察。"
  ],
  "stop_or_escalate": [
    "天气变坏、路线受阻、超时未归、外部冲突时，启动查找或等待流程。"
  ],
  "notes": "没有通信时，登记就是通信的替身。",
