{
  "id": "DG-0562",
  "title": "电池不足：照明分级使用",
  "category": "能源照明与设备",
  "priority": "P0",
  "scenario": "电池不足：照明分级使用相关场景出现，外部支援不确定，需要立刻用本地资源处理。",
  "goal": "围绕能源照明与设备降低跌倒和耗尽风险，形成可记录、可复核的行动。",
  "tools": [
    "纸笔",
    "标签",
    "手电",
    "干净布"
  ],
  "steps": [
    "点清所有可用照明和电池，标出满电、半电和备用。",
    "睡眠区只保留低亮或反光标记，不长期开强光。",
    "厕所、楼梯、门口和危险物位置设置短时行动照明。",
    "值守或异常观察才使用较亮照明，用完立即关闭。",
    "每天固定时间回收检查电量，不让电池分散在个人包里。"
  ],
  "check": [
    "照明已分级。",
    "备用电池已集中管理。",
    "高亮灯有使用规则。"
  ],
  "common_mistakes": [
    "整晚开大灯。",
    "每个人随意拿电池。",
    "用手机手电代替固定照明。"
  ],
  "fallback": [
    "没有足够灯具时，用浅色布、反光条、荧光贴或固定路线减少照明需求。"
  ],
  "stop_or_escalate": [
    "夜间跌倒、照明完全耗尽或必须外出时，重新分配电池并停止非必要夜间行动。"
  ],
