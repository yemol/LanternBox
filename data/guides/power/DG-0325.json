{
  "id": "DG-0325",
  "title": "个人物资编号和归属",
  "category": "个人装备与防护",
  "scenario": "多人共处时，手电、药品、水杯、餐具、衣物、包、工具容易混淆。",
  "goal": "减少混用、丢失、污染和争议。",
  "tools": [
    "标签纸",
    "记号笔",
    "编号清单",
    "收纳袋"
  ],
  "steps": [
    "为每个成员设定个人编号或姓名缩写。",
    "个人水杯、餐具、药包、外出包、睡眠袋贴上归属标记。",
    "容易混淆的同款物品增加颜色、绳结或位置标记。",
    "个人药品不得随意混入公共药箱，必须有成员对应关系。",
    "公共工具和个人工具分开记录。",
    "发现无主物品先放到失物区，不直接占用。",
    "每周检查个人关键物品是否齐全。"
  ],
  "check": [
    "个人水杯餐具有标记。",
    "个人药品能对应成员。",
    "无主物品有临时区。"
  ],
  "common_mistakes": [
    "大家共用水杯。",
    "同款手电混在一起。",
    "个人药品没有归属。"
  ],
  "fallback": "没有标签纸时，用绳结、布条、刻痕或颜色点做归属标记。",
  "stop_or_escalate": [
    "个人药品、水杯、餐具混用导致过敏、污染或争议时，立即重新编号。"
  ],
  "notes": "个人物资的归属清楚，能少很多没必要的吵架。",
