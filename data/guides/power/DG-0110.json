{
  "id": "DG-0110",
  "title": "小型发电机使用边界",
  "category": "能源照明与设备",
  "priority": "P0",
  "scenario": "有汽油、柴油或燃气小型发电机。",
  "goal": "在避免中毒、火灾和噪音暴露的前提下获取电力。",
  "tools": [
    "发电机",
    "燃料",
    "延长线",
    "灭火材料",
    "一氧化碳报警器可选",
    "记录本"
  ],
  "steps": [
    "发电机只能在室外通风处使用，远离门窗、通风口和睡眠区。",
    "启动前检查燃料、机油、线缆和周围可燃物。",
    "先启动发电机稳定运行，再连接设备。",
    "优先给充电宝、电池、照明和必要设备集中充电。",
    "不要长时间空转，也不要超负荷带大功率电器。",
    "运行结束后冷却，再补燃料。",
    "记录燃料消耗、运行时间和充电设备。"
  ],
  "check": [
    "发电机在室外通风处。",
    "废气没有进入室内。",
    "没有超负荷和线缆发热。"
  ],
  "common_mistakes": [
    "在车库、室内、楼道使用。",
    "发电机热的时候加油。",
    "一台插线板接一串大功率设备。"
  ],
  "fallback": [
    "没有一氧化碳报警器时，更要远离门窗并安排人员观察气味、头晕、恶心等异常。"
  ],
  "stop_or_escalate": [
    "有人头晕恶心、设备线缆发热、燃料泄漏、火花、异响时立即停机。"
  ],
  "notes": "发电机最危险的不是没电，而是一氧化碳和火。",
