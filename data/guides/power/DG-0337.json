{
  "id": "DG-0337",
  "title": "充电优先级",
  "category": "能源照明与设备",
  "priority": "P0",
  "scenario": "太阳能、电源站、发电机、移动电源或有限插座可用，但电量不足以全充。",
  "goal": "让关键通信、照明和医疗相关设备优先充电。",
  "tools": [
    "充电清单",
    "标签",
    "计时器",
    "电源设备"
  ],
  "steps": [
    "先列出必须充电设备：照明、通信、医疗记录设备、壳中灯终端、对讲机。",
    "再列出低优先级设备：娱乐、非必要拍摄、备用设备。",
    "按优先级排队充电，不先给最方便拿到的设备充。",
    "每个设备贴编号并记录开始时间和结束时间。",
    "充到够用即可，不一定每台都充满。",
    "充电时有人观察发热、异味和线缆松动。",
    "充电结束后更新电量记录。"
  ],
  "check": [
    "充电有优先级。",
    "关键设备先充。",
    "充电过程有人观察。"
  ],
  "common_mistakes": [
    "谁先抢到插座谁先充。",
    "娱乐设备占用关键电力。",
    "充电线发热没人管。"
  ],
  "fallback": "电量极少时，优先照明和通信，暂停非必要设备。",
  "stop_or_escalate": [
    "设备发热、充电器异味、电源不足、医疗或通信设备低电时，立即调整优先级。"
  ],
  "notes": "有限电力不是平均分，是按生命线排序。",
