{
  "id": "DG-0111",
  "title": "电线和插线板安全检查",
  "category": "能源照明与设备",
  "scenario": "断电恢复、临时供电、发电机供电或多个设备充电时。",
  "goal": "避免触电、短路和火灾。",
  "tools": [
    "手电",
    "绝缘胶带",
    "标签纸",
    "干布",
    "备用线"
  ],
  "steps": [
    "使用前检查电线外皮是否破损、插头是否变形、插线板是否有焦味。",
    "地面潮湿时，插线板垫高，远离水桶、洗手站和门口雨水。",
    "大功率设备不要接在串联插线板上。",
    "发现线材发热、松动、火花、焦味，立刻断电。",
    "轻微外皮破损只能临时绝缘包扎，不能用于高功率设备。",
    "损坏线材贴标签，放入待修区，不混回正常线材。"
  ],
  "check": [
    "线材无明显破损。",
    "插线板离水源远。",
    "没有串联过载。"
  ],
  "common_mistakes": [
    "带电缠胶带。",
    "破损线继续带大功率电器。",
    "插线板放湿地上。"
  ],
  "fallback": "线材不足时，优先保障低功率关键设备，不为方便乱接。",
  "stop_or_escalate": [
    "焦味、冒烟、火花、线材发热、触电感时立即断电并隔离。"
  ],
  "notes": "临时供电最怕临时心态。",
