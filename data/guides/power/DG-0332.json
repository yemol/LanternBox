{
  "id": "DG-0332",
  "title": "手电分级使用",
  "category": "能源照明与设备",
  "scenario": "手电、电筒、头灯、露营灯、电池灯数量有限。",
  "goal": "按任务使用不同亮度和灯具，避免浪费和暴露。",
  "tools": [
    "手电",
    "头灯",
    "低亮灯",
    "标签纸",
    "电池清单"
  ],
  "steps": [
    "把灯具分为近距离低亮、工作照明、户外强光和备用四类。",
    "夜间室内行动优先用低亮灯。",
    "维修、包扎和找小零件用工作照明。",
    "户外强光只用于短时确认危险，不长时间扫射。",
    "备用灯不参与日常使用，除非其他灯失效。",
    "每个灯具贴编号，记录电池型号和存放位置。",
    "使用后归位并记录电量异常。"
  ],
  "check": [
    "灯具用途分级。",
    "备用灯未被日常消耗。",
    "灯具有编号。"
  ],
  "common_mistakes": [
    "所有任务都用最亮档。",
    "备用灯被拿去玩。",
    "电池型号不记。"
  ],
  "fallback": "灯具少时，至少区分日常低亮灯和紧急备用灯。",
  "stop_or_escalate": [
    "所有灯具电量下降、强光频繁暴露位置、夜间找不到备用灯时，重做分级。"
  ],
  "notes": "手电也要分工，不然最亮的那个会最先死。",
