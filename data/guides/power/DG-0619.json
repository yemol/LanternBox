{
  "id": "DG-0619",
  "title": "负载过大时断开排序",
  "category": "能源",
  "priority": "P0",
  "scenario": "同一电源同时接入太多设备，出现变暗、发热、断续或异味，需要按顺序断开负载。",
  "goal": "在不损坏关键设备的前提下，快速降低负载并保留最重要供电。",
  "keywords": [
    "能源",
    "能源",
    "负载过大时断开排序",
    "长期断供",
    "小团队",
    "行动卡",
    "负载过大时断开排序",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "负载清单",
    "标签",
    "手电",
    "绝缘胶带",
    "计时工具",
    "记录纸"
  ],
  "steps": [
    "先观察异常来自电源、插排、线缆还是某个设备，不用手触碰发热金属部位。",
    "按娱乐设备、备用设备、普通照明、充电设备、通信医疗设备的顺序断开负载。",
    "每断开一类等待短时间，记录电源是否恢复稳定、异味是否消失、温度是否下降。",
    "把可疑线缆和设备贴上待检标签，不再换到其他电源继续试。",
    "恢复供电时只接一个关键设备，确认稳定后再按优先级逐个增加。"
  ],
  "check": [
    "非关键负载已先断开。",
    "发热或异味设备已贴待检标签。",
    "恢复供电按单设备逐步进行。"
  ],
  "common_mistakes": [
    "异常时反复插拔所有设备。",
    "先保留最耗电设备。",
    "把发热线缆换个插口继续用。"
  ],
  "fallback": [
    "没有负载清单时，先断开肉眼可见最大功率或非生存用途设备。",
    "照明不足时保留一盏低功耗灯，其余改用固定开灯窗口。"
  ],
  "stop_or_escalate": [
    "出现火花、焦味、冒烟、外壳变形或手感烫时停止使用该电源路径。",
    "无法判断哪个设备异常时，全部断开并改用备用电源。"
  ],
