{
  "id": "DG-0616",
  "title": "充电宝鼓包发热停用隔离",
  "category": "能源",
  "priority": "P0",
  "scenario": "充电宝或电池包出现鼓包、发热、异味或外壳开裂，继续使用可能引发火灾和有毒烟气。",
  "goal": "立即停用并隔离可疑电池，保护人员、燃料和其他电源设备。",
  "keywords": [
    "能源",
    "能源",
    "充电宝鼓包发热停用隔离",
    "长期断供",
    "小团队",
    "行动卡",
    "充电宝鼓包发热停用隔离",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "耐热容器或金属盆",
    "干沙或土",
    "标签",
    "手套",
    "夹子",
    "记录纸"
  ],
  "steps": [
    "先断开所有充电线和负载，不再按键测试电量，也不放入口袋或床边。",
    "不要用手长时间握持发热电池，使用夹子或隔热物把它移到通风、远离可燃物的位置。",
    "放入耐热容器周围留空，旁边准备干沙或土覆盖，标记禁用。",
    "检查同一充电区域的线缆、插头和其他电池是否发热或有异味。",
    "记录设备编号、异常时间、正在充电还是放电，并从轮换清单中移除。"
  ],
  "check": [
    "可疑电池已断开并离开睡眠区。",
    "隔离点远离纸张、布料、燃料和水桶。",
    "同批设备已复查。"
  ],
  "common_mistakes": [
    "继续充电看能不能恢复。",
    "把鼓包电池放进背包。",
    "用水直接处理正在异常发热的电池。"
  ],
  "fallback": [
    "没有金属容器时，选择空旷地面或砖石表面临时隔离，并清走周边可燃物。",
    "电源不足时优先保留正常设备给照明、通信和医疗记录。"
  ],
  "stop_or_escalate": [
    "出现冒烟、刺鼻味、嘶嘶声、快速升温或变形扩大时人员后撤，停止搬动。",
    "隔离区附近有燃料、儿童或无法通风时，立即重新划出安全边界。"
  ],
