{
  "id": "DG-0372",
  "title": "常用工具每日归位",
  "category": "工具维修与替代制作",
  "scenario": "剪刀、刀具、钳子、螺丝刀、锤子、手电、胶带等高频工具经常被多人使用。",
  "goal": "让常用工具用完能回到固定位置，避免关键时刻找不到。",
  "tools": [
    "工具箱",
    "标签纸",
    "挂钩",
    "记录本"
  ],
  "steps": [
    "给常用工具设置固定位置，贴上名称标签。",
    "工具用完后先清理污水、泥土、油渍或血迹，再归位。",
    "锋利工具必须合上、套住或放入硬盒。",
    "借出工具记录借用人、时间和用途。",
    "每天睡前检查剪刀、刀具、手电、胶带、螺丝刀是否在位。",
    "发现工具缺失时先查借用记录，不直接互相指责。",
    "工具位置改变后通知所有成员。"
  ],
  "check": [
    "常用工具有固定位置。",
    "锋利工具有保护。",
    "借出有记录。"
  ],
  "common_mistakes": [
    "工具随手放床上。",
    "刀具裸放。",
    "胶带和剪刀用完不归位。"
  ],
  "fallback": "没有工具箱时，用墙钩、布袋、硬纸盒或桌面标记区临时归位。",
  "stop_or_escalate": [
    "急救、撤离、维修前找不到关键工具时，立即重整工具归位系统。"
  ],
  "notes": "工具归位就是给混乱装抽屉。",
