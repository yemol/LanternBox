{
  "id": "DG-0662",
  "title": "呕吐物清理后手卫生",
  "category": "污染控制 / 隔离 / 清洁分区",
  "priority": "P0",
  "scenario": "人员清理过呕吐物，双手和工具可能把污染带入生活区。",
  "goal": "在接触餐具、饮水或他人前完成可验证的手部清洁。",
  "keywords": [
    "污染控制",
    "污染控制 / 隔离 / 清洁分区",
    "呕吐物清理后手卫生",
    "长期断供",
    "小团队",
    "行动卡",
    "呕吐物清理后手卫生",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "清洁水",
    "肥皂或清洁剂",
    "一次性手部隔离材料",
    "专用擦布",
    "污染标记"
  ],
  "steps": [
    "把清理工具留在污染区，先移除手套或套手塑料袋。",
    "用少量水冲掉可见污物，避免飞溅到衣物和水容器。",
    "用肥皂揉搓掌心、手背、指缝、指尖和腕部，再用清洁水冲净。",
    "用专用干布擦干，检查指甲缝和皮肤破口。",
    "清洁门把手等已触碰位置，并标记待处理工具。"
  ],
  "check": [
    "双手无可见污物、异味和黏滑感。",
    "指缝与指甲边已清洁，破口有覆盖。",
    "污染工具没有进入餐饮区。"
  ],
  "common_mistakes": [
    "戴过手套就跳过洗手。",
    "在公用水桶上方直接冲洗。",
    "用同一块布擦手和擦污染地面。"
  ],
  "fallback": [
    "水很少时先用纸或专用布去除污物，再用少量肥皂水分段清洁，废液留在污染区。",
    "无肥皂时用清洁水充分机械擦洗并暂停食品处理，直到可再次规范清洁。"
  ],
  "stop_or_escalate": [
    "手部有开放伤口、污染进入眼口或清洁后仍有污物时停止接触食物和照护对象。",
    "呕吐持续发生或污染区扩大时暂停逐点清理，先固定污染边界。"
  ],
