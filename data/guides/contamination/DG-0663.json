{
  "id": "DG-0663",
  "title": "污水进屋后的污染线",
  "category": "污染控制 / 隔离 / 清洁分区",
  "priority": "P0",
  "scenario": "污水进入住所并可能流向睡眠、储水或食物区。",
  "goal": "建立看得见的污染线，使人员和物资只按单向路径移动。",
  "keywords": [
    "污染控制",
    "污染控制 / 隔离 / 清洁分区",
    "污水进屋后的污染线",
    "长期断供",
    "小团队",
    "行动卡",
    "污水进屋后的污染线",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "绳带或醒目标记",
    "防水鞋套或塑料袋",
    "吸水阻挡物",
    "专用容器",
    "记录纸"
  ],
  "steps": [
    "从干净侧观察污水最高到达线和继续流动方向。",
    "先把人员、饮水、食物和药品移到高处干净区。",
    "沿污水外缘设置连续标记，只保留一个受控进出口。",
    "在入口分别放置污染工具和脱卸材料，指定一名记录者。",
    "按由干净到污染的顺序处理，离开时脱下外层并清洁手脚。"
  ],
  "check": [
    "污染线连续可见，没有穿过睡眠或食物区。",
    "清洁物资与污染工具分开存放。",
    "所有进入者和退出时间都有记录。"
  ],
  "common_mistakes": [
    "踩过污水后返回清洁区取物。",
    "边清理边移动污染线却不通知成员。",
    "用饮用水冲散污水。"
  ],
  "fallback": [
    "无绳带时用成排物件或粉笔画线，并安排一人守住入口。",
    "无法清理时封闭整间区域，从高处另设睡眠和取水点。"
  ],
  "stop_or_escalate": [
    "污水继续上涨、污染线被越过、出现刺鼻气味或皮肤伤口暴露时停止进入并扩大隔离。",
    "无法判断电源是否浸水时禁止涉水和通电。"
  ],
