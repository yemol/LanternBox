{
  "id": "DG-0661",
  "title": "血液污染物双层封存",
  "category": "污染控制 / 隔离 / 清洁分区",
  "priority": "P0",
  "scenario": "带血布料或废物需要在住所内暂存。",
  "goal": "封住污染物并阻断它与皮肤、饮水和食物接触。",
  "keywords": [
    "污染控制",
    "污染控制 / 隔离 / 清洁分区",
    "血液污染物双层封存",
    "长期断供",
    "小团队",
    "行动卡",
    "血液污染物双层封存",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "两只无破损袋或容器",
    "手套或塑料袋",
    "吸水材料",
    "标签",
    "清洁用水"
  ],
  "steps": [
    "先覆盖仍在渗漏的污染物，不挤压或抖动。",
    "用手套或反套塑料袋拾取，连同吸水材料放入第一层袋。",
    "挤出多余空气后扎紧第一层，再装入第二层并封口。",
    "在外层标明血液污染和封存时间，放到远离水食物的固定区。",
    "脱下手部隔离层后清洁双手和接触面。"
  ],
  "check": [
    "外袋表面无血迹或湿痕。",
    "封口倒置时不渗漏。",
    "存放点有清晰污染标记且远离清洁物资。"
  ],
  "common_mistakes": [
    "用手直接压实袋内物。",
    "只套一层薄袋。",
    "把污染袋放在食物或取水通道旁。"
  ],
  "fallback": [
    "只有一只袋时先用不渗漏容器加盖，外侧标记并限制搬动。",
    "无手套时用完整塑料袋套手，完成后把接触面翻入袋内。"
  ],
  "stop_or_escalate": [
    "袋体被尖物刺破、外层出现湿痕或污染沾到裸露伤口时停止搬动并重新扩大隔离。",
    "无法形成不渗漏封装时，不把污染物穿过清洁区。"
  ],
