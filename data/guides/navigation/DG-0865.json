  "tools": [
    "路线图",
    "备用路线",
    "风险评分表",
    "水位或天气记录",
    "人员状态记录"
  ],
  "steps": [
    "对路线做风险评分，逐段检查积水、桥涵、坡地、坍塌、冲突、烟火和照明。",
    "确认每段是否有返回点或备用路线。",
    "设置继续、绕行、等待和取消条件。",
    "标记不可通行点、危险边界和复查时间。",
    "把路线版本交给留守人或同行成员。"
  ],
  "check": [
    "危险点已标出。",
    "备用路线存在且不是未经复查的未知路。",
    "返回路线没有被切断。",
    "继续或停止线不是临时口头决定。"
  ],
  "common_mistakes": [
    "把熟路当作低风险路。",
    "只看距离，不看水、坡地和夜间边界。",
    "遇阻后直接跟随他人绕行。"
  ],
  "fallback": [
    "改用已复查的备用路线。",
    "缩短移动距离，只到最近安全点。",
    "转入临时避难点等待复查。"
  ],
  "stop_or_escalate": [
    "水流不明、桥面受损、坡面开裂、落石、烟火阻断、夜间照明不足或路线进入冲突区域时停止通行。",
    "所有可选路线都缺返回点或风险边界不明时，不强行移动。"
  ],
