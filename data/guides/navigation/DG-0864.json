  ],
  "common_mistakes": [
    "边走边等定位恢复。",
    "分散寻找方向。",
    "把漂移轨迹当作安全返回线。"
  ],
  "fallback": [
    "留在安全可见位置，用哨声、灯光、通信或纸条报告位置。",
    "无通信时按原定等待规则保留体力。",
    "有可信 track 片段时只用可信段转返回摘要。"
