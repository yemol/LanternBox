  ],
  "common_mistakes": [
    "只保存轨迹线，不写关键点含义。",
    "忽略漂移和断点。",
    "把一次任务轨迹直接当长期安全路线。"
  ],
  "fallback": [
    "手写点位和时间。",
    "用地标顺序替代轨迹。",
    "回到基地后补录为任务路线记录。"
