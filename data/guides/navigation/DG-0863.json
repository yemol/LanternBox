  "tools": [
    "纸质地图或草图",
    "路线卡",
    "铅笔",
    "计时工具",
    "照明和通信窗口记录"
  ],
  "steps": [
    "写明人员、目的、出发时间、最晚返回时间和留守联系人。",
    "标出起点、目标、去程、返回路线和备用路线。",
    "设置检查点、折返线、夜间停止线和可等待位置。",
    "标出危险点、禁行点、通信窗口和最近安全点。",
    "出发前把路线卡交给留守人，并确认对方能复述。"
  ],
  "check": [
    "返回路线能被第二个人复述。",
    "至少有一个备用路线或撤回点。",
    "最晚返回时间、折返线和夜间停止线明确。",
    "留守人知道超时后先看哪张记录。"
  ],
  "common_mistakes": [
    "只写目标，不写返回路线。",
    "把最短路线当作安全路线。",
    "临时改路却不更新留守记录。"
  ],
  "fallback": [
    "没有地图时使用手绘草图、地标顺序、步数和时间。",
    "不能确认返回时缩短任务距离，只到最近确定点。",
    "无人留守时不做远距离外出。"
  ],
  "stop_or_escalate": [
    "无返回路线、无地图或草图、夜间照明不足、天气恶化、人员体力不足或通信窗口不可用时，不扩大外出范围。",
    "到折返时间、路线受阻或返回资源不足时停止向目标推进并返回。"
  ],
