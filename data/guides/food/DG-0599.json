{
  "id": "DG-0599",
  "title": "主食不足：低体力消耗配给",
  "category": "水与食物保障",
  "priority": "P0",
  "scenario": "米、面、饼干等主食不足，同时需要维持多天。",
  "goal": "把主食和体力任务一起管理，减少无谓消耗。",
  "tools": [
    "库存表",
    "任务表",
    "锅"
  ],
  "steps": [
    "估算主食能支撑的餐数，不按平时饭量分配。",
    "取消或推迟重体力、长距离外出和重复搬运任务。",
    "把主食与汤水、耐储配菜或少量蛋白搭配。",
    "优先保证儿童、老人、病人和必须值守人员的基础份额。",
    "每天固定时间分发，不在情绪紧张时临时加餐。"
  ],
  "check": [
    "主食餐数已估算。",
    "重体力任务已减少。",
    "优先成员份额已保留。"
  ],
  "common_mistakes": [
    "一边减饭一边安排重体力劳动。",
    "把饼干零食当自由安慰食品。",
    "不记录主食剩余。"
  ],
  "fallback": [
    "没有配菜时用热水、汤水或分餐频率减轻饥饿感，但不牺牲饮用水底线。"
  ],
  "stop_or_escalate": [
    "明显虚弱、站立头晕、儿童持续哭闹或主食低于一天时，重新评估转移、交换或求援。"
  ],
