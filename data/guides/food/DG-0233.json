{
  "id": "DG-0233",
  "title": "手动除虫和防虫",
  "category": "种植养殖与采集",
  "priority": "P1",
  "scenario": "种植容器或小菜地出现蚜虫、菜青虫、蜗牛、蚂蚁、飞虫等。",
  "goal": "用低化学依赖方式控制虫害，保护入口食物。",
  "tools": [
    "手套",
    "小刷子",
    "水",
    "纱网",
    "记录本"
  ],
  "steps": [
    "每天检查叶背、嫩芽、土面和盆底。",
    "看到大虫先手动摘除，放入远离菜地的位置处理。",
    "小虫可用水流轻冲，再检查叶背是否残留。",
    "用纱网或旧蚊帐罩住易被虫咬的叶菜。",
    "移走腐烂叶片和烂果，减少虫源。",
    "记录虫害出现日期和严重程度。",
    "不要随便用不明农药处理入口食物。"
  ],
  "check": [
    "虫害位置有记录。",
    "腐烂叶片已清理。",
    "入口食物没有使用不明药剂。"
  ],
  "common_mistakes": [
    "只看叶面不看叶背。",
    "用危险化学品喷菜。",
    "虫害严重还继续扩种。"
  ],
  "fallback": [
    "没有纱网时，用薄布、旧蚊帐、孔洞较小的布临时遮挡。"
  ],
  "stop_or_escalate": [
    "虫害快速扩散、植物大面积死亡、出现不明药剂污染时，停止食用受影响作物。"
  ],
  "notes": "小种植靠勤看，不能靠猛药。",
