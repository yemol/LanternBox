{
  "id": "DG-0229",
  "title": "叶菜轮播计划",
  "category": "种植养殖与采集",
  "priority": "P1",
  "scenario": "有少量种子和容器，想持续获得一点新鲜叶菜。",
  "goal": "用分批播种避免一次长成、一次吃完。",
  "tools": [
    "种子",
    "容器",
    "标签",
    "记录本",
    "水壶"
  ],
  "steps": [
    "选择生长快、空间需求小的叶菜或香草。",
    "不要一次把所有种子播完，把种子分成几批。",
    "每隔几天或一周播一小批，形成轮播。",
    "每个容器贴播种日期和作物名。",
    "先采外叶或间苗，不一次拔光全部。",
    "记录哪一批发芽好、哪一批失败，调整浇水和光照。",
    "保留一部分种子，不把全部希望压在一次播种上。"
  ],
  "check": [
    "播种日期分批。",
    "种子没有一次用完。",
    "收获不是一次性拔光。"
  ],
  "common_mistakes": [
    "全部种子一口气撒完。",
    "忘记哪盆什么时候种。",
    "第一批失败后没有备用种子。"
  ],
  "fallback": [
    "种子少时，先做小规模试种，确认发芽和土壤再扩大。"
  ],
  "stop_or_escalate": [
    "连续发霉、虫害、烂根或发芽率极低时，停止扩大种植，先修正条件。"
  ],
  "notes": "轮播的目标不是菜多，而是不断档。",
