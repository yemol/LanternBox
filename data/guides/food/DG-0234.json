{
  "id": "DG-0234",
  "title": "雨季种植防烂根",
  "category": "种植养殖与采集",
  "priority": "P1",
  "scenario": "连续降雨、潮湿、容器积水，植物叶黄、倒伏或根部发臭。",
  "goal": "减少积水导致的烂根和霉菌。",
  "tools": [
    "木板",
    "石头",
    "遮雨布",
    "小铲",
    "标签"
  ],
  "steps": [
    "雨前把容器垫高，确保底部排水孔不被堵住。",
    "连续雨天减少浇水，先摸土再决定。",
    "把怕涝作物移到半遮雨位置。",
    "清理盆底托盘积水。",
    "发现根部发臭或土长期泥浆状，停止浇水并改善通风。",
    "剪掉腐烂叶片，降低霉菌扩散。",
    "雨后记录哪些容器积水严重，调整位置。"
  ],
  "check": [
    "容器底部不泡水。",
    "托盘无长期积水。",
    "雨季浇水减少。"
  ],
  "common_mistakes": [
    "下雨还天天浇水。",
    "容器底孔被泥堵住。",
    "盆底积水养蚊子。"
  ],
  "fallback": [
    "无法移动容器时，在上方加临时遮雨，或挖排水槽让水离开。"
  ],
  "stop_or_escalate": [
    "根部腐臭、植物大面积倒伏、土壤发霉、蚊虫滋生时，重做排水。"
  ],
  "notes": "雨季种植要先管水出去。",
