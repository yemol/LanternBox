{
  "id": "DG-0608",
  "title": "霉变粮食和坚果停用",
  "category": "食物",
  "priority": "P0",
  "scenario": "粮食或坚果出现霉斑、霉味、结块或虫蛀，局部去除不能可靠排除毒素风险。",
  "goal": "快速停用霉变批次，保护剩余干粮不被交叉污染。",
  "keywords": [
    "食物",
    "食物",
    "霉变粮食和坚果停用",
    "长期断供",
    "小团队",
    "行动卡",
    "霉变粮食和坚果停用",
    "停止线",
    "降级处理"
  ],
  "tools": [
    "手套",
    "密封袋",
    "标签",
    "筛网",
    "干燥容器",
    "记录纸"
  ],
  "steps": [
    "先停止翻拣食用，把可疑袋口扎紧，避免霉粉扩散到其他干粮。",
    "检查同箱或同袋其他食物是否受潮、结块、异味或虫害，按批次分开。",
    "对有霉斑、明显霉味、黏连或变色的粮食坚果整批禁食，不只挖掉表层。",
    "把未受影响食物转入干燥、离地、有盖容器，并写上检查日期。",
    "记录霉变来源：漏水、地面返潮、容器破损或存放过久，用于调整储存位置。"
  ],
  "check": [
    "霉变批次已密封并标记禁食。",
    "相邻干粮已重新分区。",
    "储存位置已离地防潮。"
  ],
  "common_mistakes": [
    "洗一洗或炒一炒继续吃。",
    "把霉变部分挑掉后混回总袋。",
    "处理霉粮后不清洁手和工具。"
  ],
  "fallback": [
    "食物不足时，优先减少消耗和寻找替代来源，不用霉变粮补缺口。",
    "容器不足时，用内衬袋加高处存放，至少隔开地面和墙角潮气。"
  ],
  "stop_or_escalate": [
    "发现多人胃肠不适或同一区域持续返潮时，停止使用该储粮点。",
    "霉变扩散到主要库存时，启动重新清点和配给压缩。"
  ],
