{
  "id": "DG-0236",
  "title": "简易育苗流程",
  "category": "种植养殖与采集",
  "priority": "P1",
  "scenario": "种子有限，希望提高发芽和成苗概率。",
  "goal": "先育苗再移栽，减少种子浪费。",
  "tools": [
    "小容器",
    "土",
    "标签",
    "喷壶",
    "遮阴物"
  ],
  "steps": [
    "选择小容器，底部有排水孔。",
    "装入干净、松散、不过湿的土。",
    "每个容器少量播种，贴作物和日期标签。",
    "播种后轻轻覆土，不要压实。",
    "用喷壶或少量水保持湿润，不冲走种子。",
    "发芽后逐渐增加光照，避免突然暴晒。",
    "长到较稳后再移入大容器或菜地。"
  ],
  "check": [
    "育苗容器有排水。",
    "每批有日期标签。",
    "幼苗没有被水冲倒或暴晒。"
  ],
  "common_mistakes": [
    "种子撒一大片无法管理。",
    "没有标签搞混作物。",
    "刚发芽就暴晒。"
  ],
  "fallback": "没有喷壶时，用瓶盖扎小孔做简易洒水瓶。",
  "stop_or_escalate": [
    "幼苗大面积倒伏、发霉、徒长细弱时，调整水分和光照。"
  ],
  "notes": "育苗是把种子的风险先缩小。",
